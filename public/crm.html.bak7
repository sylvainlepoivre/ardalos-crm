<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ardalos CRM — Groupe · Plateforme complète</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════
   TOKENS & RESET
══════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
body{font-family:'DM Sans',sans-serif;background:#F3F4F8;color:#1F2937;min-height:100vh;overflow-x:hidden}
:root{
  /* Brand */
  --ard-blue:#1A2C6B;--ard-blue-mid:#223580;--ard-blue-light:#EEF1F8;--ard-blue-faint:#F5F6FC;
  --ard-gold:#C9A84C;--ard-gold-light:#FDF6E3;--ard-gold-border:#DFC070;
  --ard-dark:#0D1A42;--ard-dark2:#162151;
  /* Grays */
  --g50:#FAFAFA;--g100:#F4F5F7;--g200:#E8EAED;--g300:#D1D5DB;
  --g400:#9CA3AF;--g500:#6B7280;--g600:#4B5563;--g700:#374151;--g800:#1F2937;--g900:#111827;
  /* Semantic */
  --green:#059669;--green-bg:#ECFDF5;--green-bdr:#A7F3D0;
  --amber:#D97706;--amber-bg:#FFFBEB;--amber-bdr:#FCD34D;
  --red:#DC2626;--red-bg:#FEF2F2;--red-bdr:#FECACA;
  --teal:#0891B2;--teal-bg:#ECFEFF;--teal-bdr:#A5F3FC;
  --purple:#7C3AED;--purple-bg:#F5F3FF;--purple-bdr:#C4B5FD;
  /* Layout */
  --sw:248px;--th:56px;
  /* Radii */
  --r4:4px;--r8:8px;--r12:12px;--r16:16px;--r20:20px;
  /* Shadows */
  --s1:0 1px 3px rgba(26,44,107,.07);
  --s2:0 4px 16px rgba(26,44,107,.10);
  --s3:0 8px 32px rgba(26,44,107,.14);
  --s4:0 16px 48px rgba(26,44,107,.18);
  --tr:.15s ease;
}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--g300);border-radius:99px}
input,select,textarea,button{font-family:'DM Sans',sans-serif}

/* ══════════════════════════════════
   APP SHELL
══════════════════════════════════ */
#app{display:flex;min-height:100vh}

/* ══════════════════════════════════
   SIDEBAR
══════════════════════════════════ */
#sidebar{
  width:var(--sw);min-width:var(--sw);
  background:var(--ard-dark);
  display:flex;flex-direction:column;
  position:fixed;top:0;bottom:0;left:0;z-index:200;
  overflow:hidden;overflow-y:auto;
  transition:transform var(--tr);
}
#sidebar::-webkit-scrollbar{width:0}

.sb-logo{
  padding:20px 18px 16px;
  border-bottom:1px solid rgba(255,255,255,.06);
  display:flex;align-items:center;gap:10px;flex-shrink:0;
}
.sb-logo-mark{
  width:36px;height:36px;
  border-radius:var(--r8);
  background:linear-gradient(145deg,var(--ard-blue),var(--ard-blue-mid));
  border:2px solid rgba(201,168,76,.5);
  display:flex;align-items:center;justify-content:center;
  font-family:'Playfair Display',serif;font-size:15px;font-weight:700;
  color:var(--ard-gold);flex-shrink:0;
}
.sb-logo-text{line-height:1.15}
.sb-logo-text .t1{font-family:'Playfair Display',serif;font-size:14px;font-weight:600;color:#fff;letter-spacing:.01em}
.sb-logo-text .t2{font-size:10px;color:rgba(255,255,255,.35);letter-spacing:.1em;text-transform:uppercase}

.entity-sw{
  margin:10px 12px 4px;
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.08);
  border-radius:var(--r8);
  padding:9px 12px;cursor:pointer;
  display:flex;align-items:center;justify-content:space-between;gap:8px;
  transition:background var(--tr);
}
.entity-sw:hover{background:rgba(255,255,255,.09)}
.entity-sw-info .name{font-size:12px;font-weight:500;color:#fff}
.entity-sw-info .role{font-size:10px;color:rgba(255,255,255,.35);margin-top:1px}
.entity-sw-chevron{font-size:11px;color:rgba(255,255,255,.25)}

.nav-section{padding:4px 0}
.nav-section-label{
  font-size:10px;font-weight:600;
  color:rgba(255,255,255,.22);
  letter-spacing:.1em;text-transform:uppercase;
  padding:10px 18px 3px;
}
.nav-item{
  display:flex;align-items:center;gap:9px;
  padding:7px 12px 7px 18px;
  cursor:pointer;
  color:rgba(255,255,255,.45);
  font-size:13px;font-weight:400;
  transition:all var(--tr);
  position:relative;user-select:none;
}
.nav-item:hover{color:rgba(255,255,255,.8);background:rgba(255,255,255,.04)}
.nav-item.active{color:#fff;font-weight:500;background:rgba(201,168,76,.1)}
.nav-item.active::before{
  content:'';position:absolute;left:0;top:25%;bottom:25%;
  width:2.5px;background:var(--ard-gold);border-radius:0 2px 2px 0;
}
.nav-ic{width:15px;height:15px;flex-shrink:0;opacity:.65}
.nav-item.active .nav-ic,.nav-item:hover .nav-ic{opacity:1}
.nav-badge{
  margin-left:auto;
  background:var(--red);color:#fff;
  font-size:10px;font-weight:600;
  padding:1px 5px;border-radius:99px;
  min-width:17px;text-align:center;
  line-height:1.5;
}
.nav-badge.amber{background:var(--ard-gold);color:var(--ard-dark)}
.nav-badge.blue{background:rgba(201,168,76,.15);color:var(--ard-gold);border:1px solid rgba(201,168,76,.25)}

.sb-footer{
  margin-top:auto;padding:12px;
  border-top:1px solid rgba(255,255,255,.06);flex-shrink:0;
}
.user-row{
  display:flex;align-items:center;gap:8px;
  padding:8px;border-radius:var(--r8);
  cursor:pointer;transition:background var(--tr);
}
.user-row:hover{background:rgba(255,255,255,.05)}
.user-av{
  width:30px;height:30px;border-radius:50%;
  background:rgba(201,168,76,.18);
  border:1.5px solid rgba(201,168,76,.35);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:600;color:var(--ard-gold);flex-shrink:0;
}
.user-info-wrap{flex:1;overflow:hidden}
.user-name-text{font-size:12px;font-weight:500;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.user-role-text{font-size:10px;color:rgba(255,255,255,.3)}

/* ══════════════════════════════════
   MAIN
══════════════════════════════════ */
#main{margin-left:var(--sw);flex:1;display:flex;flex-direction:column;min-height:100vh}

/* ══════════════════════════════════
   TOPBAR
══════════════════════════════════ */
#topbar{
  height:var(--th);background:#fff;
  border-bottom:1px solid var(--g200);
  display:flex;align-items:center;
  padding:0 24px;gap:12px;
  position:sticky;top:0;z-index:100;
}
.breadcrumb{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--g400)}
.breadcrumb-sep{color:var(--g300)}
.breadcrumb-cur{color:var(--g800);font-weight:500}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:8px}
.search-wrap{
  display:flex;align-items:center;gap:7px;
  background:var(--g100);border:1px solid var(--g200);
  border-radius:var(--r8);padding:6px 12px;width:230px;
  transition:all var(--tr);cursor:text;
}
.search-wrap:focus-within{background:#fff;border-color:var(--ard-blue);box-shadow:0 0 0 3px rgba(26,44,107,.07)}
.search-wrap input{border:none;background:transparent;font-size:13px;color:var(--g700);outline:none;width:100%}
.search-wrap input::placeholder{color:var(--g400)}
.search-ic{color:var(--g400);font-size:14px;flex-shrink:0}
.tb-btn{
  width:34px;height:34px;border:1px solid var(--g200);
  border-radius:var(--r8);background:#fff;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  color:var(--g500);font-size:14px;transition:all var(--tr);position:relative;
}
.tb-btn:hover{background:var(--ard-blue-faint);border-color:var(--ard-blue);color:var(--ard-blue)}
.notif-dot{position:absolute;top:7px;right:7px;width:6px;height:6px;border-radius:50%;background:var(--red);border:1.5px solid #fff}
.btn-p{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--ard-blue);color:#fff;
  border:none;border-radius:var(--r8);
  padding:7px 14px;font-size:12px;font-weight:500;
  cursor:pointer;transition:all var(--tr);white-space:nowrap;
}
.btn-p:hover{background:var(--ard-blue-mid);box-shadow:0 4px 12px rgba(26,44,107,.25);transform:translateY(-1px)}
.btn-s{
  display:inline-flex;align-items:center;gap:6px;
  background:#fff;color:var(--g600);
  border:1px solid var(--g200);border-radius:var(--r8);
  padding:6px 12px;font-size:12px;font-weight:500;
  cursor:pointer;transition:all var(--tr);white-space:nowrap;
}
.btn-s:hover{background:var(--g50);border-color:var(--g300)}
.btn-g{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--ard-gold);color:var(--ard-dark);
  border:none;border-radius:var(--r8);
  padding:7px 14px;font-size:12px;font-weight:600;
  cursor:pointer;transition:all var(--tr);
}
.btn-g:hover{filter:brightness(1.07);transform:translateY(-1px)}
.btn-danger{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--red-bg);color:var(--red);
  border:1px solid var(--red-bdr);border-radius:var(--r8);
  padding:6px 12px;font-size:12px;font-weight:500;
  cursor:pointer;transition:all var(--tr);
}
.btn-danger:hover{background:var(--red);color:#fff}

/* ══════════════════════════════════
   CONTENT
══════════════════════════════════ */
#content{flex:1;padding:24px;overflow-y:auto}
.page{display:none}
.page.active{display:block;animation:pg-in .2s ease}
@keyframes pg-in{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

.page-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:22px;gap:12px}
.page-hdr-left .page-title{font-family:'Playfair Display',serif;font-size:1.45rem;color:var(--ard-dark);font-weight:600;line-height:1.2}
.page-hdr-left .page-sub{font-size:13px;color:var(--g400);margin-top:3px}
.page-hdr-right{display:flex;gap:8px;flex-shrink:0;margin-top:2px}

/* ══════════════════════════════════
   KPI GRID
══════════════════════════════════ */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:20px}
.kpi{
  background:#fff;border:1px solid var(--g200);border-radius:var(--r12);
  padding:15px 17px;position:relative;overflow:hidden;
  transition:all var(--tr);cursor:default;
}
.kpi:hover{box-shadow:var(--s2);transform:translateY(-1px)}
.kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:2.5px;background:var(--ard-blue);border-radius:var(--r12) var(--r12) 0 0}
.kpi.gold::after{background:var(--ard-gold)}
.kpi.green::after{background:var(--green)}
.kpi.red::after{background:var(--red)}
.kpi.teal::after{background:var(--teal)}
.kpi.purple::after{background:var(--purple)}
.kpi-label{font-size:10px;font-weight:600;color:var(--g400);text-transform:uppercase;letter-spacing:.07em;margin-bottom:7px}
.kpi-value{font-size:24px;font-weight:600;color:var(--g900);line-height:1;font-family:'DM Sans',sans-serif}
.kpi-sub{font-size:11px;margin-top:5px;display:flex;align-items:center;gap:4px;color:var(--g400)}
.kpi-sub.up{color:var(--green)}.kpi-sub.down{color:var(--red)}

/* ══════════════════════════════════
   CARDS
══════════════════════════════════ */
.card{background:#fff;border:1px solid var(--g200);border-radius:var(--r12);overflow:hidden}
.card-h{padding:13px 18px;border-bottom:1px solid var(--g100);display:flex;align-items:center;justify-content:space-between;gap:8px}
.card-title{font-size:13px;font-weight:600;color:var(--g800);display:flex;align-items:center;gap:6px}
.card-b{padding:16px 18px}
.card-f{padding:10px 18px;border-top:1px solid var(--g100);background:var(--g50);display:flex;align-items:center;gap:8px}
.card-accent-blue{border-top:3px solid var(--ard-blue)}
.card-accent-gold{border-top:3px solid var(--ard-gold)}

/* ══════════════════════════════════
   GRID LAYOUTS
══════════════════════════════════ */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.g65{display:grid;grid-template-columns:65fr 35fr;gap:16px}
.g70{display:grid;grid-template-columns:70fr 30fr;gap:16px}
.g35{display:grid;grid-template-columns:35fr 65fr;gap:16px}

/* ══════════════════════════════════
   BADGES
══════════════════════════════════ */
.badge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:99px;font-size:11px;font-weight:500;white-space:nowrap}
.b-blue{background:#EFF6FF;color:#1D4ED8;border:1px solid #BFDBFE}
.b-green{background:var(--green-bg);color:#065F46;border:1px solid var(--green-bdr)}
.b-amber{background:var(--amber-bg);color:#92400E;border:1px solid var(--amber-bdr)}
.b-red{background:var(--red-bg);color:#991B1B;border:1px solid var(--red-bdr)}
.b-gray{background:var(--g100);color:var(--g600);border:1px solid var(--g200)}
.b-gold{background:var(--ard-gold-light);color:#7B5E1A;border:1px solid var(--ard-gold-border)}
.b-navy{background:var(--ard-blue-light);color:var(--ard-blue);border:1px solid #C7D2FE}
.b-teal{background:var(--teal-bg);color:#0E7490;border:1px solid var(--teal-bdr)}
.b-purple{background:var(--purple-bg);color:#6D28D9;border:1px solid var(--purple-bdr)}

/* ══════════════════════════════════
   PROGRESS
══════════════════════════════════ */
.prog{height:4px;background:var(--g200);border-radius:99px;overflow:hidden}
.prog-fill{height:100%;border-radius:99px;background:var(--ard-blue);transition:width .6s ease}
.prog-fill.gold{background:var(--ard-gold)}
.prog-fill.green{background:var(--green)}
.prog-fill.red{background:var(--red)}
.prog-fill.teal{background:var(--teal)}

/* ══════════════════════════════════
   DATA TABLE
══════════════════════════════════ */
.dt{width:100%;border-collapse:collapse}
.dt th{font-size:10px;font-weight:600;color:var(--g500);text-transform:uppercase;letter-spacing:.07em;padding:9px 14px;background:var(--g50);border-bottom:1px solid var(--g200);text-align:left;white-space:nowrap}
.dt td{padding:11px 14px;border-bottom:1px solid var(--g100);font-size:13px;color:var(--g600);vertical-align:middle}
.dt tr:last-child td{border-bottom:none}
.dt tbody tr{cursor:pointer;transition:background var(--tr)}
.dt tbody tr:hover td{background:var(--g50)}
.dt .name-cell{font-weight:500;color:var(--g900)}

/* ══════════════════════════════════
   AVATAR
══════════════════════════════════ */
.av{width:30px;height:30px;border-radius:50%;background:var(--ard-blue-light);color:var(--ard-blue);font-size:11px;font-weight:600;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0}
.av-lg{width:44px;height:44px;font-size:15px}
.av-xl{width:52px;height:52px;font-size:17px}

/* ══════════════════════════════════
   TIMELINE
══════════════════════════════════ */
.tl{display:flex;flex-direction:column}
.tl-item{display:flex;gap:11px;padding:9px 0;position:relative}
.tl-item:not(:last-child)::after{content:'';position:absolute;left:10px;top:30px;bottom:0;width:1px;background:var(--g200)}
.tl-dot{width:22px;height:22px;border-radius:50%;background:#fff;border:2px solid var(--ard-blue);display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;color:var(--ard-blue);z-index:1}
.tl-dot.green{border-color:var(--green);color:var(--green)}
.tl-dot.gold{border-color:var(--ard-gold);color:var(--ard-gold)}
.tl-dot.red{border-color:var(--red);color:var(--red)}
.tl-dot.gray{border-color:var(--g300);color:var(--g400)}
.tl-body{flex:1;padding-top:1px}
.tl-action{font-size:13px;font-weight:500;color:var(--g800)}
.tl-meta{font-size:11px;color:var(--g400);margin-top:2px}
.tl-note{font-size:12px;color:var(--g600);margin-top:5px;padding:6px 10px;background:var(--g50);border-radius:var(--r4);border-left:2.5px solid var(--g300)}

/* ══════════════════════════════════
   PIPELINE KANBAN
══════════════════════════════════ */
.kanban-wrap{display:flex;gap:12px;overflow-x:auto;padding-bottom:12px;min-height:420px}
.kb-col{min-width:220px;max-width:220px;background:var(--g100);border:1px solid var(--g200);border-radius:var(--r12);display:flex;flex-direction:column}
.kb-col-h{padding:10px 12px;border-bottom:1px solid var(--g200);display:flex;align-items:center;justify-content:space-between}
.kb-col-name{font-size:12px;font-weight:600;color:var(--g700)}
.kb-col-count{font-size:11px;color:var(--g400);font-weight:500}
.kb-body{flex:1;padding:8px;display:flex;flex-direction:column;gap:7px;min-height:80px}
.kb-card{background:#fff;border:1px solid var(--g200);border-radius:var(--r8);padding:10px 12px;cursor:pointer;transition:all var(--tr)}
.kb-card:hover{border-color:var(--ard-blue);box-shadow:var(--s1);transform:translateY(-1px)}
.kb-card.urgent{border-color:var(--red);background:var(--red-bg)}
.kb-card.winning{border-color:var(--green);background:var(--green-bg)}
.kb-card-name{font-size:12px;font-weight:600;color:var(--g800)}
.kb-card-co{font-size:11px;color:var(--g500);margin-top:1px}
.kb-card-f{display:flex;align-items:center;justify-content:space-between;margin-top:7px}
.kb-card-val{font-size:12px;font-weight:600;color:var(--ard-blue)}

/* ══════════════════════════════════
   ALERTS
══════════════════════════════════ */
.alert{border-radius:var(--r8);padding:11px 14px;display:flex;align-items:flex-start;gap:10px;font-size:13px;margin-bottom:12px}
.alert-ic{font-size:15px;flex-shrink:0;margin-top:1px}
.alert-title{font-weight:600;margin-bottom:2px}
.alert-r{background:var(--red-bg);border:1px solid var(--red-bdr);color:#7F1D1D}
.alert-a{background:var(--amber-bg);border:1px solid var(--amber-bdr);color:#78350F}
.alert-g{background:var(--green-bg);border:1px solid var(--green-bdr);color:#064E3B}
.alert-b{background:var(--ard-blue-faint);border:1px solid #C7D2FE;color:var(--ard-blue)}

/* ══════════════════════════════════
   FORMS
══════════════════════════════════ */
.fg{margin-bottom:13px}
.flabel{display:block;font-size:12px;font-weight:500;color:var(--g600);margin-bottom:4px}
.flabel .req{color:var(--red)}
.finput,.fselect{
  width:100%;border:1px solid var(--g300);border-radius:var(--r8);
  padding:8px 11px;font-size:13px;color:var(--g800);
  background:#fff;outline:none;transition:border-color var(--tr);
}
.finput:focus,.fselect:focus{border-color:var(--ard-blue);box-shadow:0 0 0 3px rgba(26,44,107,.07)}
.finput::placeholder{color:var(--g400)}
.fselect{cursor:pointer;appearance:none;background-image:url("data:image/svg+xml,%3Csvg width='10' height='10' viewBox='0 0 10 10' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1.5 3.5l3.5 3.5 3.5-3.5' stroke='%239CA3AF' stroke-width='1.5' fill='none'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 10px center;padding-right:26px}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.ftextarea{width:100%;border:1px solid var(--g300);border-radius:var(--r8);padding:8px 11px;font-size:13px;color:var(--g800);background:#fff;outline:none;resize:vertical;min-height:72px;transition:border-color var(--tr)}
.ftextarea:focus{border-color:var(--ard-blue);box-shadow:0 0 0 3px rgba(26,44,107,.07)}

/* ══════════════════════════════════
   TABS
══════════════════════════════════ */
.tabs{display:flex;gap:0;border-bottom:1px solid var(--g200);margin-bottom:18px;overflow-x:auto}
.tab{padding:9px 15px;font-size:12px;font-weight:500;color:var(--g500);cursor:pointer;border-bottom:2px solid transparent;transition:all var(--tr);white-space:nowrap}
.tab:hover{color:var(--g800)}
.tab.active{color:var(--ard-blue);border-bottom-color:var(--ard-blue);font-weight:600}

/* ══════════════════════════════════
   STAT INLINE
══════════════════════════════════ */
.si{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--g100)}
.si:last-child{border-bottom:none}
.si-l{font-size:12px;color:var(--g500)}
.si-r{font-size:13px;font-weight:500;color:var(--g800)}

/* ══════════════════════════════════
   AFDAS SPECIFIC
══════════════════════════════════ */
.afdas-card{border-radius:var(--r8);padding:12px 14px;margin-bottom:9px;position:relative}
.afdas-ok{background:var(--green-bg);border:1px solid var(--green-bdr)}
.afdas-warn{background:var(--amber-bg);border:1px solid var(--amber-bdr)}
.afdas-ko{background:var(--red-bg);border:1px solid var(--red-bdr)}
.afdas-hdr{font-size:13px;font-weight:600;margin-bottom:5px;display:flex;align-items:center;gap:6px}
.afdas-ok .afdas-hdr{color:#065F46}
.afdas-warn .afdas-hdr{color:#78350F}
.afdas-ko .afdas-hdr{color:#7F1D1D}
.afdas-detail{font-size:12px}
.afdas-ok .afdas-detail{color:#047857}
.afdas-warn .afdas-detail{color:#92400E}
.afdas-ko .afdas-detail{color:#991B1B}
.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dot-ok{background:var(--green)}.dot-warn{background:var(--amber)}.dot-ko{background:var(--red)}

/* ══════════════════════════════════
   QUALIOPI
══════════════════════════════════ */
.qi-row{display:flex;align-items:center;gap:9px;padding:7px 0;border-bottom:1px solid var(--g100)}
.qi-row:last-child{border-bottom:none}
.qi-num{width:23px;height:23px;border-radius:50%;font-size:10px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.qi-ok{background:var(--green-bg);color:#065F46}
.qi-warn{background:var(--amber-bg);color:#92400E}
.qi-ko{background:var(--red-bg);color:#991B1B}
.qi-lbl{font-size:12px;color:var(--g700);flex:1}

/* ══════════════════════════════════
   DOCUMENT TRACKER
══════════════════════════════════ */
.doc-row{display:flex;align-items:center;gap:9px;padding:7px 0;border-bottom:1px solid var(--g100)}
.doc-row:last-child{border-bottom:none}
.doc-ic{width:26px;height:26px;border-radius:var(--r4);background:var(--ard-blue-light);color:var(--ard-blue);font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.doc-name{font-size:12px;color:var(--g700);flex:1}
.doc-st{font-size:11px;font-weight:500}
.doc-st.ok{color:var(--green)}.doc-st.pend{color:var(--amber)}.doc-st.miss{color:var(--red)}

/* ══════════════════════════════════
   MODALS
══════════════════════════════════ */
.modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.38);z-index:500;display:none;align-items:center;justify-content:center;padding:20px}
.modal-ov.open{display:flex}
.modal{background:#fff;border-radius:var(--r16);width:100%;max-width:520px;box-shadow:var(--s4);animation:m-in .18s ease;max-height:90vh;overflow-y:auto}
.modal-lg{max-width:720px}
.modal-xl{max-width:900px}
@keyframes m-in{from{opacity:0;transform:scale(.96) translateY(10px)}to{opacity:1;transform:none}}
.modal-h{padding:18px 22px 14px;border-bottom:1px solid var(--g200);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:#fff;z-index:1}
.modal-title{font-family:'Playfair Display',serif;font-size:1.1rem;color:var(--ard-dark)}
.modal-close{width:28px;height:28px;border-radius:50%;border:none;background:var(--g100);cursor:pointer;color:var(--g500);display:flex;align-items:center;justify-content:center;font-size:14px;transition:all var(--tr)}
.modal-close:hover{background:var(--g200)}
.modal-b{padding:18px 22px}
.modal-f{padding:12px 22px;border-top:1px solid var(--g100);display:flex;justify-content:flex-end;gap:8px;position:sticky;bottom:0;background:#fff}

/* ══════════════════════════════════
   DIVIDER
══════════════════════════════════ */
.divider{display:flex;align-items:center;gap:10px;margin:18px 0 13px}
.divider-label{font-size:10px;font-weight:600;color:var(--g400);text-transform:uppercase;letter-spacing:.09em;white-space:nowrap}
.divider-line{flex:1;height:1px;background:var(--g200)}

/* ══════════════════════════════════
   SECTION HEADER
══════════════════════════════════ */
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;margin-top:18px}
.sh-label{font-size:11px;font-weight:600;color:var(--g400);text-transform:uppercase;letter-spacing:.07em}

/* ══════════════════════════════════
   NOTIFICATION DRAWER
══════════════════════════════════ */
.notif-drawer{
  position:fixed;top:var(--th);right:0;
  width:350px;height:calc(100vh - var(--th));
  background:#fff;border-left:1px solid var(--g200);
  z-index:150;transform:translateX(100%);
  transition:transform .22s ease;
  display:flex;flex-direction:column;
}
.notif-drawer.open{transform:translateX(0)}
.notif-drawer-h{padding:14px 16px;border-bottom:1px solid var(--g200);display:flex;align-items:center;justify-content:space-between}
.notif-item{padding:11px 16px;border-bottom:1px solid var(--g100);cursor:pointer;transition:background var(--tr)}
.notif-item:hover{background:var(--g50)}
.notif-item.unread{background:#FAFBFF;border-left:3px solid var(--ard-blue)}
.notif-item.unread.urgent{background:var(--red-bg);border-left-color:var(--red)}
.notif-item-title{font-size:13px;font-weight:500;color:var(--g800)}
.notif-item-desc{font-size:12px;color:var(--g500);margin-top:2px;line-height:1.4}
.notif-item-time{font-size:11px;color:var(--g400);margin-top:4px}

/* ══════════════════════════════════
   WORKFLOW BUILDER
══════════════════════════════════ */
.wf-step{display:flex;align-items:flex-start;gap:10px;margin-bottom:7px}
.wf-num{width:24px;height:24px;border-radius:50%;background:var(--ard-blue);color:#fff;font-size:10px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.wf-num.trigger{background:var(--ard-gold);color:var(--ard-dark)}
.wf-num.condition{background:var(--purple);color:#fff}
.wf-content{flex:1;background:var(--g50);border:1px solid var(--g200);border-radius:var(--r8);padding:9px 12px}
.wf-title{font-size:12px;font-weight:600;color:var(--g800)}
.wf-desc{font-size:11px;color:var(--g500);margin-top:2px}
.wf-arrow{text-align:center;font-size:11px;color:var(--g400);margin:2px 0 2px 34px}

/* ══════════════════════════════════
   MISC UTILITIES
══════════════════════════════════ */
.flex{display:flex}.items-c{align-items:center}.items-s{align-items:flex-start}.justify-b{justify-content:space-between}
.gap-1{gap:4px}.gap-2{gap:8px}.gap-3{gap:12px}.gap-4{gap:16px}
.mt-1{margin-top:4px}.mt-2{margin-top:8px}.mt-3{margin-top:12px}.mt-4{margin-top:16px}.mt-6{margin-top:24px}
.mb-2{margin-bottom:8px}.mb-3{margin-bottom:12px}.mb-4{margin-bottom:16px}.mb-6{margin-bottom:24px}
.text-xs{font-size:11px}.text-sm{font-size:12px}.text-md{font-size:13px}
.text-muted{color:var(--g400)}.text-blue{color:var(--ard-blue)}.text-gold{color:var(--ard-gold)}
.text-green{color:var(--green)}.text-red{color:var(--red)}.text-amber{color:var(--amber)}
.font-m{font-weight:500}.font-sb{font-weight:600}
.w-full{width:100%}
.truncate{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cursor-p{cursor:pointer}
.anim-kpi .kpi{animation:fadeUp .25s ease backwards}
.anim-kpi .kpi:nth-child(1){animation-delay:.04s}
.anim-kpi .kpi:nth-child(2){animation-delay:.08s}
.anim-kpi .kpi:nth-child(3){animation-delay:.12s}
.anim-kpi .kpi:nth-child(4){animation-delay:.16s}
.anim-kpi .kpi:nth-child(5){animation-delay:.20s}
.anim-kpi .kpi:nth-child(6){animation-delay:.24s}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

/* ══════════════════════════════════
   RESPONSIVE
══════════════════════════════════ */
@media(max-width:1024px){.g3{grid-template-columns:1fr 1fr}.g4{grid-template-columns:1fr 1fr}}
@media(max-width:900px){
  #sidebar{transform:translateX(-100%)}
  #sidebar.open{transform:none}
  #main{margin-left:0}
  .g2,.g65,.g70,.g35{grid-template-columns:1fr}
  .g3{grid-template-columns:1fr}
  #topbar{padding:0 16px}
  #content{padding:16px}
}
@media(max-width:600px){
  .kpi-grid{grid-template-columns:1fr 1fr}
  .page-hdr{flex-direction:column}
  .search-wrap{width:160px}
}
</style>
