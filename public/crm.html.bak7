<!-- ════════════════════════════════════════════
     JAVASCRIPT — NAVIGATION & LOGIQUE MÉTIER
════════════════════════════════════════════ -->
<script>
// ── Navigation ────────────────────────────
const PAGE_TITLES = {
  dashboard:'Dashboard',contacts:'Contacts',companies:'Entreprises',
  pipeline:'Pipeline',formations:'Formations',sessions:'Sessions & Cohortes',
  apprenants:'Apprenants',formateurs:'Formateurs',funding:'Dossiers financement',
  afdas:'Moteur AFDAS',qualiopi:'Qualiopi',documents:'Documents',
  workflows:'Workflows',tasks:'Tâches',reporting:'Reporting',campaigns:'Campagnes'
};

function navigate(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const el = document.getElementById('page-' + page);
  if (el) el.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => {
    n.classList.remove('active');
    if (n.dataset.page === page) n.classList.add('active');
  });
  document.getElementById('bc-page').textContent = PAGE_TITLES[page] || page;
  document.getElementById('notif-drawer').classList.remove('open');
  window.scrollTo(0,0);
}

document.querySelectorAll('.nav-item[data-page]').forEach(item => {
  item.addEventListener('click', () => navigate(item.dataset.page));
});

// ── Notifications ─────────────────────────
function toggleNotifs() {
  document.getElementById('notif-drawer').classList.toggle('open');
}

// ── Modals ────────────────────────────────
function openModal(id) { document.getElementById('modal-' + id)?.classList.add('open') }
function closeModal(id) { document.getElementById('modal-' + id)?.classList.remove('open') }

document.querySelectorAll('.modal-ov').forEach(ov => {
  ov.addEventListener('click', e => { if (e.target === ov) ov.classList.remove('open') });
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.querySelectorAll('.modal-ov.open').forEach(m => m.classList.remove('open'));
    document.getElementById('notif-drawer').classList.remove('open');
  }
  if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
    e.preventDefault();
    document.getElementById('global-search').focus();
  }
});

// ── Tabs ──────────────────────────────────
function setTab(el, groupId) {
  el.closest('.tabs').querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

// ── AFDAS Quick Calc ─────────────────────
function quickCalc() {
  const rate = parseInt(document.getElementById('quick-cat').value) || 40;
  const hours = parseInt(document.getElementById('quick-hours').value) || 0;
  const amount = rate * hours;
  document.getElementById('quick-amount').textContent = amount.toLocaleString('fr-FR') + '€ HT';

  let carence, warn = '';
  if (hours <= 40) { carence = '12 mois'; }
  else if (hours <= 80) { carence = '18 mois'; }
  else { carence = '24 mois'; warn = '⚠ Formation > 80h — Carence longue (24 mois). Envisager découpage en 2 blocs.'; }
  document.getElementById('quick-carence').textContent = carence;
  document.getElementById('quick-warning').textContent = warn;
}
quickCalc(); // init

// ── AFDAS Full Calculator ─────────────────
function fullCalcAfdas() {
  const catSel = document.getElementById('ac-cat');
  const seuil = parseInt(catSel.selectedOptions[0].dataset.seuil);
  const volume = parseInt(document.getElementById('ac-volume').value);
  const lastDur = parseInt(document.getElementById('ac-lastdur').value) || 0;
  const lastDate = new Date(document.getElementById('ac-lastdate').value);
  const formRate = parseInt(document.getElementById('ac-formcat').value);
  const newHours = parseInt(document.getElementById('ac-newdur').value) || 0;
  const today = new Date(2026, 3, 19);

  const eligible = volume >= seuil;
  let carenceMois = lastDur <= 40 ? 12 : lastDur <= 80 ? 18 : 24;
  const finCarence = new Date(lastDate);
  finCarence.setMonth(finCarence.getMonth() + carenceMois);
  const carenceOk = finCarence <= today;
  const daysLeft = Math.max(0, Math.ceil((finCarence - today) / 86400000));

  let newCarence = newHours <= 40 ? 12 : newHours <= 80 ? 18 : 24;
  const budget = formRate * newHours;
  const quadrimestre = today.getMonth() < 4 ? 'Q1 (Janv–Avril 2026)' : today.getMonth() < 8 ? 'Q2 (Mai–Août 2026)' : 'Q3 (Sept–Déc 2026)';
  const nextQ = today.getMonth() < 4 ? 'Q2 — dès le 1er mai 2026' : today.getMonth() < 8 ? 'Q3 — dès le 1er septembre 2026' : 'Q1 2027';

  const result = document.getElementById('ac-result');
  result.style.display = 'block';

  if (!eligible) {
    result.innerHTML = `<div class="afdas-card afdas-ko"><div class="afdas-hdr"><span class="dot dot-ko"></span>Non éligible</div><div class="afdas-detail">Volume déclaré : <strong>${volume}</strong> — Seuil requis : <strong>${seuil}</strong> pour cette catégorie.<br>Solution : Vérifier le volume réel ou envisager CPF / OPCO comme alternative.</div></div>`;
    return;
  }

  if (!carenceOk) {
    result.innerHTML = `
      <div class="afdas-card afdas-ko">
        <div class="afdas-hdr"><span class="dot dot-ko"></span>Éligible mais EN CARENCE — ${daysLeft} jours restants</div>
        <div class="afdas-detail">
          Dernière formation : ${lastDur}h → Carence de ${carenceMois} mois<br>
          Fin de carence : <strong>${finCarence.toLocaleDateString('fr-FR')}</strong><br>
          <div class="flex gap-2 mt-2">
            <span class="badge b-amber">AFDAS possible dès ${nextQ}</span>
            <span class="badge b-teal">CPF disponible maintenant</span>
          </div>
          <div style="margin-top:8px;padding:8px;background:rgba(0,0,0,.04);border-radius:var(--r4)">
            <strong>Recommandation :</strong> Utiliser CPF (${newHours}h × ${formRate}€ = max CPF disponible) en attendant la levée de carence AFDAS.
          </div>
        </div>
      </div>`;
    return;
  }

  result.innerHTML = `
    <div class="afdas-card afdas-ok">
      <div class="afdas-hdr"><span class="dot dot-ok"></span>Éligible — Prêt à déposer sur MyA</div>
      <div class="afdas-detail">
        Volume activité : <strong>${volume} / ${seuil} requis ✓</strong> · Carence : levée<br>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px">
          <div style="background:rgba(6,95,70,.12);border-radius:var(--r8);padding:9px;text-align:center">
            <div style="font-size:10px;color:#065F46;text-transform:uppercase;letter-spacing:.07em;font-weight:600">Financement estimé</div>
            <div style="font-size:22px;font-weight:700;color:#065F46;margin:3px 0">${budget.toLocaleString('fr-FR')}€</div>
            <div style="font-size:11px;color:#047857">${newHours}h × ${formRate}€/h</div>
          </div>
          <div style="background:rgba(6,95,70,.08);border-radius:var(--r8);padding:9px;text-align:center">
            <div style="font-size:10px;color:#065F46;text-transform:uppercase;letter-spacing:.07em;font-weight:600">Carence induite</div>
            <div style="font-size:22px;font-weight:700;color:#D97706;margin:3px 0">${newCarence} mois</div>
            <div style="font-size:11px;color:#047857">Prochaine action : ${nextQ}</div>
          </div>
        </div>
        <div style="margin-top:10px;padding:8px 10px;background:rgba(6,95,70,.08);border-radius:var(--r4);font-size:12px">
          <strong>Fenêtre recommandée :</strong> ${quadrimestre}<br>
          <strong>Règle d'or :</strong> Déposer en DÉBUT de quadrimestre — budget épuisé par ordre d'arrivée.<br>
          ${newHours > 80 ? '<strong>⚠ Formation >80h :</strong> Carence 24 mois. Envisager découpage en deux blocs de 40h.' : ''}
        </div>
      </div>
    </div>`;
}

// ── Entity Menu ───────────────────────────
function toggleEntityMenu() {
  // Placeholder — would open entity switcher
}

// ── Global Search ────────────────────────
document.getElementById('global-search').addEventListener('keyup', function(e) {
  if (e.key === 'Enter' && this.value.length > 1) {
    navigate('contacts');
    this.value = '';
  }
});
</script>


<!-- === CONNEXION SUPABASE POUR KPI DASHBOARD (ajoute pour donnees reelles) === -->
<script>
(function() {
  // Configuration Supabase
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';

  // Verifier que la lib Supabase est chargee
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    console.warn('[Ardalos KPI] Lib Supabase non chargee, KPI non mis a jour');
    return;
  }

  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function fmtEuro(n) {
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function setKpi(id, value, sub) {
    var el = document.getElementById(id);
    if (el) el.textContent = value;
    if (sub !== undefined) {
      var subEl = document.getElementById(id + '-sub');
      if (subEl) subEl.textContent = sub;
    }
  }

  async function loadKpis() {
    try {
      // --- 1. Leads actifs = nombre total de contacts ---
      var contactsR = await sb.from('contacts').select('id', { count: 'exact', head: true });
      setKpi('kpi-leads', contactsR.count || 0, 'Total contacts');

      // --- 2/3/4. Inscriptions + CA previsionnel + Apprenants confirmes ---
      var insR = await sb.from('formation_inscriptions').select('id, statut, montant_total_ht');
      var ins = insR.data || [];
      var actives = ins.filter(function(i) { return i.statut !== 'abandon'; });
      var confirmes = ins.filter(function(i) { return i.statut === 'confirme' || i.statut === 'present'; });
      var caTotal = actives.reduce(function(s, i) { return s + (Number(i.montant_total_ht) || 0); }, 0);

      setKpi('kpi-ca', fmtEuro(caTotal), 'HT · ' + actives.length + ' dossier' + (actives.length > 1 ? 's' : '') + ' actif' + (actives.length > 1 ? 's' : ''));
      setKpi('kpi-deals', actives.length, 'inscriptions actives');
      setKpi('kpi-apprenants', confirmes.length, confirmes.length + ' confirme' + (confirmes.length > 1 ? 's' : '') + ' / present' + (confirmes.length > 1 ? 's' : ''));

      // --- 5. Dossiers AFDAS ---
      var finR = await sb.from('formation_financements').select('id').eq('type_financement', 'AFDAS');
      var nbAfdas = (finR.data || []).length;
      setKpi('kpi-afdas', nbAfdas, nbAfdas === 0 ? 'Aucun' : 'dossiers AFDAS');

      console.log('[Ardalos KPI] OK charges');
    } catch (e) {
      console.error('[Ardalos KPI] Erreur:', e);
      ['kpi-leads', 'kpi-ca', 'kpi-deals', 'kpi-apprenants', 'kpi-afdas'].forEach(function(id) {
        setKpi(id, 'N/A', 'Erreur');
      });
    }
  }

  // Attendre que le DOM soit pret
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadKpis);
  } else {
    loadKpis();
  }
})();
</script>


<!-- === CONNEXION SUPABASE POUR KANBAN PIPELINE === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';

  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    console.warn('[Ardalos Pipeline] Lib Supabase non chargee');
    return;
  }
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  // Mapping statut_prospection -> colonne Kanban
  var STATUS_TO_COL = {
    'a_contacter':        'nouveau',
    'interesse':          'qualif',
    'en_discussion':      'qualif',
    'dossier_en_cours':   'dossier',
    'financement_demande':       'financement',
    'financement_en_instruction':'financement',
    'confirme':           'closing',
  };

  function fmtEuro(n) {
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function makeCard(ins) {
    var contact = ins.contacts || {};
    var session = ins.formation_sessions || {};
    var formation = session.formations || {};

    var nom = ((contact.prenom || '') + ' ' + (contact.nom || '')).trim() || '(sans nom)';
    var titreFormation = formation.titre || 'Formation';
    var montant = Number(ins.montant_total_ht) || 0;

    // Badge: commercial si present, sinon statut
    var badge = '';
    if (ins.commercial_responsable) {
      badge = '<span class="badge b-navy" style="font-size:10px">' + escapeHtml(ins.commercial_responsable) + '</span>';
    } else if (ins.statut === 'confirme') {
      badge = '<span class="badge b-green" style="font-size:10px">Confirme</span>';
    } else {
      badge = '<span class="badge b-gray" style="font-size:10px">Prospect</span>';
    }

    // Classe urgente si rappel prevu et date depassee
    var urgentClass = '';
    if (ins.date_rappel_prevu) {
      var today = new Date().toISOString().substring(0, 10);
      if (ins.date_rappel_prevu < today) urgentClass = ' urgent';
    }
    // Classe winning pour closing
    if (ins.statut === 'confirme') urgentClass = ' winning';

    return '<div class="kb-card' + urgentClass + '">' +
      '<div class="kb-card-name">' + escapeHtml(nom) + '</div>' +
      '<div class="kb-card-co">' + escapeHtml(titreFormation) + '</div>' +
      '<div class="kb-card-f">' +
        '<span class="kb-card-val">' + fmtEuro(montant) + '</span>' +
        badge +
      '</div>' +
    '</div>';
  }

  function getColKey(ins) {
    // Closing : statut d'inscription = confirme ou present
    if (ins.statut === 'confirme' || ins.statut === 'present') return 'closing';
    // Abandon : on les ignore
    if (ins.statut === 'abandon') return null;
    // Sinon on utilise le statut_prospection
    var sp = ins.statut_prospection;
    if (sp && STATUS_TO_COL[sp]) return STATUS_TO_COL[sp];
    // Par defaut : nouveau lead
    return 'nouveau';
  }

  async function loadPipeline() {
    try {
      var subtitleEl = document.getElementById('pipe-subtitle');
      var r = await sb.from('formation_inscriptions')
        .select('id, statut, statut_prospection, commercial_responsable, date_rappel_prevu, montant_total_ht, contacts(prenom, nom), formation_sessions(formations(titre))')
        .order('created_at', { ascending: false });

      if (r.error) throw r.error;
      var inscriptions = r.data || [];

      // Grouper par colonne
      var cols = { nouveau: [], qualif: [], dossier: [], financement: [], closing: [] };
      var actives = 0;
      var ca = 0;
      for (var i = 0; i < inscriptions.length; i++) {
        var ins = inscriptions[i];
        var key = getColKey(ins);
        if (key) {
          cols[key].push(ins);
          actives++;
          ca += Number(ins.montant_total_ht) || 0;
        }
      }

      // Render colonnes
      var colSums = {};
      Object.keys(cols).forEach(function(key) {
        var colEl = document.getElementById('pipe-col-' + key);
        var cntEl = document.getElementById('pipe-cnt-' + key);
        if (!colEl) return;

        var list = cols[key];
        var sum = list.reduce(function(s, x) { return s + (Number(x.montant_total_ht) || 0); }, 0);
        colSums[key] = sum;

        if (list.length === 0) {
          colEl.innerHTML = '<div style="padding:20px;text-align:center;color:#9ca3af;font-size:12px;font-style:italic">Aucun dossier</div>';
        } else {
          colEl.innerHTML = list.map(makeCard).join('');
        }
        if (cntEl) cntEl.textContent = list.length + ' · ' + fmtEuro(sum);
      });

      // Sous-titre
      if (subtitleEl) subtitleEl.textContent = actives + ' dossier' + (actives > 1 ? 's' : '') + ' actif' + (actives > 1 ? 's' : '') + ' · ' + fmtEuro(ca) + ' CA previsionnel';

      console.log('[Ardalos Pipeline] OK charge :', actives, 'dossiers,', fmtEuro(ca));
    } catch (e) {
      console.error('[Ardalos Pipeline] Erreur:', e);
      var subtitleEl = document.getElementById('pipe-subtitle');
      if (subtitleEl) subtitleEl.textContent = 'Erreur de chargement du pipeline';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadPipeline);
  } else {
    loadPipeline();
  }
})();
</script>


<!-- === CONNEXION SUPABASE POUR CONTACTS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';

  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    console.warn('[Ardalos Contacts] Lib Supabase non chargee');
    return;
  }
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function getInitials(prenom, nom) {
    var p = (prenom || '').trim();
    var n = (nom || '').trim();
    var ip = p.length > 0 ? p[0].toUpperCase() : '';
    var in_ = n.length > 0 ? n[0].toUpperCase() : '';
    return (ip + in_) || '??';
  }

  // Palette de couleurs pour les avatars (repartition stable via hash du nom)
  var AVATAR_COLORS = [
    { bg: 'var(--ard-blue)', fg: '#fff' },
    { bg: 'var(--ard-gold-light)', fg: 'var(--ard-gold)' },
    { bg: 'var(--green-bg)', fg: 'var(--green)' },
    { bg: 'var(--purple-bg)', fg: 'var(--purple)' },
    { bg: 'var(--teal-bg)', fg: 'var(--teal)' },
  ];
  function pickColor(name) {
    var sum = 0;
    for (var i = 0; i < name.length; i++) sum += name.charCodeAt(i);
    return AVATAR_COLORS[sum % AVATAR_COLORS.length];
  }

  function fmtDate(s) {
    if (!s) return '';
    var d = new Date(s);
    var now = new Date();
    var diffDays = Math.floor((now - d) / (1000 * 60 * 60 * 24));
    if (diffDays === 0) return 'Aujourd\'hui';
    if (diffDays === 1) return 'Hier';
    if (diffDays < 7) return 'Il y a ' + diffDays + 'j';
    if (diffDays < 30) return 'Il y a ' + Math.floor(diffDays / 7) + 'sem';
    return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' });
  }

  async function loadContacts() {
    try {
      var subtitleEl = document.getElementById('contacts-subtitle');
      var tbodyEl = document.getElementById('contacts-tbody');
      var paginationEl = document.getElementById('contacts-pagination');

      // 1. Tous les contacts
      var cR = await sb.from('contacts').select('*').order('created_at', { ascending: false });
      if (cR.error) throw cR.error;
      var contacts = cR.data || [];

      // 2. Toutes les inscriptions pour determiner statut
      var iR = await sb.from('formation_inscriptions').select('contact_id, statut, commercial_responsable, created_at').order('created_at', { ascending: false });
      var inscriptions = iR.data || [];

      // 3. Grouper inscriptions par contact
      var insByContact = {};
      for (var i = 0; i < inscriptions.length; i++) {
        var ins = inscriptions[i];
        if (!insByContact[ins.contact_id]) insByContact[ins.contact_id] = [];
        insByContact[ins.contact_id].push(ins);
      }

      // 4. Compter les nouveaux contacts cette semaine
      var oneWeekAgo = new Date();
      oneWeekAgo.setDate(oneWeekAgo.getDate() - 7);
      var nbNouveaux = contacts.filter(function(c) { return new Date(c.created_at) >= oneWeekAgo; }).length;

      // 5. Update sous-titre
      if (subtitleEl) {
        subtitleEl.textContent = contacts.length + ' contact' + (contacts.length > 1 ? 's' : '') + ' · ' + nbNouveaux + ' nouveau' + (nbNouveaux > 1 ? 'x' : '') + ' cette semaine';
      }

      // 6. Render tbody
      if (contacts.length === 0) {
        tbodyEl.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Aucun contact</td></tr>';
      } else {
        var rows = contacts.map(function(c) {
          var ins = insByContact[c.id] || [];
          var lastIns = ins[0];
          var nbIns = ins.length;
          var nbConfirmes = ins.filter(function(i) { return i.statut === 'confirme' || i.statut === 'present'; }).length;

          // Badge statut
          var statutBadge = '<span class="badge b-gray">Lead</span>';
          if (nbConfirmes > 0) statutBadge = '<span class="badge b-green">Client</span>';
          else if (nbIns > 0) statutBadge = '<span class="badge b-amber">Prospect</span>';

          // Badge type (heuristique simple: si entreprise dans inscriptions, Salarie, sinon Intermittent)
          var typeBadge = '<span class="badge b-navy">Stagiaire</span>';

          // Initiales + couleur
          var initials = getInitials(c.prenom, c.nom);
          var color = pickColor(c.prenom + c.nom);
          var avStyle = 'background:' + color.bg + ';color:' + color.fg;

          // Nombre d'inscriptions
          var nbInsHtml = nbIns > 0
            ? '<span class="badge b-teal">' + nbIns + ' inscription' + (nbIns > 1 ? 's' : '') + '</span>'
            : '<span class="text-xs text-muted">—</span>';

          // Commercial
          var commercial = lastIns && lastIns.commercial_responsable
            ? escapeHtml(lastIns.commercial_responsable)
            : '<span class="text-muted">—</span>';

          // Activite = derniere inscription ou creation contact
          var activityDate = lastIns ? lastIns.created_at : c.created_at;

          return '<tr>' +
            '<td><input type="checkbox" onclick="event.stopPropagation()"></td>' +
            '<td><div class="flex items-c gap-2">' +
              '<div class="av" style="' + avStyle + '">' + initials + '</div>' +
              '<div>' +
                '<div class="name-cell">' + escapeHtml((c.prenom || '') + ' ' + (c.nom || '')).trim() + '</div>' +
                '<div class="text-xs text-muted">' + escapeHtml(c.email || '—') + '</div>' +
              '</div>' +
            '</div></td>' +
            '<td>' + statutBadge + '</td>' +
            '<td>' + typeBadge + '</td>' +
            '<td class="text-xs">' + escapeHtml(c.telephone || '—') + '</td>' +
            '<td>' + nbInsHtml + '</td>' +
            '<td>' + commercial + '</td>' +
            '<td class="text-xs text-muted">' + fmtDate(activityDate) + '</td>' +
            '<td><button class="btn-s" style="font-size:11px;padding:3px 8px" onclick="event.stopPropagation()">Voir</button></td>' +
          '</tr>';
        });
        tbodyEl.innerHTML = rows.join('');
      }

      // 7. Update pagination footer
      if (paginationEl) {
        var shown = Math.min(contacts.length, contacts.length);
        paginationEl.textContent = contacts.length > 0
          ? '1–' + shown + ' sur ' + contacts.length
          : '0 contact';
      }

      console.log('[Ardalos Contacts] OK charges :', contacts.length, 'contacts,', nbNouveaux, 'nouveaux cette semaine');
    } catch (e) {
      console.error('[Ardalos Contacts] Erreur:', e);
      var tbodyEl = document.getElementById('contacts-tbody');
      if (tbodyEl) tbodyEl.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:20px;color:#dc2626">Erreur de chargement : ' + escapeHtml(e.message || 'inconnue') + '</td></tr>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadContacts);
  } else {
    loadContacts();
  }
})();
</script>


<!-- === CONNEXION SUPABASE POUR FORMATEURS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';

  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    console.warn('[Ardalos Formateurs] Lib Supabase non chargee');
    return;
  }
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function getInitials(prenom, nom) {
    var p = (prenom || '').trim();
    var n = (nom || '').trim();
    var ip = p.length > 0 ? p[0].toUpperCase() : '';
    var in_ = n.length > 0 ? n[0].toUpperCase() : '';
    return (ip + in_) || '??';
  }

  // Palette de couleurs pour les avatars (repartition stable via hash)
  var AVATAR_COLORS = [
    { bg: 'var(--ard-blue)', fg: '#fff' },
    { bg: 'var(--ard-dark2)', fg: 'var(--ard-gold)' },
    { bg: 'var(--teal-bg)', fg: 'var(--teal)' },
    { bg: 'var(--green-bg)', fg: 'var(--green)' },
    { bg: 'var(--purple-bg)', fg: 'var(--purple)' },
    { bg: 'var(--ard-gold-light)', fg: 'var(--ard-gold)' },
  ];
  function pickColor(name) {
    var sum = 0;
    for (var i = 0; i < name.length; i++) sum += name.charCodeAt(i);
    return AVATAR_COLORS[sum % AVATAR_COLORS.length];
  }

  async function loadFormateurs() {
    try {
      var subtitleEl = document.getElementById('formateurs-subtitle');
      var gridEl = document.getElementById('formateurs-grid');

      // 1. Tous les formateurs
      var fR = await sb.from('formateurs').select('*').order('nom', { ascending: true });
      if (fR.error) throw fR.error;
      var formateurs = fR.data || [];

      // 2. Toutes les sessions 2026 pour compter par formateur
      var anneeActuelle = new Date().getFullYear();
      var debutAnnee = anneeActuelle + '-01-01';
      var finAnnee = anneeActuelle + '-12-31';
      var sR = await sb.from('formation_sessions')
        .select('id, formateur_id, date_debut')
        .gte('date_debut', debutAnnee)
        .lte('date_debut', finAnnee);
      var sessions = sR.data || [];

      // 3. Toutes les inscriptions pour compter les apprenants par session
      var iR = await sb.from('formation_inscriptions').select('session_id, statut');
      var inscriptions = iR.data || [];

      // Map session -> nb apprenants
      var apprenantsBySession = {};
      for (var i = 0; i < inscriptions.length; i++) {
        var ins = inscriptions[i];
        if (ins.statut === 'abandon') continue;
        apprenantsBySession[ins.session_id] = (apprenantsBySession[ins.session_id] || 0) + 1;
      }

      // Agreger par formateur
      var statsByFormateur = {};
      formateurs.forEach(function(f) {
        statsByFormateur[f.id] = { nbSessions: 0, nbApprenants: 0 };
      });
      sessions.forEach(function(s) {
        if (s.formateur_id && statsByFormateur[s.formateur_id]) {
          statsByFormateur[s.formateur_id].nbSessions++;
          statsByFormateur[s.formateur_id].nbApprenants += (apprenantsBySession[s.id] || 0);
        }
      });

      // Update sous-titre
      if (subtitleEl) {
        subtitleEl.textContent = formateurs.length + ' formateur' + (formateurs.length > 1 ? 's' : '') + ' certifie' + (formateurs.length > 1 ? 's' : '') + ' · Tous Qualiopi';
      }

      // Render grid
      if (formateurs.length === 0) {
        gridEl.innerHTML = '<div style="grid-column:1/-1;padding:40px;text-align:center;color:#9ca3af;font-style:italic">Aucun formateur dans la base</div>';
      } else {
        var cards = formateurs.map(function(f) {
          var stats = statsByFormateur[f.id] || { nbSessions: 0, nbApprenants: 0 };
          var initials = getInitials(f.prenom, f.nom);
          var nomComplet = ((f.prenom || '') + ' ' + (f.nom || '')).trim() || 'Sans nom';
          var color = pickColor(nomComplet);
          var avStyle = 'background:' + color.bg + ';color:' + color.fg;
          var specialite = f.specialite || f.titre || 'Formateur';

          // Satisfaction : on a pas de donnees reelles, on laisse un placeholder
          var satisfaction = '<span class="text-muted">—</span>';

          return '<div class="card cursor-p" onmouseover="this.style.boxShadow=\'var(--s2)\'" onmouseout="this.style.boxShadow=\'none\'">' +
            '<div class="card-h"><div class="flex items-c gap-3">' +
              '<div class="av av-lg" style="' + avStyle + '">' + initials + '</div>' +
              '<div>' +
                '<div class="font-sb" style="color:var(--ard-dark)">' + escapeHtml(nomComplet) + '</div>' +
                '<div class="text-xs text-muted">' + escapeHtml(specialite) + '</div>' +
              '</div>' +
            '</div></div>' +
            '<div class="card-b">' +
              '<div class="si"><span class="si-l">Sessions ' + anneeActuelle + '</span><span class="si-r">' + stats.nbSessions + '</span></div>' +
              '<div class="si"><span class="si-l">Apprenants</span><span class="si-r">' + stats.nbApprenants + '</span></div>' +
              '<div class="si"><span class="si-l">Satisfaction</span><span class="si-r">' + satisfaction + '</span></div>' +
              '<div class="si"><span class="si-l">Qualiopi</span><span class="si-r"><span class="badge b-green">Conforme</span></span></div>' +
            '</div>' +
            '<div class="card-f"><button class="btn-s" style="font-size:11px">Fiche</button><button class="btn-p" style="font-size:11px;padding:4px 10px;margin-left:4px" onclick="navigate(\'documents\')">Docs</button></div>' +
          '</div>';
        });
        gridEl.innerHTML = cards.join('');
      }

      console.log('[Ardalos Formateurs] OK charges :', formateurs.length, 'formateurs');
    } catch (e) {
      console.error('[Ardalos Formateurs] Erreur:', e);
      var gridEl = document.getElementById('formateurs-grid');
      if (gridEl) gridEl.innerHTML = '<div style="grid-column:1/-1;padding:40px;text-align:center;color:#dc2626">Erreur de chargement : ' + escapeHtml(e.message || 'inconnue') + '</div>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadFormateurs);
  } else {
    loadFormateurs();
  }
})();
</script>


<!-- === CONNEXION SUPABASE POUR APPRENANTS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    console.warn('[Ardalos Apprenants] Lib Supabase non chargee');
    return;
  }
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function getInitials(prenom, nom) {
    var p = (prenom || '').trim();
    var n = (nom || '').trim();
    return ((p[0] || '').toUpperCase() + (n[0] || '').toUpperCase()) || '??';
  }

  var AVATAR_COLORS = [
    { bg: 'var(--ard-blue)', fg: '#fff' },
    { bg: 'var(--ard-gold-light)', fg: 'var(--ard-gold)' },
    { bg: 'var(--green-bg)', fg: 'var(--green)' },
    { bg: 'var(--purple-bg)', fg: 'var(--purple)' },
    { bg: 'var(--teal-bg)', fg: 'var(--teal)' },
  ];
  function pickColor(name) {
    var sum = 0;
    for (var i = 0; i < name.length; i++) sum += name.charCodeAt(i);
    return AVATAR_COLORS[sum % AVATAR_COLORS.length];
  }

  function fmtCohorte(dateDebut, dateFin) {
    if (!dateDebut) return '—';
    var d1 = new Date(dateDebut);
    var mois = ['Janv', 'Fev', 'Mars', 'Avr', 'Mai', 'Juin', 'Juil', 'Aout', 'Sept', 'Oct', 'Nov', 'Dec'];
    var s = mois[d1.getMonth()] + ' ' + d1.getFullYear();
    if (dateFin) {
      var d2 = new Date(dateFin);
      if (d2.getMonth() !== d1.getMonth() || d2.getFullYear() !== d1.getFullYear()) {
        s = mois[d1.getMonth()] + '–' + mois[d2.getMonth()] + ' ' + d2.getFullYear();
      }
    }
    return s;
  }

  function getAvancement(dateDebut, dateFin) {
    if (!dateDebut) return { pct: 0, label: 'A venir', cls: '' };
    var now = Date.now();
    var d1 = new Date(dateDebut).getTime();
    var d2 = dateFin ? new Date(dateFin).getTime() : null;
    if (now < d1) return { pct: 0, label: 'A venir', cls: '' };
    if (d2 && now > d2) return { pct: 100, label: 'Termine', cls: 'green' };
    if (d2 && d2 > d1) {
      var pct = Math.round(((now - d1) / (d2 - d1)) * 100);
      return { pct: pct, label: pct + '%', cls: pct >= 66 ? 'green' : (pct >= 33 ? '' : 'gold') };
    }
    return { pct: 50, label: 'En cours', cls: '' };
  }

  async function loadApprenants() {
    try {
      var subtitleEl = document.getElementById('apprenants-subtitle');
      var tbodyEl = document.getElementById('apprenants-tbody');

      // 1. Inscriptions actives + jointures
      var iR = await sb.from('formation_inscriptions')
        .select('id, statut, contact_id, session_id, contacts(prenom, nom), formation_sessions(date_debut, date_fin, formations(titre))')
        .neq('statut', 'abandon')
        .order('created_at', { ascending: false });
      if (iR.error) throw iR.error;
      var inscriptions = iR.data || [];

      // 2. Financements
      var fR = await sb.from('formation_financements').select('inscription_id, type_financement, statut_dossier');
      var finByIns = {};
      (fR.data || []).forEach(function(f) {
        if (!finByIns[f.inscription_id]) finByIns[f.inscription_id] = [];
        finByIns[f.inscription_id].push(f);
      });

      // Dedup par contact_id : on garde seulement la derniere inscription par personne
      var seenContacts = {};
      var apprenants = [];
      for (var i = 0; i < inscriptions.length; i++) {
        var ins = inscriptions[i];
        if (!ins.contact_id || seenContacts[ins.contact_id]) continue;
        seenContacts[ins.contact_id] = true;
        apprenants.push(ins);
      }

      // Calculer nb cohortes distinctes
      var cohortes = {};
      apprenants.forEach(function(a) {
        if (a.formation_sessions) {
          cohortes[a.formation_sessions.date_debut + '|' + (a.formation_sessions.formations ? a.formation_sessions.formations.titre : '')] = true;
        }
      });
      var nbCohortes = Object.keys(cohortes).length;

      // Sous-titre
      if (subtitleEl) {
        subtitleEl.textContent = apprenants.length + ' actif' + (apprenants.length > 1 ? 's' : '') + ' · ' + nbCohortes + ' cohorte' + (nbCohortes > 1 ? 's' : '');
      }

      // Render
      if (apprenants.length === 0) {
        tbodyEl.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Aucun apprenant actif</td></tr>';
      } else {
        var rows = apprenants.map(function(a) {
          var contact = a.contacts || {};
          var session = a.formation_sessions || {};
          var formation = session.formations || {};
          var nom = ((contact.prenom || '') + ' ' + (contact.nom || '')).trim() || 'Sans nom';
          var initials = getInitials(contact.prenom, contact.nom);
          var color = pickColor(nom);
          var avStyle = 'background:' + color.bg + ';color:' + color.fg;

          var cohorte = fmtCohorte(session.date_debut, session.date_fin);
          var avancement = getAvancement(session.date_debut, session.date_fin);

          // Financement
          var fins = finByIns[a.id] || [];
          var finBadge = '<span class="text-muted text-xs">—</span>';
          if (fins.length > 0) {
            var types = fins.map(function(f) { return f.type_financement; }).join(', ');
            var cls = 'b-navy';
            if (types.indexOf('AFDAS') !== -1) cls = 'b-navy';
            else if (types.indexOf('CPF') !== -1) cls = 'b-teal';
            else if (types.indexOf('OPCO') !== -1) cls = 'b-teal';
            finBadge = '<span class="badge ' + cls + '">' + escapeHtml(types) + '</span>';
          }

          return '<tr>' +
            '<td><div class="flex items-c gap-2">' +
              '<div class="av" style="' + avStyle + '">' + initials + '</div>' +
              '<div>' +
                '<div class="name-cell">' + escapeHtml(nom) + '</div>' +
                '<div class="text-xs text-muted">Stagiaire</div>' +
              '</div>' +
            '</div></td>' +
            '<td>' + escapeHtml(formation.titre || '—') + '</td>' +
            '<td>' + escapeHtml(cohorte) + '</td>' +
            '<td><div class="flex items-c gap-2">' +
              '<div class="prog" style="width:60px"><div class="prog-fill ' + avancement.cls + '" style="width:' + avancement.pct + '%"></div></div>' +
              '<span class="text-xs' + (avancement.cls ? ' text-' + avancement.cls : '') + '">' + avancement.label + '</span>' +
            '</div></td>' +
            '<td><span class="text-muted text-xs">—</span></td>' +
            '<td>' + finBadge + '</td>' +
            '<td><span class="text-muted text-xs">—</span></td>' +
            '<td><button class="btn-s" style="font-size:11px;padding:3px 8px">Voir</button></td>' +
          '</tr>';
        });
        tbodyEl.innerHTML = rows.join('');
      }

      console.log('[Ardalos Apprenants] OK charges :', apprenants.length, 'apprenants,', nbCohortes, 'cohortes');
    } catch (e) {
      console.error('[Ardalos Apprenants] Erreur:', e);
      var tbodyEl = document.getElementById('apprenants-tbody');
      if (tbodyEl) tbodyEl.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:20px;color:#dc2626">Erreur : ' + escapeHtml(e.message || 'inconnue') + '</td></tr>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadApprenants);
  } else {
    loadApprenants();
  }
})();
</script>


<!-- === CONNEXION SUPABASE POUR SESSIONS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtCohorte(dateDebut, dateFin) {
    if (!dateDebut) return '—';
    var d1 = new Date(dateDebut);
    var mois = ['Janv', 'Fev', 'Mars', 'Avr', 'Mai', 'Juin', 'Juil', 'Aout', 'Sept', 'Oct', 'Nov', 'Dec'];
    var s = mois[d1.getMonth()] + ' ' + d1.getFullYear();
    if (dateFin) {
      var d2 = new Date(dateFin);
      if (d2.getMonth() !== d1.getMonth() || d2.getFullYear() !== d1.getFullYear()) {
        s = mois[d1.getMonth()] + '–' + mois[d2.getMonth()] + ' ' + d2.getFullYear();
      }
    }
    return s;
  }

  function getAvancement(dateDebut, dateFin) {
    if (!dateDebut) return { pct: 0, label: '0%', cls: '', statut: 'A venir', statutCls: 'b-gray' };
    var now = Date.now();
    var d1 = new Date(dateDebut).getTime();
    var d2 = dateFin ? new Date(dateFin).getTime() : null;
    if (now < d1) return { pct: 0, label: '0%', cls: '', statut: 'Demarrage', statutCls: 'b-amber' };
    if (d2 && now > d2) return { pct: 100, label: '100%', cls: 'green', statut: 'Cloture', statutCls: 'b-navy' };
    if (d2 && d2 > d1) {
      var pct = Math.round(((now - d1) / (d2 - d1)) * 100);
      return {
        pct: pct,
        label: pct + '%',
        cls: pct >= 66 ? 'green' : (pct >= 33 ? '' : 'gold'),
        statut: 'En cours',
        statutCls: 'b-green'
      };
    }
    return { pct: 50, label: 'En cours', cls: '', statut: 'En cours', statutCls: 'b-green' };
  }

  async function loadSessions() {
    try {
      var subtitleEl = document.getElementById('sessions-subtitle');
      var tbodyEl = document.getElementById('sessions-tbody');

      // Sessions avec formations jointes
      var sR = await sb.from('formation_sessions')
        .select('id, date_debut, date_fin, formateur_principal_id, formateur_principal, formation_id, formations(titre)')
        .order('date_debut', { ascending: false });
      if (sR.error) throw sR.error;
      var sessions = sR.data || [];

      // Formateurs
      var fR = await sb.from('formateurs').select('id, prenom, nom');
      var formateursById = {};
      (fR.data || []).forEach(function(f) { formateursById[f.id] = f; });

      // Inscriptions pour compter apprenants par session
      var iR = await sb.from('formation_inscriptions').select('session_id, statut');
      var nbBySession = {};
      var totalApprenants = 0;
      (iR.data || []).forEach(function(i) {
        if (i.statut === 'abandon') return;
        nbBySession[i.session_id] = (nbBySession[i.session_id] || 0) + 1;
        totalApprenants++;
      });

      // Sessions actives (en cours + a venir)
      var now = Date.now();
      var actives = sessions.filter(function(s) {
        if (!s.date_fin) return true;
        return new Date(s.date_fin).getTime() >= now;
      });

      if (subtitleEl) {
        subtitleEl.textContent = actives.length + ' cohorte' + (actives.length > 1 ? 's' : '') + ' active' + (actives.length > 1 ? 's' : '') + ' · ' + totalApprenants + ' apprenant' + (totalApprenants > 1 ? 's' : '');
      }

      if (sessions.length === 0) {
        tbodyEl.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Aucune session</td></tr>';
      } else {
        var rows = sessions.map(function(s) {
          var formateur = s.formateur_principal_id ? formateursById[s.formateur_principal_id] : null;
          var formateurNom = formateur
            ? ((formateur.prenom || '') + ' ' + (formateur.nom || '')).trim()
            : (s.formateur_principal || '—');
          var formationTitre = (s.formations && s.formations.titre) || '—';
          var cohorte = fmtCohorte(s.date_debut, s.date_fin);
          var nb = nbBySession[s.id] || 0;
          var av = getAvancement(s.date_debut, s.date_fin);

          return '<tr>' +
            '<td class="name-cell">' + escapeHtml(cohorte) + '</td>' +
            '<td>' + escapeHtml(formationTitre) + '</td>' +
            '<td>' + escapeHtml(formateurNom) + '</td>' +
            '<td>' + nb + '</td>' +
            '<td><div class="flex items-c gap-2">' +
              '<div class="prog" style="width:60px"><div class="prog-fill ' + av.cls + '" style="width:' + av.pct + '%"></div></div>' +
              '<span class="text-xs' + (av.cls ? ' text-' + av.cls : '') + '">' + av.label + '</span>' +
            '</div></td>' +
            '<td><span class="badge ' + av.statutCls + '">' + av.statut + '</span></td>' +
          '</tr>';
        });
        tbodyEl.innerHTML = rows.join('');
      }

      console.log('[Ardalos Sessions] OK :', sessions.length, 'sessions,', actives.length, 'actives,', totalApprenants, 'apprenants');
    } catch (e) {
      console.error('[Ardalos Sessions] Erreur:', e);
      var tbodyEl = document.getElementById('sessions-tbody');
      if (tbodyEl) tbodyEl.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;color:#dc2626">Erreur : ' + escapeHtml(e.message || 'inconnue') + '</td></tr>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadSessions);
  } else {
    loadSessions();
  }
})();
</script>


<!-- === CONNEXION SUPABASE FORMATIONS + MODALES UNIVERSELLES === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  // Cache pour eviter de recharger a chaque ouverture de modale
  var cache = {
    formations: null,
    formateurs: null,
    sessions: null,
    inscriptions: null,
    financements: null,
    contacts: null,
  };

  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtEuro(n) {
    if (!n || n === 0) return '—';
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function fmtDate(s) {
    if (!s) return '—';
    return new Date(s).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function fmtCohorte(dateDebut, dateFin) {
    if (!dateDebut) return '—';
    var d1 = new Date(dateDebut);
    var mois = ['Janv', 'Fev', 'Mars', 'Avr', 'Mai', 'Juin', 'Juil', 'Aout', 'Sept', 'Oct', 'Nov', 'Dec'];
    var s = mois[d1.getMonth()] + ' ' + d1.getFullYear();
    if (dateFin) {
      var d2 = new Date(dateFin);
      if (d2.getMonth() !== d1.getMonth() || d2.getFullYear() !== d1.getFullYear()) {
        s = mois[d1.getMonth()] + '–' + mois[d2.getMonth()] + ' ' + d2.getFullYear();
      }
    }
    return s;
  }

  function getInitials(prenom, nom) {
    var p = (prenom || '').trim();
    var n = (nom || '').trim();
    return ((p[0] || '').toUpperCase() + (n[0] || '').toUpperCase()) || '??';
  }

  // Precharger toutes les donnees une fois
  async function loadAllData() {
    if (cache.formations) return; // deja charge

    var results = await Promise.all([
      sb.from('formations').select('*').order('titre', { ascending: true }),
      sb.from('formateurs').select('*'),
      sb.from('formation_sessions').select('*'),
      sb.from('formation_inscriptions').select('*, contacts(prenom, nom, email, telephone)'),
      sb.from('formation_financements').select('*'),
      sb.from('contacts').select('*'),
    ]);

    cache.formations = results[0].data || [];
    cache.formateurs = results[1].data || [];
    cache.sessions = results[2].data || [];
    cache.inscriptions = results[3].data || [];
    cache.financements = results[4].data || [];
    cache.contacts = results[5].data || [];
  }

  // =====================================================================
  // SECTION FORMATIONS (rendu)
  // =====================================================================
  async function loadFormations() {
    try {
      await loadAllData();

      var subtitleEl = document.getElementById('formations-subtitle');
      var gridEl = document.getElementById('formations-grid');
      var formations = cache.formations;

      if (subtitleEl) {
        subtitleEl.textContent = 'Catalogue · ' + formations.length + ' formation' + (formations.length > 1 ? 's' : '') + ' · NDA: 93132464513';
      }

      if (formations.length === 0) {
        gridEl.innerHTML = '<div style="grid-column:1/-1;padding:40px;text-align:center;color:#9ca3af;font-style:italic">Aucune formation dans le catalogue</div>';
        return;
      }

      // Map sessions par formation (pour compter cohortes 2026)
      var anneeActuelle = new Date().getFullYear();
      var sessionsByFormation = {};
      cache.sessions.forEach(function(s) {
        if (!s.formation_id) return;
        if (!sessionsByFormation[s.formation_id]) sessionsByFormation[s.formation_id] = [];
        sessionsByFormation[s.formation_id].push(s);
      });

      // Couleurs en-tetes (cycle bleu / or / gris)
      var HEADER_STYLES = [
        'background:var(--ard-blue);border-color:var(--ard-blue)',
        'background:var(--ard-dark2);border-color:var(--ard-dark2)',
        'background:#374151;border-color:#374151',
      ];

      var cards = formations.map(function(f, idx) {
        var hStyle = HEADER_STYLES[idx % 3];
        var sessions = sessionsByFormation[f.id] || [];
        var sessionsThisYear = sessions.filter(function(s) {
          if (!s.date_debut) return false;
          return new Date(s.date_debut).getFullYear() === anneeActuelle;
        });
        var nbCohortes = sessionsThisYear.length;

        var duree = f.duree ? f.duree + 'h' : '—';
        var modalite = f.modalite || '—';
        var tarif = f.tarif ? fmtEuro(Number(f.tarif)) : '—';
        var financement = f.financement || 'À définir';

        // Badges financement (extrait depuis le champ)
        var finBadges = '';
        if (f.financement) {
          var finArr = f.financement.split(/[,;/]/).map(function(x) { return x.trim(); }).filter(Boolean);
          finBadges = finArr.slice(0, 3).map(function(ff) {
            var cls = 'b-navy';
            if (ff.toUpperCase().indexOf('CPF') !== -1) cls = 'b-teal';
            else if (ff.toUpperCase().indexOf('OPCO') !== -1) cls = 'b-teal';
            return '<span class="badge ' + cls + '" style="font-size:10px">' + escapeHtml(ff) + '</span>';
          }).join(' ');
        }
        if (!finBadges) finBadges = '<span class="text-muted text-xs">À définir</span>';

        return '<div class="card" style="cursor:pointer;transition:all var(--tr)" onmouseover="this.style.boxShadow=\'var(--s2)\'" onmouseout="this.style.boxShadow=\'none\'" onclick="window.ardalosOpenFormation(\'' + escapeHtml(f.id) + '\')">' +
          '<div class="card-h" style="' + hStyle + '">' +
            '<span class="card-title" style="color:#fff">' + escapeHtml(f.titre || 'Sans titre') + '</span>' +
            '<span class="badge b-gold">Qualiopi</span>' +
          '</div>' +
          '<div class="card-b">' +
            '<div class="si"><span class="si-l">Durée</span><span class="si-r">' + duree + '</span></div>' +
            '<div class="si"><span class="si-l">Modalité</span><span class="si-r">' + escapeHtml(modalite) + '</span></div>' +
            '<div class="si"><span class="si-l">Tarif HT</span><span class="si-r">' + tarif + '</span></div>' +
            (f.niveau ? '<div class="si"><span class="si-l">Niveau</span><span class="si-r">' + escapeHtml(f.niveau) + '</span></div>' : '') +
            '<div class="si"><span class="si-l">Financement</span><span class="si-r" style="display:flex;gap:3px;flex-wrap:wrap;justify-content:flex-end">' + finBadges + '</span></div>' +
            '<div style="margin-top:10px">' +
              '<div class="flex items-c justify-b mb-1">' +
                '<span class="text-xs text-muted">Sessions ' + anneeActuelle + '</span>' +
                '<span class="text-xs font-sb">' + nbCohortes + '</span>' +
              '</div>' +
              '<div class="prog"><div class="prog-fill gold" style="width:' + Math.min(nbCohortes * 33, 100) + '%"></div></div>' +
            '</div>' +
          '</div>' +
          '<div class="card-f">' +
            '<span class="badge b-green">Active</span>' +
            '<button class="btn-s" style="font-size:11px;padding:3px 10px;margin-left:auto" onclick="event.stopPropagation();window.ardalosOpenFormation(\'' + escapeHtml(f.id) + '\')">Gérer</button>' +
          '</div>' +
        '</div>';
      });
      gridEl.innerHTML = cards.join('');

      console.log('[Ardalos Formations] OK :', formations.length, 'formations');
    } catch (e) {
      console.error('[Ardalos Formations] Erreur:', e);
      var gridEl = document.getElementById('formations-grid');
      if (gridEl) gridEl.innerHTML = '<div style="grid-column:1/-1;padding:40px;text-align:center;color:#dc2626">Erreur : ' + escapeHtml(e.message || 'inconnue') + '</div>';
    }
  }

  // =====================================================================
  // MODALE FORMATION : ouvrir + rendu
  // =====================================================================
  window.ardalosOpenFormation = async function(formationId) {
    try {
      await loadAllData();
      var titleEl = document.getElementById('detail-modal-title');
      var bodyEl = document.getElementById('detail-modal-body');

      var formation = cache.formations.find(function(f) { return f.id === formationId; });
      if (!formation) { alert('Formation introuvable'); return; }

      titleEl.textContent = formation.titre || 'Formation';

      var sessions = cache.sessions.filter(function(s) { return s.formation_id === formationId; });
      sessions.sort(function(a, b) {
        return new Date(b.date_debut || 0).getTime() - new Date(a.date_debut || 0).getTime();
      });

      // Nb apprenants par session
      var nbBySession = {};
      cache.inscriptions.forEach(function(i) {
        if (i.statut === 'abandon') return;
        nbBySession[i.session_id] = (nbBySession[i.session_id] || 0) + 1;
      });

      var totalApprenants = 0;
      sessions.forEach(function(s) { totalApprenants += (nbBySession[s.id] || 0); });

      // Formateurs
      var formateursById = {};
      cache.formateurs.forEach(function(f) { formateursById[f.id] = f; });

      var sessionsHtml = sessions.length === 0
        ? '<div style="padding:14px;text-align:center;color:#9ca3af;font-style:italic;border:1px dashed #e5e7eb;border-radius:8px">Aucune session pour cette formation</div>'
        : '<table class="dt" style="font-size:12px">' +
            '<thead><tr><th>Cohorte</th><th>Formateur</th><th>Lieu</th><th>Apprenants</th><th>Statut</th></tr></thead>' +
            '<tbody>' +
              sessions.map(function(s) {
                var formateur = s.formateur_principal_id ? formateursById[s.formateur_principal_id] : null;
                var formateurNom = formateur
                  ? ((formateur.prenom || '') + ' ' + (formateur.nom || '')).trim()
                  : (s.formateur_principal || '—');
                var nb = nbBySession[s.id] || 0;
                var statutLabel = s.statut || (s.date_debut && new Date(s.date_debut) > new Date() ? 'À venir' : 'En cours');
                return '<tr>' +
                  '<td>' + escapeHtml(fmtCohorte(s.date_debut, s.date_fin)) + '</td>' +
                  '<td>' + escapeHtml(formateurNom) + '</td>' +
                  '<td>' + escapeHtml(s.lieu || '—') + '</td>' +
                  '<td>' + nb + '</td>' +
                  '<td><span class="badge b-navy">' + escapeHtml(statutLabel) + '</span></td>' +
                '</tr>';
              }).join('') +
            '</tbody>' +
          '</table>';

      bodyEl.innerHTML =
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">' +
          '<div class="si"><span class="si-l">Durée</span><span class="si-r">' + (formation.duree ? formation.duree + 'h' : '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Tarif HT</span><span class="si-r">' + (formation.tarif ? fmtEuro(Number(formation.tarif)) : '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Modalité</span><span class="si-r">' + escapeHtml(formation.modalite || '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Niveau</span><span class="si-r">' + escapeHtml(formation.niveau || '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Financement</span><span class="si-r">' + escapeHtml(formation.financement || '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Réf. interne</span><span class="si-r">' + escapeHtml(formation.ref_interne || '—') + '</span></div>' +
        '</div>' +
        (formation.description ? '<div style="margin-bottom:10px"><div class="text-xs text-muted" style="margin-bottom:4px">Description</div><div style="font-size:13px">' + escapeHtml(formation.description) + '</div></div>' : '') +
        (formation.objectifs ? '<div style="margin-bottom:10px"><div class="text-xs text-muted" style="margin-bottom:4px">Objectifs</div><div style="font-size:13px;white-space:pre-wrap">' + escapeHtml(formation.objectifs) + '</div></div>' : '') +
        (formation.prerequis ? '<div style="margin-bottom:10px"><div class="text-xs text-muted" style="margin-bottom:4px">Prérequis</div><div style="font-size:13px;white-space:pre-wrap">' + escapeHtml(formation.prerequis) + '</div></div>' : '') +
        (formation.public_vise ? '<div style="margin-bottom:10px"><div class="text-xs text-muted" style="margin-bottom:4px">Public visé</div><div style="font-size:13px;white-space:pre-wrap">' + escapeHtml(formation.public_vise) + '</div></div>' : '') +
        '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="flex items-c justify-b" style="margin-bottom:10px">' +
            '<span class="font-sb" style="font-size:13px;color:var(--ard-dark)">Sessions programmées</span>' +
            '<span class="text-xs text-muted">' + sessions.length + ' session' + (sessions.length > 1 ? 's' : '') + ' · ' + totalApprenants + ' apprenant' + (totalApprenants > 1 ? 's' : '') + '</span>' +
          '</div>' +
          sessionsHtml +
        '</div>';

      openModal('detail');
    } catch (e) {
      console.error(e);
      alert('Erreur : ' + (e.message || 'inconnue'));
    }
  };

  // =====================================================================
  // MODALE APPRENANT : ouvrir + rendu
  // =====================================================================
  window.ardalosOpenApprenant = async function(contactId) {
    try {
      await loadAllData();
      var titleEl = document.getElementById('detail-modal-title');
      var bodyEl = document.getElementById('detail-modal-body');

      var contact = cache.contacts.find(function(c) { return c.id === contactId; });
      if (!contact) { alert('Apprenant introuvable'); return; }

      titleEl.textContent = ((contact.prenom || '') + ' ' + (contact.nom || '')).trim() || 'Apprenant';

      var inscriptions = cache.inscriptions.filter(function(i) { return i.contact_id === contactId; });
      inscriptions.sort(function(a, b) {
        return new Date(b.created_at || 0).getTime() - new Date(a.created_at || 0).getTime();
      });

      var sessionsById = {};
      cache.sessions.forEach(function(s) { sessionsById[s.id] = s; });
      var formationsById = {};
      cache.formations.forEach(function(f) { formationsById[f.id] = f; });

      // Financements par inscription
      var finByIns = {};
      cache.financements.forEach(function(f) {
        if (!finByIns[f.inscription_id]) finByIns[f.inscription_id] = [];
        finByIns[f.inscription_id].push(f);
      });

      var inscriptionsHtml = inscriptions.length === 0
        ? '<div style="padding:14px;text-align:center;color:#9ca3af;font-style:italic;border:1px dashed #e5e7eb;border-radius:8px">Aucune inscription</div>'
        : inscriptions.map(function(i) {
            var s = sessionsById[i.session_id] || {};
            var f = formationsById[s.formation_id] || {};
            var fins = finByIns[i.id] || [];
            var finsText = fins.length > 0
              ? fins.map(function(ff) { return ff.type_financement + (ff.montant_ht ? ' (' + fmtEuro(Number(ff.montant_ht)) + ')' : ''); }).join(' · ')
              : '—';
            var statutCls = 'b-gray';
            if (i.statut === 'confirme' || i.statut === 'present') statutCls = 'b-green';
            else if (i.statut === 'abandon') statutCls = 'b-red';
            else if (i.statut === 'prospect') statutCls = 'b-amber';
            return '<div style="padding:10px;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:8px;font-size:12px">' +
              '<div class="flex items-c justify-b" style="margin-bottom:6px">' +
                '<span class="font-sb">' + escapeHtml(f.titre || 'Formation') + '</span>' +
                '<span class="badge ' + statutCls + '">' + escapeHtml(i.statut || 'inconnu') + '</span>' +
              '</div>' +
              '<div class="text-xs text-muted">Cohorte : ' + escapeHtml(fmtCohorte(s.date_debut, s.date_fin)) + ' · ' + escapeHtml(s.lieu || 'Lieu à préciser') + '</div>' +
              '<div class="text-xs" style="margin-top:4px">Montant : <strong>' + (i.montant_total_ht ? fmtEuro(Number(i.montant_total_ht)) : '—') + '</strong> · Financement : ' + escapeHtml(finsText) + '</div>' +
              (i.commercial_responsable ? '<div class="text-xs text-muted">Commercial : ' + escapeHtml(i.commercial_responsable) + '</div>' : '') +
            '</div>';
          }).join('');

      bodyEl.innerHTML =
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">' +
          '<div class="si"><span class="si-l">Email</span><span class="si-r">' + escapeHtml(contact.email || '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Téléphone</span><span class="si-r">' + escapeHtml(contact.telephone || '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Créé le</span><span class="si-r">' + fmtDate(contact.created_at) + '</span></div>' +
          '<div class="si"><span class="si-l">Inscriptions</span><span class="si-r">' + inscriptions.length + '</span></div>' +
        '</div>' +
        '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="font-sb" style="font-size:13px;color:var(--ard-dark);margin-bottom:10px">Parcours de formation</div>' +
          inscriptionsHtml +
        '</div>';

      openModal('detail');
    } catch (e) {
      console.error(e);
      alert('Erreur : ' + (e.message || 'inconnue'));
    }
  };

  // =====================================================================
  // MODALE FORMATEUR : ouvrir + rendu
  // =====================================================================
  window.ardalosOpenFormateur = async function(formateurId) {
    try {
      await loadAllData();
      var titleEl = document.getElementById('detail-modal-title');
      var bodyEl = document.getElementById('detail-modal-body');

      var formateur = cache.formateurs.find(function(f) { return f.id === formateurId; });
      if (!formateur) { alert('Formateur introuvable'); return; }

      var nomComplet = ((formateur.prenom || '') + ' ' + (formateur.nom || '')).trim() || 'Formateur';
      titleEl.textContent = nomComplet;

      // Sessions de ce formateur
      var sessions = cache.sessions.filter(function(s) { return s.formateur_principal_id === formateurId; });
      sessions.sort(function(a, b) {
        return new Date(b.date_debut || 0).getTime() - new Date(a.date_debut || 0).getTime();
      });

      var formationsById = {};
      cache.formations.forEach(function(f) { formationsById[f.id] = f; });

      var nbBySession = {};
      cache.inscriptions.forEach(function(i) {
        if (i.statut === 'abandon') return;
        nbBySession[i.session_id] = (nbBySession[i.session_id] || 0) + 1;
      });

      var totalApprenants = 0;
      sessions.forEach(function(s) { totalApprenants += (nbBySession[s.id] || 0); });

      var sessionsHtml = sessions.length === 0
        ? '<div style="padding:14px;text-align:center;color:#9ca3af;font-style:italic;border:1px dashed #e5e7eb;border-radius:8px">Aucune session attribuée</div>'
        : sessions.map(function(s) {
            var f = formationsById[s.formation_id] || {};
            var nb = nbBySession[s.id] || 0;
            return '<div style="padding:10px;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:8px;font-size:12px">' +
              '<div class="flex items-c justify-b" style="margin-bottom:4px">' +
                '<span class="font-sb">' + escapeHtml(f.titre || 'Formation') + '</span>' +
                '<span class="badge b-navy">' + escapeHtml(fmtCohorte(s.date_debut, s.date_fin)) + '</span>' +
              '</div>' +
              '<div class="text-xs text-muted">' + escapeHtml(s.lieu || 'Lieu à préciser') + ' · ' + nb + ' apprenant' + (nb > 1 ? 's' : '') + '</div>' +
            '</div>';
          }).join('');

      bodyEl.innerHTML =
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">' +
          (formateur.specialite ? '<div class="si"><span class="si-l">Spécialité</span><span class="si-r">' + escapeHtml(formateur.specialite) + '</span></div>' : '') +
          (formateur.titre ? '<div class="si"><span class="si-l">Titre</span><span class="si-r">' + escapeHtml(formateur.titre) + '</span></div>' : '') +
          (formateur.email ? '<div class="si"><span class="si-l">Email</span><span class="si-r">' + escapeHtml(formateur.email) + '</span></div>' : '') +
          (formateur.telephone ? '<div class="si"><span class="si-l">Téléphone</span><span class="si-r">' + escapeHtml(formateur.telephone) + '</span></div>' : '') +
          '<div class="si"><span class="si-l">Sessions totales</span><span class="si-r">' + sessions.length + '</span></div>' +
          '<div class="si"><span class="si-l">Apprenants totaux</span><span class="si-r">' + totalApprenants + '</span></div>' +
        '</div>' +
        '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="font-sb" style="font-size:13px;color:var(--ard-dark);margin-bottom:10px">Sessions animées</div>' +
          sessionsHtml +
        '</div>';

      openModal('detail');
    } catch (e) {
      console.error(e);
      alert('Erreur : ' + (e.message || 'inconnue'));
    }
  };

  // =====================================================================
  // Patcher les fonctions existantes : apprenants + formateurs pour brancher les boutons
  // =====================================================================
  // On patche le script apprenants pour que le bouton "Voir" appelle ardalosOpenApprenant
  // Meme logique pour formateurs

  // On attend que le DOM ait charge puis on re-render avec les bons boutons
  function attachButtons() {
    // Apprenants : remplacer les "Voir" par des boutons qui ouvrent la modale
    var apprenantsTbody = document.getElementById('apprenants-tbody');
    if (apprenantsTbody) {
      // Observer les changements pour brancher le bouton
      var observer = new MutationObserver(function() {
        var buttons = apprenantsTbody.querySelectorAll('button');
        buttons.forEach(function(btn) {
          if (btn._ardalosHooked) return;
          var row = btn.closest('tr');
          if (!row) return;
          var nameEl = row.querySelector('.name-cell');
          if (!nameEl) return;
          var nomComplet = nameEl.textContent.trim();
          // Trouver le contact avec ce nom
          var contact = cache.contacts && cache.contacts.find(function(c) {
            return ((c.prenom || '') + ' ' + (c.nom || '')).trim() === nomComplet;
          });
          if (contact) {
            btn._ardalosHooked = true;
            btn.onclick = function(e) {
              e.stopPropagation();
              window.ardalosOpenApprenant(contact.id);
            };
          }
        });
      });
      observer.observe(apprenantsTbody, { childList: true, subtree: true });
    }

    // Formateurs : brancher le bouton "Fiche" de chaque card
    var formateursGrid = document.getElementById('formateurs-grid');
    if (formateursGrid) {
      var observer2 = new MutationObserver(function() {
        var cards = formateursGrid.querySelectorAll('.card');
        cards.forEach(function(card) {
          if (card._ardalosHooked) return;
          var nameEl = card.querySelector('.font-sb');
          if (!nameEl) return;
          var nomComplet = nameEl.textContent.trim();
          var formateur = cache.formateurs && cache.formateurs.find(function(f) {
            return ((f.prenom || '') + ' ' + (f.nom || '')).trim() === nomComplet;
          });
          if (formateur) {
            card._ardalosHooked = true;
            // Le premier bouton est "Fiche"
            var buttons = card.querySelectorAll('button');
            if (buttons.length >= 1) {
              buttons[0].onclick = function(e) {
                e.stopPropagation();
                window.ardalosOpenFormateur(formateur.id);
              };
            }
          }
        });
      });
      observer2.observe(formateursGrid, { childList: true, subtree: true });
    }
  }

  function init() {
    loadFormations();
    attachButtons();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

</body>
</html>
