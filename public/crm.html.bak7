<body>
<div id="app">

<!-- ════════════════════════════════════════════
     SIDEBAR
════════════════════════════════════════════ -->
<nav id="sidebar">
  <div class="sb-logo">
    <div class="sb-logo-mark">A</div>
    <div class="sb-logo-text">
      <div class="t1">Ardalos</div>
      <div class="t2">Groupe CRM</div>
    </div>
  </div>

  <div class="entity-sw" onclick="toggleEntityMenu()">
    <div class="entity-sw-info">
      <div class="name">Ardalos Formation</div>
      <div class="role">Admin groupe · Vue consolidée</div>
