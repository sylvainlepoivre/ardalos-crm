<!-- ════════════════════════════════════════════
     MAIN
════════════════════════════════════════════ -->
<div id="main">
<header id="topbar">
  <div class="breadcrumb">
    <span>Ardalos Groupe</span>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-cur" id="bc-page">Dashboard</span>
  </div>
  <div class="tb-right">
    <div class="search-wrap">
      <span class="search-ic">⌕</span>
      <input type="text" id="global-search" placeholder="⌘K — Rechercher…">
    </div>
    <button class="tb-btn" onclick="toggleNotifs()" title="Notifications">
      🔔<span class="notif-dot"></span>
    </button>
    <button class="tb-btn" title="Aide">?</button>
    <button class="btn-p" onclick="openModal('quick-add')">+ Créer</button>
  </div>
</header>

<!-- ════════════════════════════════════════════
     PAGES
════════════════════════════════════════════ -->
<div id="content">

<!-- ▶ DASHBOARD ──────────────────────────── -->
<div id="page-dashboard" class="page active">
  <div class="page-hdr">
    <div class="page-hdr-left">
      <h1 class="page-title">Tableau de bord</h1>
      <p class="page-sub">Vue consolidée Ardalos Groupe · Avril 2026</p>
    </div>
    <div class="page-hdr-right">
      <select class="fselect" style="width:auto;font-size:12px"><option>30 derniers jours</option><option>Ce trimestre</option><option>Cette année</option></select>
      <button class="btn-s">↓ Rapport</button>
    </div>
  </div>

  <div class="kpi-grid anim-kpi">
    <div class="kpi" onclick="navigate('contacts')">
      <div class="kpi-label">Leads actifs</div>
      <div class="kpi-value" id="kpi-leads">...</div>
      <div class="kpi-sub" id="kpi-leads-sub">Chargement...</div>
    </div>
    <div class="kpi gold" onclick="navigate('pipeline')">
      <div class="kpi-label">CA prévisionnel</div>
      <div class="kpi-value" id="kpi-ca">...</div>
      <div class="kpi-sub" id="kpi-ca-sub">Chargement...</div>
    </div>
    <div class="kpi green" onclick="navigate('pipeline')">
      <div class="kpi-label">Deals pipeline</div>
      <div class="kpi-value" id="kpi-deals">...</div>
      <div class="kpi-sub" id="kpi-deals-sub">Chargement...</div>
    </div>
    <div class="kpi teal" onclick="navigate('apprenants')">
      <div class="kpi-label">Apprenants</div>
      <div class="kpi-value" id="kpi-apprenants">...</div>
      <div class="kpi-sub" id="kpi-apprenants-sub">Chargement...</div>
    </div>
    <div class="kpi" onclick="navigate('funding')">
      <div class="kpi-label">Dossiers AFDAS</div>
      <div class="kpi-value" id="kpi-afdas">...</div>
      <div class="kpi-sub" id="kpi-afdas-sub">Chargement...</div>
    </div>
    <div class="kpi green" onclick="navigate('qualiopi')">
      <div class="kpi-label">Score Qualiopi</div>
      <div class="kpi-value">94%</div>
      <div class="kpi-sub">28/32 conformes</div>
    </div>
  </div>

  <div class="alert alert-r">
    <span class="alert-ic">⚠</span>
    <div>
      <div class="alert-title">Urgent — Sophie Martin · Dossier AFDAS J-6</div>
      2 pièces manquantes : attestation employeur · CV à jour. Dépôt limite le 01/05/2026.
      <button class="badge b-navy" style="cursor:pointer;margin-left:8px" onclick="navigate('funding')">Voir le dossier →</button>
    </div>
  </div>
  <div class="alert alert-a">
    <span class="alert-ic">⏱</span>
    <div>
      <div class="alert-title">Fenêtre ouverte — Lucas Bernard · Budget Q2 disponible mai</div>
      Carence levée le 15/03. Dépôt optimal : 1–5 mai 2026. Formation 60–80h recommandée.
      <button class="badge b-gold" style="cursor:pointer;margin-left:8px" onclick="navigate('afdas')">Stratégie AFDAS →</button>
    </div>
  </div>

  <div class="g65 mt-4">
    <div class="card card-accent-blue">
      <div class="card-h">
        <span class="card-title">Pipeline commercial</span>
        <button class="btn-s" style="font-size:11px;padding:4px 10px" onclick="navigate('pipeline')">Vue complète →</button>
      </div>
      <div style="padding:12px;overflow-x:auto">
        <div class="kanban-wrap" style="min-height:200px">
          <div class="kb-col">
            <div class="kb-col-h" style="border-top:3px solid var(--g400)">
              <span class="kb-col-name">Nouveau lead</span><span class="kb-col-count">12 · 18k€</span>
            </div>
