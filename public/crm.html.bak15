      <div class="divider mt-4"><div class="divider-label">Barèmes horaires</div><div class="divider-line"></div></div>
      <div class="si"><span class="si-l">Pratiques artistiques</span><span class="si-r text-gold font-sb">60€/h HT</span></div>
      <div class="si"><span class="si-l">Sécurité / CACES / habilitations</span><span class="si-r font-sb">48€/h HT</span></div>
      <div class="si"><span class="si-l">Transverses, PAO, gestion</span><span class="si-r">40€/h HT</span></div>
      <div class="si"><span class="si-l">Pratiques corporelles</span><span class="si-r">40€/h HT</span></div>
      <div class="si"><span class="si-l">Métier non-technique</span><span class="si-r">40€/h HT</span></div>
      <div class="divider mt-4"><div class="divider-label">Fenêtres de dépôt</div><div class="divider-line"></div></div>
