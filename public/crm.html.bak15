              </div>
            </div>
            <div id="quick-warning" style="margin-top:8px;font-size:11px;color:#78350F"></div>
          </div>
        </div>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:12px">
      <div class="card">
        <div class="card-h"><span class="card-title">Barèmes 2026</span></div>
        <div class="card-b">
          <div class="si"><span class="si-l">Pratiques artistiques</span><span class="si-r text-gold">60€/h HT</span></div>
          <div class="si"><span class="si-l">Sécurité (CACES, habilit.)</span><span class="si-r">48€/h HT</span></div>
          <div class="si"><span class="si-l">Transverses (gestion, PAO)</span><span class="si-r">40€/h HT</span></div>
          <div class="si"><span class="si-l">Métier non-technique</span><span class="si-r">40€/h HT</span></div>
          <div class="si"><span class="si-l">Pratiques corporelles</span><span class="si-r">40€/h HT</span></div>
          <div style="margin-top:10px;background:var(--ard-blue-faint);border-radius:var(--r8);padding:9px 11px;font-size:11px;color:var(--ard-blue)">
            <strong>Sécurité :</strong> sans carence (plafond 3 000€/an)<br>
            <strong>RSE / VHSS :</strong> sans carence
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-h"><span class="card-title">Seuils d'éligibilité 2026</span></div>
        <div class="card-b">
          <div class="si"><span class="si-l">Artiste interprète</span><span class="si-r">≥ 48 cachets</span></div>
          <div class="si"><span class="si-l">Metteur en scène</span><span class="si-r">≥ 48 cachets</span></div>
          <div class="si"><span class="si-l">Réalisateur</span><span class="si-r">≥ 48 cachets</span></div>
          <div class="si"><span class="si-l">Technicien spectacle vivant</span><span class="si-r">≥ 88 jours</span></div>
          <div class="si"><span class="si-l">Technicien cinéma/audio</span><span class="si-r">≥ 130 jours</span></div>
        </div>
      </div>
      <div class="card">
        <div class="card-h"><span class="card-title">Quadrimestres 2026</span></div>
        <div class="card-b">
          <div class="si"><span class="si-l flex items-c gap-1"><span class="dot dot-ok"></span>Q1 Janv–Avril</span><span class="si-r text-green">Budget OK</span></div>
          <div class="si"><span class="si-l flex items-c gap-1"><span class="dot dot-warn"></span>Q2 Mai–Août</span><span class="si-r text-amber">Ouverture 1er mai</span></div>
          <div class="si"><span class="si-l flex items-c gap-1"><span class="dot" style="background:var(--g300)"></span>Q3 Sept–Déc</span><span class="si-r text-muted">Futur</span></div>
          <div style="margin-top:10px;background:var(--g50);border-radius:var(--r8);padding:9px 11px;font-size:11px;color:var(--g600);border:1px solid var(--g200)">
