<!-- ════════════════════════════════════════════
     JAVASCRIPT — NAVIGATION & LOGIQUE MÉTIER
════════════════════════════════════════════ -->
<script>
// ── Navigation ────────────────────────────
const PAGE_TITLES = {
  dashboard:'Dashboard',contacts:'Contacts',companies:'Entreprises',
  pipeline:'Pipeline',formations:'Formations',sessions:'Sessions & Cohortes',
  apprenants:'Apprenants',formateurs:'Formateurs',funding:'Dossiers financement',
  afdas:'Moteur AFDAS',qualiopi:'Qualiopi',documents:'Documents',
  workflows:'Workflows',tasks:'Tâches',reporting:'Reporting',campaigns:'Campagnes'
};

function navigate(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const el = document.getElementById('page-' + page);
  if (el) el.classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n => {
    n.classList.remove('active');
    if (n.dataset.page === page) n.classList.add('active');
  });
  document.getElementById('bc-page').textContent = PAGE_TITLES[page] || page;
  document.getElementById('notif-drawer').classList.remove('open');
  window.scrollTo(0,0);
}

document.querySelectorAll('.nav-item[data-page]').forEach(item => {
  item.addEventListener('click', () => navigate(item.dataset.page));
});

// ── Notifications ─────────────────────────
function toggleNotifs() {
  document.getElementById('notif-drawer').classList.toggle('open');
}

// ── Modals ────────────────────────────────
function openModal(id) { document.getElementById('modal-' + id)?.classList.add('open') }
function closeModal(id) { document.getElementById('modal-' + id)?.classList.remove('open') }

document.querySelectorAll('.modal-ov').forEach(ov => {
  ov.addEventListener('click', e => { if (e.target === ov) ov.classList.remove('open') });
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.querySelectorAll('.modal-ov.open').forEach(m => m.classList.remove('open'));
    document.getElementById('notif-drawer').classList.remove('open');
  }
  if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
    e.preventDefault();
    document.getElementById('global-search').focus();
  }
});

// ── Tabs ──────────────────────────────────
function setTab(el, groupId) {
  el.closest('.tabs').querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

// ── AFDAS Quick Calc ─────────────────────
function quickCalc() {
  const rate = parseInt(document.getElementById('quick-cat').value) || 40;
  const hours = parseInt(document.getElementById('quick-hours').value) || 0;
  const amount = rate * hours;
  document.getElementById('quick-amount').textContent = amount.toLocaleString('fr-FR') + '€ HT';

  let carence, warn = '';
  if (hours <= 40) { carence = '12 mois'; }
  else if (hours <= 80) { carence = '18 mois'; }
  else { carence = '24 mois'; warn = '⚠ Formation > 80h — Carence longue (24 mois). Envisager découpage en 2 blocs.'; }
  document.getElementById('quick-carence').textContent = carence;
  document.getElementById('quick-warning').textContent = warn;
}
quickCalc(); // init

// ── AFDAS Full Calculator ─────────────────
function fullCalcAfdas() {
  const catSel = document.getElementById('ac-cat');
  const seuil = parseInt(catSel.selectedOptions[0].dataset.seuil);
  const volume = parseInt(document.getElementById('ac-volume').value);
  const lastDur = parseInt(document.getElementById('ac-lastdur').value) || 0;
  const lastDate = new Date(document.getElementById('ac-lastdate').value);
  const formRate = parseInt(document.getElementById('ac-formcat').value);
  const newHours = parseInt(document.getElementById('ac-newdur').value) || 0;
  const today = new Date(2026, 3, 19);

  const eligible = volume >= seuil;
  let carenceMois = lastDur <= 40 ? 12 : lastDur <= 80 ? 18 : 24;
  const finCarence = new Date(lastDate);
  finCarence.setMonth(finCarence.getMonth() + carenceMois);
  const carenceOk = finCarence <= today;
  const daysLeft = Math.max(0, Math.ceil((finCarence - today) / 86400000));

  let newCarence = newHours <= 40 ? 12 : newHours <= 80 ? 18 : 24;
  const budget = formRate * newHours;
  const quadrimestre = today.getMonth() < 4 ? 'Q1 (Janv–Avril 2026)' : today.getMonth() < 8 ? 'Q2 (Mai–Août 2026)' : 'Q3 (Sept–Déc 2026)';
  const nextQ = today.getMonth() < 4 ? 'Q2 — dès le 1er mai 2026' : today.getMonth() < 8 ? 'Q3 — dès le 1er septembre 2026' : 'Q1 2027';

  const result = document.getElementById('ac-result');
  result.style.display = 'block';

  if (!eligible) {
    result.innerHTML = `<div class="afdas-card afdas-ko"><div class="afdas-hdr"><span class="dot dot-ko"></span>Non éligible</div><div class="afdas-detail">Volume déclaré : <strong>${volume}</strong> — Seuil requis : <strong>${seuil}</strong> pour cette catégorie.<br>Solution : Vérifier le volume réel ou envisager CPF / OPCO comme alternative.</div></div>`;
    return;
  }

  if (!carenceOk) {
    result.innerHTML = `
      <div class="afdas-card afdas-ko">
        <div class="afdas-hdr"><span class="dot dot-ko"></span>Éligible mais EN CARENCE — ${daysLeft} jours restants</div>
        <div class="afdas-detail">
          Dernière formation : ${lastDur}h → Carence de ${carenceMois} mois<br>
          Fin de carence : <strong>${finCarence.toLocaleDateString('fr-FR')}</strong><br>
          <div class="flex gap-2 mt-2">
            <span class="badge b-amber">AFDAS possible dès ${nextQ}</span>
            <span class="badge b-teal">CPF disponible maintenant</span>
          </div>
          <div style="margin-top:8px;padding:8px;background:rgba(0,0,0,.04);border-radius:var(--r4)">
            <strong>Recommandation :</strong> Utiliser CPF (${newHours}h × ${formRate}€ = max CPF disponible) en attendant la levée de carence AFDAS.
          </div>
        </div>
      </div>`;
    return;
  }

  result.innerHTML = `
    <div class="afdas-card afdas-ok">
      <div class="afdas-hdr"><span class="dot dot-ok"></span>Éligible — Prêt à déposer sur MyA</div>
      <div class="afdas-detail">
        Volume activité : <strong>${volume} / ${seuil} requis ✓</strong> · Carence : levée<br>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px">
          <div style="background:rgba(6,95,70,.12);border-radius:var(--r8);padding:9px;text-align:center">
            <div style="font-size:10px;color:#065F46;text-transform:uppercase;letter-spacing:.07em;font-weight:600">Financement estimé</div>
            <div style="font-size:22px;font-weight:700;color:#065F46;margin:3px 0">${budget.toLocaleString('fr-FR')}€</div>
            <div style="font-size:11px;color:#047857">${newHours}h × ${formRate}€/h</div>
          </div>
          <div style="background:rgba(6,95,70,.08);border-radius:var(--r8);padding:9px;text-align:center">
            <div style="font-size:10px;color:#065F46;text-transform:uppercase;letter-spacing:.07em;font-weight:600">Carence induite</div>
            <div style="font-size:22px;font-weight:700;color:#D97706;margin:3px 0">${newCarence} mois</div>
            <div style="font-size:11px;color:#047857">Prochaine action : ${nextQ}</div>
          </div>
        </div>
        <div style="margin-top:10px;padding:8px 10px;background:rgba(6,95,70,.08);border-radius:var(--r4);font-size:12px">
          <strong>Fenêtre recommandée :</strong> ${quadrimestre}<br>
          <strong>Règle d'or :</strong> Déposer en DÉBUT de quadrimestre — budget épuisé par ordre d'arrivée.<br>
          ${newHours > 80 ? '<strong>⚠ Formation >80h :</strong> Carence 24 mois. Envisager découpage en deux blocs de 40h.' : ''}
        </div>
      </div>
    </div>`;
}

// ── Entity Menu ───────────────────────────
function toggleEntityMenu() {
  // Placeholder — would open entity switcher
}

// ── Global Search ────────────────────────
document.getElementById('global-search').addEventListener('keyup', function(e) {
  if (e.key === 'Enter' && this.value.length > 1) {
    navigate('contacts');
    this.value = '';
  }
});
</script>


<!-- === CONNEXION SUPABASE POUR KPI DASHBOARD (ajoute pour donnees reelles) === -->
<script>
(function() {
  // Configuration Supabase
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';

  // Verifier que la lib Supabase est chargee
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    console.warn('[Ardalos KPI] Lib Supabase non chargee, KPI non mis a jour');
    return;
  }

  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function fmtEuro(n) {
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function setKpi(id, value, sub) {
    var el = document.getElementById(id);
    if (el) el.textContent = value;
    if (sub !== undefined) {
      var subEl = document.getElementById(id + '-sub');
      if (subEl) subEl.textContent = sub;
    }
  }

  async function loadKpis() {
    try {
      // --- 1. Leads actifs = nombre total de contacts ---
      var contactsR = await sb.from('contacts').select('id', { count: 'exact', head: true });
      setKpi('kpi-leads', contactsR.count || 0, 'Total contacts');

      // --- 2/3/4. Inscriptions + CA previsionnel + Apprenants confirmes ---
      var insR = await sb.from('formation_inscriptions').select('id, statut, montant_total_ht');
      var ins = insR.data || [];
      var actives = ins.filter(function(i) { return i.statut !== 'abandon'; });
      var confirmes = ins.filter(function(i) { return i.statut === 'confirme' || i.statut === 'present'; });
      var caTotal = actives.reduce(function(s, i) { return s + (Number(i.montant_total_ht) || 0); }, 0);

      setKpi('kpi-ca', fmtEuro(caTotal), 'HT · ' + actives.length + ' dossier' + (actives.length > 1 ? 's' : '') + ' actif' + (actives.length > 1 ? 's' : ''));
      setKpi('kpi-deals', actives.length, 'inscriptions actives');
      setKpi('kpi-apprenants', confirmes.length, confirmes.length + ' confirme' + (confirmes.length > 1 ? 's' : '') + ' / present' + (confirmes.length > 1 ? 's' : ''));

      // --- 5. Dossiers AFDAS ---
      var finR = await sb.from('formation_financements').select('id').eq('type_financement', 'AFDAS');
      var nbAfdas = (finR.data || []).length;
      setKpi('kpi-afdas', nbAfdas, nbAfdas === 0 ? 'Aucun' : 'dossiers AFDAS');

      console.log('[Ardalos KPI] OK charges');
    } catch (e) {
      console.error('[Ardalos KPI] Erreur:', e);
      ['kpi-leads', 'kpi-ca', 'kpi-deals', 'kpi-apprenants', 'kpi-afdas'].forEach(function(id) {
        setKpi(id, 'N/A', 'Erreur');
      });
    }
  }

  // Attendre que le DOM soit pret
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadKpis);
  } else {
    loadKpis();
  }
})();
</script>


<!-- === CONNEXION SUPABASE POUR KANBAN PIPELINE === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';

  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    console.warn('[Ardalos Pipeline] Lib Supabase non chargee');
    return;
  }
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  // Mapping statut_prospection -> colonne Kanban
  var STATUS_TO_COL = {
    'a_contacter':        'nouveau',
    'interesse':          'qualif',
    'en_discussion':      'qualif',
    'dossier_en_cours':   'dossier',
    'financement_demande':       'financement',
    'financement_en_instruction':'financement',
    'confirme':           'closing',
  };

  function fmtEuro(n) {
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function makeCard(ins) {
    var contact = ins.contacts || {};
    var session = ins.formation_sessions || {};
    var formation = session.formations || {};

    var nom = ((contact.prenom || '') + ' ' + (contact.nom || '')).trim() || '(sans nom)';
    var titreFormation = formation.titre || 'Formation';
    var montant = Number(ins.montant_total_ht) || 0;

    // Badge: commercial si present, sinon statut
    var badge = '';
    if (ins.commercial_responsable) {
      badge = '<span class="badge b-navy" style="font-size:10px">' + escapeHtml(ins.commercial_responsable) + '</span>';
    } else if (ins.statut === 'confirme') {
      badge = '<span class="badge b-green" style="font-size:10px">Confirme</span>';
    } else {
      badge = '<span class="badge b-gray" style="font-size:10px">Prospect</span>';
    }

    // Classe urgente si rappel prevu et date depassee
    var urgentClass = '';
    if (ins.date_rappel_prevu) {
      var today = new Date().toISOString().substring(0, 10);
      if (ins.date_rappel_prevu < today) urgentClass = ' urgent';
    }
    // Classe winning pour closing
    if (ins.statut === 'confirme') urgentClass = ' winning';

    return '<div class="kb-card' + urgentClass + '">' +
      '<div class="kb-card-name">' + escapeHtml(nom) + '</div>' +
      '<div class="kb-card-co">' + escapeHtml(titreFormation) + '</div>' +
      '<div class="kb-card-f">' +
        '<span class="kb-card-val">' + fmtEuro(montant) + '</span>' +
        badge +
      '</div>' +
    '</div>';
  }

  function getColKey(ins) {
    // Closing : statut d'inscription = confirme ou present
    if (ins.statut === 'confirme' || ins.statut === 'present') return 'closing';
    // Abandon : on les ignore
    if (ins.statut === 'abandon') return null;
    // Sinon on utilise le statut_prospection
    var sp = ins.statut_prospection;
    if (sp && STATUS_TO_COL[sp]) return STATUS_TO_COL[sp];
    // Par defaut : nouveau lead
    return 'nouveau';
  }

  async function loadPipeline() {
    try {
      var subtitleEl = document.getElementById('pipe-subtitle');
      var r = await sb.from('formation_inscriptions')
        .select('id, statut, statut_prospection, commercial_responsable, date_rappel_prevu, montant_total_ht, contacts(prenom, nom), formation_sessions(formations(titre))')
        .order('created_at', { ascending: false });

      if (r.error) throw r.error;
      var inscriptions = r.data || [];

      // Grouper par colonne
      var cols = { nouveau: [], qualif: [], dossier: [], financement: [], closing: [] };
      var actives = 0;
      var ca = 0;
      for (var i = 0; i < inscriptions.length; i++) {
        var ins = inscriptions[i];
        var key = getColKey(ins);
        if (key) {
          cols[key].push(ins);
          actives++;
          ca += Number(ins.montant_total_ht) || 0;
        }
      }

      // Render colonnes
      var colSums = {};
      Object.keys(cols).forEach(function(key) {
        var colEl = document.getElementById('pipe-col-' + key);
        var cntEl = document.getElementById('pipe-cnt-' + key);
        if (!colEl) return;

        var list = cols[key];
        var sum = list.reduce(function(s, x) { return s + (Number(x.montant_total_ht) || 0); }, 0);
        colSums[key] = sum;

        if (list.length === 0) {
          colEl.innerHTML = '<div style="padding:20px;text-align:center;color:#9ca3af;font-size:12px;font-style:italic">Aucun dossier</div>';
        } else {
          colEl.innerHTML = list.map(makeCard).join('');
        }
        if (cntEl) cntEl.textContent = list.length + ' · ' + fmtEuro(sum);
      });

      // Sous-titre
      if (subtitleEl) subtitleEl.textContent = actives + ' dossier' + (actives > 1 ? 's' : '') + ' actif' + (actives > 1 ? 's' : '') + ' · ' + fmtEuro(ca) + ' CA previsionnel';

      console.log('[Ardalos Pipeline] OK charge :', actives, 'dossiers,', fmtEuro(ca));
    } catch (e) {
      console.error('[Ardalos Pipeline] Erreur:', e);
      var subtitleEl = document.getElementById('pipe-subtitle');
      if (subtitleEl) subtitleEl.textContent = 'Erreur de chargement du pipeline';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadPipeline);
  } else {
    loadPipeline();
  }
})();
</script>


<!-- === CONNEXION SUPABASE POUR CONTACTS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';

  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    console.warn('[Ardalos Contacts] Lib Supabase non chargee');
    return;
  }
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function getInitials(prenom, nom) {
    var p = (prenom || '').trim();
    var n = (nom || '').trim();
    var ip = p.length > 0 ? p[0].toUpperCase() : '';
    var in_ = n.length > 0 ? n[0].toUpperCase() : '';
    return (ip + in_) || '??';
  }

  // Palette de couleurs pour les avatars (repartition stable via hash du nom)
  var AVATAR_COLORS = [
    { bg: 'var(--ard-blue)', fg: '#fff' },
    { bg: 'var(--ard-gold-light)', fg: 'var(--ard-gold)' },
    { bg: 'var(--green-bg)', fg: 'var(--green)' },
    { bg: 'var(--purple-bg)', fg: 'var(--purple)' },
    { bg: 'var(--teal-bg)', fg: 'var(--teal)' },
  ];
  function pickColor(name) {
    var sum = 0;
    for (var i = 0; i < name.length; i++) sum += name.charCodeAt(i);
    return AVATAR_COLORS[sum % AVATAR_COLORS.length];
  }

  function fmtDate(s) {
    if (!s) return '';
    var d = new Date(s);
    var now = new Date();
    var diffDays = Math.floor((now - d) / (1000 * 60 * 60 * 24));
    if (diffDays === 0) return 'Aujourd\'hui';
    if (diffDays === 1) return 'Hier';
    if (diffDays < 7) return 'Il y a ' + diffDays + 'j';
    if (diffDays < 30) return 'Il y a ' + Math.floor(diffDays / 7) + 'sem';
    return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' });
  }

  async function loadContacts() {
    try {
      var subtitleEl = document.getElementById('contacts-subtitle');
      var tbodyEl = document.getElementById('contacts-tbody');
      var paginationEl = document.getElementById('contacts-pagination');

      // 1. Tous les contacts
      var cR = await sb.from('contacts').select('*').order('created_at', { ascending: false });
      if (cR.error) throw cR.error;
      var contacts = cR.data || [];

      // 2. Toutes les inscriptions pour determiner statut
      var iR = await sb.from('formation_inscriptions').select('contact_id, statut, commercial_responsable, created_at').order('created_at', { ascending: false });
      var inscriptions = iR.data || [];

      // 3. Grouper inscriptions par contact
      var insByContact = {};
      for (var i = 0; i < inscriptions.length; i++) {
        var ins = inscriptions[i];
        if (!insByContact[ins.contact_id]) insByContact[ins.contact_id] = [];
        insByContact[ins.contact_id].push(ins);
      }

      // 4. Compter les nouveaux contacts cette semaine
      var oneWeekAgo = new Date();
      oneWeekAgo.setDate(oneWeekAgo.getDate() - 7);
      var nbNouveaux = contacts.filter(function(c) { return new Date(c.created_at) >= oneWeekAgo; }).length;

      // 5. Update sous-titre
      if (subtitleEl) {
        subtitleEl.textContent = contacts.length + ' contact' + (contacts.length > 1 ? 's' : '') + ' · ' + nbNouveaux + ' nouveau' + (nbNouveaux > 1 ? 'x' : '') + ' cette semaine';
      }

      // 6. Render tbody
      if (contacts.length === 0) {
        tbodyEl.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Aucun contact</td></tr>';
      } else {
        var rows = contacts.map(function(c) {
          var ins = insByContact[c.id] || [];
          var lastIns = ins[0];
          var nbIns = ins.length;
          var nbConfirmes = ins.filter(function(i) { return i.statut === 'confirme' || i.statut === 'present'; }).length;

          // Badge statut
          var statutBadge = '<span class="badge b-gray">Lead</span>';
          if (nbConfirmes > 0) statutBadge = '<span class="badge b-green">Client</span>';
          else if (nbIns > 0) statutBadge = '<span class="badge b-amber">Prospect</span>';

          // Badge type (heuristique simple: si entreprise dans inscriptions, Salarie, sinon Intermittent)
          var typeBadge = '<span class="badge b-navy">Stagiaire</span>';

          // Initiales + couleur
          var initials = getInitials(c.prenom, c.nom);
          var color = pickColor(c.prenom + c.nom);
          var avStyle = 'background:' + color.bg + ';color:' + color.fg;

          // Nombre d'inscriptions
          var nbInsHtml = nbIns > 0
            ? '<span class="badge b-teal">' + nbIns + ' inscription' + (nbIns > 1 ? 's' : '') + '</span>'
            : '<span class="text-xs text-muted">—</span>';

          // Commercial
          var commercial = lastIns && lastIns.commercial_responsable
            ? escapeHtml(lastIns.commercial_responsable)
            : '<span class="text-muted">—</span>';

          // Activite = derniere inscription ou creation contact
          var activityDate = lastIns ? lastIns.created_at : c.created_at;

          return '<tr>' +
            '<td><input type="checkbox" onclick="event.stopPropagation()"></td>' +
            '<td><div class="flex items-c gap-2">' +
              '<div class="av" style="' + avStyle + '">' + initials + '</div>' +
              '<div>' +
                '<div class="name-cell">' + escapeHtml((c.prenom || '') + ' ' + (c.nom || '')).trim() + '</div>' +
                '<div class="text-xs text-muted">' + escapeHtml(c.email || '—') + '</div>' +
              '</div>' +
            '</div></td>' +
            '<td>' + statutBadge + '</td>' +
            '<td>' + typeBadge + '</td>' +
            '<td class="text-xs">' + escapeHtml(c.telephone || '—') + '</td>' +
            '<td>' + nbInsHtml + '</td>' +
            '<td>' + commercial + '</td>' +
            '<td class="text-xs text-muted">' + fmtDate(activityDate) + '</td>' +
            '<td><button class="btn-s" style="font-size:11px;padding:3px 8px" onclick="event.stopPropagation()">Voir</button></td>' +
          '</tr>';
        });
        tbodyEl.innerHTML = rows.join('');
      }

      // 7. Update pagination footer
      if (paginationEl) {
        var shown = Math.min(contacts.length, contacts.length);
        paginationEl.textContent = contacts.length > 0
          ? '1–' + shown + ' sur ' + contacts.length
          : '0 contact';
      }

      console.log('[Ardalos Contacts] OK charges :', contacts.length, 'contacts,', nbNouveaux, 'nouveaux cette semaine');
    } catch (e) {
      console.error('[Ardalos Contacts] Erreur:', e);
      var tbodyEl = document.getElementById('contacts-tbody');
      if (tbodyEl) tbodyEl.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:20px;color:#dc2626">Erreur de chargement : ' + escapeHtml(e.message || 'inconnue') + '</td></tr>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadContacts);
  } else {
    loadContacts();
  }
})();
</script>


<!-- === CONNEXION SUPABASE POUR FORMATEURS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';

  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    console.warn('[Ardalos Formateurs] Lib Supabase non chargee');
    return;
  }
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function getInitials(prenom, nom) {
    var p = (prenom || '').trim();
    var n = (nom || '').trim();
    var ip = p.length > 0 ? p[0].toUpperCase() : '';
    var in_ = n.length > 0 ? n[0].toUpperCase() : '';
    return (ip + in_) || '??';
  }

  // Palette de couleurs pour les avatars (repartition stable via hash)
  var AVATAR_COLORS = [
    { bg: 'var(--ard-blue)', fg: '#fff' },
    { bg: 'var(--ard-dark2)', fg: 'var(--ard-gold)' },
    { bg: 'var(--teal-bg)', fg: 'var(--teal)' },
    { bg: 'var(--green-bg)', fg: 'var(--green)' },
    { bg: 'var(--purple-bg)', fg: 'var(--purple)' },
    { bg: 'var(--ard-gold-light)', fg: 'var(--ard-gold)' },
  ];
  function pickColor(name) {
    var sum = 0;
    for (var i = 0; i < name.length; i++) sum += name.charCodeAt(i);
    return AVATAR_COLORS[sum % AVATAR_COLORS.length];
  }

  async function loadFormateurs() {
    try {
      var subtitleEl = document.getElementById('formateurs-subtitle');
      var gridEl = document.getElementById('formateurs-grid');

      // 1. Tous les formateurs
      var fR = await sb.from('formateurs').select('*').order('nom', { ascending: true });
      if (fR.error) throw fR.error;
      var formateurs = fR.data || [];

      // 2. Toutes les sessions 2026 pour compter par formateur
      var anneeActuelle = new Date().getFullYear();
      var debutAnnee = anneeActuelle + '-01-01';
      var finAnnee = anneeActuelle + '-12-31';
      var sR = await sb.from('formation_sessions')
        .select('id, formateur_id, date_debut')
        .gte('date_debut', debutAnnee)
        .lte('date_debut', finAnnee);
      var sessions = sR.data || [];

      // 3. Toutes les inscriptions pour compter les apprenants par session
      var iR = await sb.from('formation_inscriptions').select('session_id, statut');
      var inscriptions = iR.data || [];

      // Map session -> nb apprenants
      var apprenantsBySession = {};
      for (var i = 0; i < inscriptions.length; i++) {
        var ins = inscriptions[i];
        if (ins.statut === 'abandon') continue;
        apprenantsBySession[ins.session_id] = (apprenantsBySession[ins.session_id] || 0) + 1;
      }

      // Agreger par formateur
      var statsByFormateur = {};
      formateurs.forEach(function(f) {
        statsByFormateur[f.id] = { nbSessions: 0, nbApprenants: 0 };
      });
      sessions.forEach(function(s) {
        if (s.formateur_id && statsByFormateur[s.formateur_id]) {
          statsByFormateur[s.formateur_id].nbSessions++;
          statsByFormateur[s.formateur_id].nbApprenants += (apprenantsBySession[s.id] || 0);
        }
      });

      // Update sous-titre
      if (subtitleEl) {
        subtitleEl.textContent = formateurs.length + ' formateur' + (formateurs.length > 1 ? 's' : '') + ' certifie' + (formateurs.length > 1 ? 's' : '') + ' · Tous Qualiopi';
      }

      // Render grid
      if (formateurs.length === 0) {
        gridEl.innerHTML = '<div style="grid-column:1/-1;padding:40px;text-align:center;color:#9ca3af;font-style:italic">Aucun formateur dans la base</div>';
      } else {
        var cards = formateurs.map(function(f) {
          var stats = statsByFormateur[f.id] || { nbSessions: 0, nbApprenants: 0 };
          var initials = getInitials(f.prenom, f.nom);
          var nomComplet = ((f.prenom || '') + ' ' + (f.nom || '')).trim() || 'Sans nom';
          var color = pickColor(nomComplet);
          var avStyle = 'background:' + color.bg + ';color:' + color.fg;
          var specialite = f.specialite || f.titre || 'Formateur';

          // Satisfaction : on a pas de donnees reelles, on laisse un placeholder
          var satisfaction = '<span class="text-muted">—</span>';

          return '<div class="card cursor-p" onmouseover="this.style.boxShadow=\'var(--s2)\'" onmouseout="this.style.boxShadow=\'none\'">' +
            '<div class="card-h"><div class="flex items-c gap-3">' +
              '<div class="av av-lg" style="' + avStyle + '">' + initials + '</div>' +
              '<div>' +
                '<div class="font-sb" style="color:var(--ard-dark)">' + escapeHtml(nomComplet) + '</div>' +
                '<div class="text-xs text-muted">' + escapeHtml(specialite) + '</div>' +
              '</div>' +
            '</div></div>' +
            '<div class="card-b">' +
              '<div class="si"><span class="si-l">Sessions ' + anneeActuelle + '</span><span class="si-r">' + stats.nbSessions + '</span></div>' +
              '<div class="si"><span class="si-l">Apprenants</span><span class="si-r">' + stats.nbApprenants + '</span></div>' +
              '<div class="si"><span class="si-l">Satisfaction</span><span class="si-r">' + satisfaction + '</span></div>' +
              '<div class="si"><span class="si-l">Qualiopi</span><span class="si-r"><span class="badge b-green">Conforme</span></span></div>' +
            '</div>' +
            '<div class="card-f"><button class="btn-s" style="font-size:11px">Fiche</button><button class="btn-p" style="font-size:11px;padding:4px 10px;margin-left:4px" onclick="navigate(\'documents\')">Docs</button></div>' +
          '</div>';
        });
        gridEl.innerHTML = cards.join('');
      }

      console.log('[Ardalos Formateurs] OK charges :', formateurs.length, 'formateurs');
    } catch (e) {
      console.error('[Ardalos Formateurs] Erreur:', e);
      var gridEl = document.getElementById('formateurs-grid');
      if (gridEl) gridEl.innerHTML = '<div style="grid-column:1/-1;padding:40px;text-align:center;color:#dc2626">Erreur de chargement : ' + escapeHtml(e.message || 'inconnue') + '</div>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadFormateurs);
  } else {
    loadFormateurs();
  }
})();
</script>


<!-- === CONNEXION SUPABASE POUR APPRENANTS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    console.warn('[Ardalos Apprenants] Lib Supabase non chargee');
    return;
  }
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function getInitials(prenom, nom) {
    var p = (prenom || '').trim();
    var n = (nom || '').trim();
    return ((p[0] || '').toUpperCase() + (n[0] || '').toUpperCase()) || '??';
  }

  var AVATAR_COLORS = [
    { bg: 'var(--ard-blue)', fg: '#fff' },
    { bg: 'var(--ard-gold-light)', fg: 'var(--ard-gold)' },
    { bg: 'var(--green-bg)', fg: 'var(--green)' },
    { bg: 'var(--purple-bg)', fg: 'var(--purple)' },
    { bg: 'var(--teal-bg)', fg: 'var(--teal)' },
  ];
  function pickColor(name) {
    var sum = 0;
    for (var i = 0; i < name.length; i++) sum += name.charCodeAt(i);
    return AVATAR_COLORS[sum % AVATAR_COLORS.length];
  }

  function fmtCohorte(dateDebut, dateFin) {
    if (!dateDebut) return '—';
    var d1 = new Date(dateDebut);
    var mois = ['Janv', 'Fev', 'Mars', 'Avr', 'Mai', 'Juin', 'Juil', 'Aout', 'Sept', 'Oct', 'Nov', 'Dec'];
    var s = mois[d1.getMonth()] + ' ' + d1.getFullYear();
    if (dateFin) {
      var d2 = new Date(dateFin);
      if (d2.getMonth() !== d1.getMonth() || d2.getFullYear() !== d1.getFullYear()) {
        s = mois[d1.getMonth()] + '–' + mois[d2.getMonth()] + ' ' + d2.getFullYear();
      }
    }
    return s;
  }

  function getAvancement(dateDebut, dateFin) {
    if (!dateDebut) return { pct: 0, label: 'A venir', cls: '' };
    var now = Date.now();
    var d1 = new Date(dateDebut).getTime();
    var d2 = dateFin ? new Date(dateFin).getTime() : null;
    if (now < d1) return { pct: 0, label: 'A venir', cls: '' };
    if (d2 && now > d2) return { pct: 100, label: 'Termine', cls: 'green' };
    if (d2 && d2 > d1) {
      var pct = Math.round(((now - d1) / (d2 - d1)) * 100);
      return { pct: pct, label: pct + '%', cls: pct >= 66 ? 'green' : (pct >= 33 ? '' : 'gold') };
    }
    return { pct: 50, label: 'En cours', cls: '' };
  }

  async function loadApprenants() {
    try {
      var subtitleEl = document.getElementById('apprenants-subtitle');
      var tbodyEl = document.getElementById('apprenants-tbody');

      // 1. Inscriptions actives + jointures
      var iR = await sb.from('formation_inscriptions')
        .select('id, statut, contact_id, session_id, contacts(prenom, nom), formation_sessions(date_debut, date_fin, formations(titre))')
        .neq('statut', 'abandon')
        .order('created_at', { ascending: false });
      if (iR.error) throw iR.error;
      var inscriptions = iR.data || [];

      // 2. Financements
      var fR = await sb.from('formation_financements').select('inscription_id, type_financement, statut_dossier');
      var finByIns = {};
      (fR.data || []).forEach(function(f) {
        if (!finByIns[f.inscription_id]) finByIns[f.inscription_id] = [];
        finByIns[f.inscription_id].push(f);
      });

      // Dedup par contact_id : on garde seulement la derniere inscription par personne
      var seenContacts = {};
      var apprenants = [];
      for (var i = 0; i < inscriptions.length; i++) {
        var ins = inscriptions[i];
        if (!ins.contact_id || seenContacts[ins.contact_id]) continue;
        seenContacts[ins.contact_id] = true;
        apprenants.push(ins);
      }

      // Calculer nb cohortes distinctes
      var cohortes = {};
      apprenants.forEach(function(a) {
        if (a.formation_sessions) {
          cohortes[a.formation_sessions.date_debut + '|' + (a.formation_sessions.formations ? a.formation_sessions.formations.titre : '')] = true;
        }
      });
      var nbCohortes = Object.keys(cohortes).length;

      // Sous-titre
      if (subtitleEl) {
        subtitleEl.textContent = apprenants.length + ' actif' + (apprenants.length > 1 ? 's' : '') + ' · ' + nbCohortes + ' cohorte' + (nbCohortes > 1 ? 's' : '');
      }

      // Render
      if (apprenants.length === 0) {
        tbodyEl.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Aucun apprenant actif</td></tr>';
      } else {
        var rows = apprenants.map(function(a) {
          var contact = a.contacts || {};
          var session = a.formation_sessions || {};
          var formation = session.formations || {};
          var nom = ((contact.prenom || '') + ' ' + (contact.nom || '')).trim() || 'Sans nom';
          var initials = getInitials(contact.prenom, contact.nom);
          var color = pickColor(nom);
          var avStyle = 'background:' + color.bg + ';color:' + color.fg;

          var cohorte = fmtCohorte(session.date_debut, session.date_fin);
          var avancement = getAvancement(session.date_debut, session.date_fin);

          // Financement
          var fins = finByIns[a.id] || [];
          var finBadge = '<span class="text-muted text-xs">—</span>';
          if (fins.length > 0) {
            var types = fins.map(function(f) { return f.type_financement; }).join(', ');
            var cls = 'b-navy';
            if (types.indexOf('AFDAS') !== -1) cls = 'b-navy';
            else if (types.indexOf('CPF') !== -1) cls = 'b-teal';
            else if (types.indexOf('OPCO') !== -1) cls = 'b-teal';
            finBadge = '<span class="badge ' + cls + '">' + escapeHtml(types) + '</span>';
          }

          return '<tr>' +
            '<td><div class="flex items-c gap-2">' +
              '<div class="av" style="' + avStyle + '">' + initials + '</div>' +
              '<div>' +
                '<div class="name-cell">' + escapeHtml(nom) + '</div>' +
                '<div class="text-xs text-muted">Stagiaire</div>' +
              '</div>' +
            '</div></td>' +
            '<td>' + escapeHtml(formation.titre || '—') + '</td>' +
            '<td>' + escapeHtml(cohorte) + '</td>' +
            '<td><div class="flex items-c gap-2">' +
              '<div class="prog" style="width:60px"><div class="prog-fill ' + avancement.cls + '" style="width:' + avancement.pct + '%"></div></div>' +
              '<span class="text-xs' + (avancement.cls ? ' text-' + avancement.cls : '') + '">' + avancement.label + '</span>' +
            '</div></td>' +
            '<td><span class="text-muted text-xs">—</span></td>' +
            '<td>' + finBadge + '</td>' +
            '<td><span class="text-muted text-xs">—</span></td>' +
            '<td><button class="btn-s" style="font-size:11px;padding:3px 8px">Voir</button></td>' +
          '</tr>';
        });
        tbodyEl.innerHTML = rows.join('');
      }

      console.log('[Ardalos Apprenants] OK charges :', apprenants.length, 'apprenants,', nbCohortes, 'cohortes');
    } catch (e) {
      console.error('[Ardalos Apprenants] Erreur:', e);
      var tbodyEl = document.getElementById('apprenants-tbody');
      if (tbodyEl) tbodyEl.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:20px;color:#dc2626">Erreur : ' + escapeHtml(e.message || 'inconnue') + '</td></tr>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadApprenants);
  } else {
    loadApprenants();
  }
})();
</script>


<!-- === CONNEXION SUPABASE POUR SESSIONS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtCohorte(dateDebut, dateFin) {
    if (!dateDebut) return '—';
    var d1 = new Date(dateDebut);
    var mois = ['Janv', 'Fev', 'Mars', 'Avr', 'Mai', 'Juin', 'Juil', 'Aout', 'Sept', 'Oct', 'Nov', 'Dec'];
    var s = mois[d1.getMonth()] + ' ' + d1.getFullYear();
    if (dateFin) {
      var d2 = new Date(dateFin);
      if (d2.getMonth() !== d1.getMonth() || d2.getFullYear() !== d1.getFullYear()) {
        s = mois[d1.getMonth()] + '–' + mois[d2.getMonth()] + ' ' + d2.getFullYear();
      }
    }
    return s;
  }

  function getAvancement(dateDebut, dateFin) {
    if (!dateDebut) return { pct: 0, label: '0%', cls: '', statut: 'A venir', statutCls: 'b-gray' };
    var now = Date.now();
    var d1 = new Date(dateDebut).getTime();
    var d2 = dateFin ? new Date(dateFin).getTime() : null;
    if (now < d1) return { pct: 0, label: '0%', cls: '', statut: 'Demarrage', statutCls: 'b-amber' };
    if (d2 && now > d2) return { pct: 100, label: '100%', cls: 'green', statut: 'Cloture', statutCls: 'b-navy' };
    if (d2 && d2 > d1) {
      var pct = Math.round(((now - d1) / (d2 - d1)) * 100);
      return {
        pct: pct,
        label: pct + '%',
        cls: pct >= 66 ? 'green' : (pct >= 33 ? '' : 'gold'),
        statut: 'En cours',
        statutCls: 'b-green'
      };
    }
    return { pct: 50, label: 'En cours', cls: '', statut: 'En cours', statutCls: 'b-green' };
  }

  async function loadSessions() {
    try {
      var subtitleEl = document.getElementById('sessions-subtitle');
      var tbodyEl = document.getElementById('sessions-tbody');

      // Sessions avec formations jointes
      var sR = await sb.from('formation_sessions')
        .select('id, date_debut, date_fin, formateur_principal_id, formateur_principal, formation_id, formations(titre)')
        .order('date_debut', { ascending: false });
      if (sR.error) throw sR.error;
      var sessions = sR.data || [];

      // Formateurs
      var fR = await sb.from('formateurs').select('id, prenom, nom');
      var formateursById = {};
      (fR.data || []).forEach(function(f) { formateursById[f.id] = f; });

      // Inscriptions pour compter apprenants par session
      var iR = await sb.from('formation_inscriptions').select('session_id, statut');
      var nbBySession = {};
      var totalApprenants = 0;
      (iR.data || []).forEach(function(i) {
        if (i.statut === 'abandon') return;
        nbBySession[i.session_id] = (nbBySession[i.session_id] || 0) + 1;
        totalApprenants++;
      });

      // Sessions actives (en cours + a venir)
      var now = Date.now();
      var actives = sessions.filter(function(s) {
        if (!s.date_fin) return true;
        return new Date(s.date_fin).getTime() >= now;
      });

      if (subtitleEl) {
        subtitleEl.textContent = actives.length + ' cohorte' + (actives.length > 1 ? 's' : '') + ' active' + (actives.length > 1 ? 's' : '') + ' · ' + totalApprenants + ' apprenant' + (totalApprenants > 1 ? 's' : '');
      }

      if (sessions.length === 0) {
        tbodyEl.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Aucune session</td></tr>';
      } else {
        var rows = sessions.map(function(s) {
          var formateur = s.formateur_principal_id ? formateursById[s.formateur_principal_id] : null;
          var formateurNom = formateur
            ? ((formateur.prenom || '') + ' ' + (formateur.nom || '')).trim()
            : (s.formateur_principal || '—');
          var formationTitre = (s.formations && s.formations.titre) || '—';
          var cohorte = fmtCohorte(s.date_debut, s.date_fin);
          var nb = nbBySession[s.id] || 0;
          var av = getAvancement(s.date_debut, s.date_fin);

          return '<tr>' +
            '<td class="name-cell">' + escapeHtml(cohorte) + '</td>' +
            '<td>' + escapeHtml(formationTitre) + '</td>' +
            '<td>' + escapeHtml(formateurNom) + '</td>' +
            '<td>' + nb + '</td>' +
            '<td><div class="flex items-c gap-2">' +
              '<div class="prog" style="width:60px"><div class="prog-fill ' + av.cls + '" style="width:' + av.pct + '%"></div></div>' +
              '<span class="text-xs' + (av.cls ? ' text-' + av.cls : '') + '">' + av.label + '</span>' +
            '</div></td>' +
            '<td><span class="badge ' + av.statutCls + '">' + av.statut + '</span></td>' +
          '</tr>';
        });
        tbodyEl.innerHTML = rows.join('');
      }

      console.log('[Ardalos Sessions] OK :', sessions.length, 'sessions,', actives.length, 'actives,', totalApprenants, 'apprenants');
    } catch (e) {
      console.error('[Ardalos Sessions] Erreur:', e);
      var tbodyEl = document.getElementById('sessions-tbody');
      if (tbodyEl) tbodyEl.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:20px;color:#dc2626">Erreur : ' + escapeHtml(e.message || 'inconnue') + '</td></tr>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadSessions);
  } else {
    loadSessions();
  }
})();
</script>


<!-- === CONNEXION SUPABASE FORMATIONS + MODALES UNIVERSELLES === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  // Cache pour eviter de recharger a chaque ouverture de modale
  var cache = {
    formations: null,
    formateurs: null,
    sessions: null,
    inscriptions: null,
    financements: null,
    contacts: null,
  };

  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtEuro(n) {
    if (!n || n === 0) return '—';
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function fmtDate(s) {
    if (!s) return '—';
    return new Date(s).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function fmtCohorte(dateDebut, dateFin) {
    if (!dateDebut) return '—';
    var d1 = new Date(dateDebut);
    var mois = ['Janv', 'Fev', 'Mars', 'Avr', 'Mai', 'Juin', 'Juil', 'Aout', 'Sept', 'Oct', 'Nov', 'Dec'];
    var s = mois[d1.getMonth()] + ' ' + d1.getFullYear();
    if (dateFin) {
      var d2 = new Date(dateFin);
      if (d2.getMonth() !== d1.getMonth() || d2.getFullYear() !== d1.getFullYear()) {
        s = mois[d1.getMonth()] + '–' + mois[d2.getMonth()] + ' ' + d2.getFullYear();
      }
    }
    return s;
  }

  function getInitials(prenom, nom) {
    var p = (prenom || '').trim();
    var n = (nom || '').trim();
    return ((p[0] || '').toUpperCase() + (n[0] || '').toUpperCase()) || '??';
  }

  // Precharger toutes les donnees une fois
  async function loadAllData() {
    if (cache.formations) return; // deja charge

    var results = await Promise.all([
      sb.from('formations').select('*').order('titre', { ascending: true }),
      sb.from('formateurs').select('*'),
      sb.from('formation_sessions').select('*'),
      sb.from('formation_inscriptions').select('*, contacts(prenom, nom, email, telephone)'),
      sb.from('formation_financements').select('*'),
      sb.from('contacts').select('*'),
    ]);

    cache.formations = results[0].data || [];
    cache.formateurs = results[1].data || [];
    cache.sessions = results[2].data || [];
    cache.inscriptions = results[3].data || [];
    cache.financements = results[4].data || [];
    cache.contacts = results[5].data || [];
  }

  // =====================================================================
  // SECTION FORMATIONS (rendu)
  // =====================================================================
  async function loadFormations() {
    try {
      await loadAllData();

      var subtitleEl = document.getElementById('formations-subtitle');
      var gridEl = document.getElementById('formations-grid');
      var formations = cache.formations;

      if (subtitleEl) {
        subtitleEl.textContent = 'Catalogue · ' + formations.length + ' formation' + (formations.length > 1 ? 's' : '') + ' · NDA: 93132464513';
      }

      if (formations.length === 0) {
        gridEl.innerHTML = '<div style="grid-column:1/-1;padding:40px;text-align:center;color:#9ca3af;font-style:italic">Aucune formation dans le catalogue</div>';
        return;
      }

      // Map sessions par formation (pour compter cohortes 2026)
      var anneeActuelle = new Date().getFullYear();
      var sessionsByFormation = {};
      cache.sessions.forEach(function(s) {
        if (!s.formation_id) return;
        if (!sessionsByFormation[s.formation_id]) sessionsByFormation[s.formation_id] = [];
        sessionsByFormation[s.formation_id].push(s);
      });

      // Couleurs en-tetes (cycle bleu / or / gris)
      var HEADER_STYLES = [
        'background:var(--ard-blue);border-color:var(--ard-blue)',
        'background:var(--ard-dark2);border-color:var(--ard-dark2)',
        'background:#374151;border-color:#374151',
      ];

      var cards = formations.map(function(f, idx) {
        var hStyle = HEADER_STYLES[idx % 3];
        var sessions = sessionsByFormation[f.id] || [];
        var sessionsThisYear = sessions.filter(function(s) {
          if (!s.date_debut) return false;
          return new Date(s.date_debut).getFullYear() === anneeActuelle;
        });
        var nbCohortes = sessionsThisYear.length;

        var duree = f.duree ? f.duree + 'h' : '—';
        var modalite = f.modalite || '—';
        var tarif = f.tarif ? fmtEuro(Number(f.tarif)) : '—';
        var financement = f.financement || 'À définir';

        // Badges financement (extrait depuis le champ)
        var finBadges = '';
        if (f.financement) {
          var finArr = f.financement.split(/[,;/]/).map(function(x) { return x.trim(); }).filter(Boolean);
          finBadges = finArr.slice(0, 3).map(function(ff) {
            var cls = 'b-navy';
            if (ff.toUpperCase().indexOf('CPF') !== -1) cls = 'b-teal';
            else if (ff.toUpperCase().indexOf('OPCO') !== -1) cls = 'b-teal';
            return '<span class="badge ' + cls + '" style="font-size:10px">' + escapeHtml(ff) + '</span>';
          }).join(' ');
        }
        if (!finBadges) finBadges = '<span class="text-muted text-xs">À définir</span>';

        return '<div class="card" style="cursor:pointer;transition:all var(--tr)" onmouseover="this.style.boxShadow=\'var(--s2)\'" onmouseout="this.style.boxShadow=\'none\'" onclick="window.ardalosOpenFormation(\'' + escapeHtml(f.id) + '\')">' +
          '<div class="card-h" style="' + hStyle + '">' +
            '<span class="card-title" style="color:#fff">' + escapeHtml(f.titre || 'Sans titre') + '</span>' +
            '<span class="badge b-gold">Qualiopi</span>' +
          '</div>' +
          '<div class="card-b">' +
            '<div class="si"><span class="si-l">Durée</span><span class="si-r">' + duree + '</span></div>' +
            '<div class="si"><span class="si-l">Modalité</span><span class="si-r">' + escapeHtml(modalite) + '</span></div>' +
            '<div class="si"><span class="si-l">Tarif HT</span><span class="si-r">' + tarif + '</span></div>' +
            (f.niveau ? '<div class="si"><span class="si-l">Niveau</span><span class="si-r">' + escapeHtml(f.niveau) + '</span></div>' : '') +
            '<div class="si"><span class="si-l">Financement</span><span class="si-r" style="display:flex;gap:3px;flex-wrap:wrap;justify-content:flex-end">' + finBadges + '</span></div>' +
            '<div style="margin-top:10px">' +
              '<div class="flex items-c justify-b mb-1">' +
                '<span class="text-xs text-muted">Sessions ' + anneeActuelle + '</span>' +
                '<span class="text-xs font-sb">' + nbCohortes + '</span>' +
              '</div>' +
              '<div class="prog"><div class="prog-fill gold" style="width:' + Math.min(nbCohortes * 33, 100) + '%"></div></div>' +
            '</div>' +
          '</div>' +
          '<div class="card-f">' +
            '<span class="badge b-green">Active</span>' +
            '<button class="btn-s" style="font-size:11px;padding:3px 10px;margin-left:auto" onclick="event.stopPropagation();window.ardalosOpenFormation(\'' + escapeHtml(f.id) + '\')">Gérer</button>' +
          '</div>' +
        '</div>';
      });
      gridEl.innerHTML = cards.join('');

      console.log('[Ardalos Formations] OK :', formations.length, 'formations');
    } catch (e) {
      console.error('[Ardalos Formations] Erreur:', e);
      var gridEl = document.getElementById('formations-grid');
      if (gridEl) gridEl.innerHTML = '<div style="grid-column:1/-1;padding:40px;text-align:center;color:#dc2626">Erreur : ' + escapeHtml(e.message || 'inconnue') + '</div>';
    }
  }

  // =====================================================================
  // MODALE FORMATION : ouvrir + rendu
  // =====================================================================
  window.ardalosOpenFormation = async function(formationId) {
    try {
      await loadAllData();
      var titleEl = document.getElementById('detail-modal-title');
      var bodyEl = document.getElementById('detail-modal-body');

      var formation = cache.formations.find(function(f) { return f.id === formationId; });
      if (!formation) { alert('Formation introuvable'); return; }

      titleEl.textContent = formation.titre || 'Formation';

      var sessions = cache.sessions.filter(function(s) { return s.formation_id === formationId; });
      sessions.sort(function(a, b) {
        return new Date(b.date_debut || 0).getTime() - new Date(a.date_debut || 0).getTime();
      });

      // Nb apprenants par session
      var nbBySession = {};
      cache.inscriptions.forEach(function(i) {
        if (i.statut === 'abandon') return;
        nbBySession[i.session_id] = (nbBySession[i.session_id] || 0) + 1;
      });

      var totalApprenants = 0;
      sessions.forEach(function(s) { totalApprenants += (nbBySession[s.id] || 0); });

      // Formateurs
      var formateursById = {};
      cache.formateurs.forEach(function(f) { formateursById[f.id] = f; });

      var sessionsHtml = sessions.length === 0
        ? '<div style="padding:14px;text-align:center;color:#9ca3af;font-style:italic;border:1px dashed #e5e7eb;border-radius:8px">Aucune session pour cette formation</div>'
        : '<table class="dt" style="font-size:12px">' +
            '<thead><tr><th>Cohorte</th><th>Formateur</th><th>Lieu</th><th>Apprenants</th><th>Statut</th></tr></thead>' +
            '<tbody>' +
              sessions.map(function(s) {
                var formateur = s.formateur_principal_id ? formateursById[s.formateur_principal_id] : null;
                var formateurNom = formateur
                  ? ((formateur.prenom || '') + ' ' + (formateur.nom || '')).trim()
                  : (s.formateur_principal || '—');
                var nb = nbBySession[s.id] || 0;
                var statutLabel = s.statut || (s.date_debut && new Date(s.date_debut) > new Date() ? 'À venir' : 'En cours');
                return '<tr>' +
                  '<td>' + escapeHtml(fmtCohorte(s.date_debut, s.date_fin)) + '</td>' +
                  '<td>' + escapeHtml(formateurNom) + '</td>' +
                  '<td>' + escapeHtml(s.lieu || '—') + '</td>' +
                  '<td>' + nb + '</td>' +
                  '<td><span class="badge b-navy">' + escapeHtml(statutLabel) + '</span></td>' +
                '</tr>';
              }).join('') +
            '</tbody>' +
          '</table>';

      bodyEl.innerHTML =
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">' +
          '<div class="si"><span class="si-l">Durée</span><span class="si-r">' + (formation.duree ? formation.duree + 'h' : '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Tarif HT</span><span class="si-r">' + (formation.tarif ? fmtEuro(Number(formation.tarif)) : '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Modalité</span><span class="si-r">' + escapeHtml(formation.modalite || '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Niveau</span><span class="si-r">' + escapeHtml(formation.niveau || '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Financement</span><span class="si-r">' + escapeHtml(formation.financement || '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Réf. interne</span><span class="si-r">' + escapeHtml(formation.ref_interne || '—') + '</span></div>' +
        '</div>' +
        (formation.description ? '<div style="margin-bottom:10px"><div class="text-xs text-muted" style="margin-bottom:4px">Description</div><div style="font-size:13px">' + escapeHtml(formation.description) + '</div></div>' : '') +
        (formation.objectifs ? '<div style="margin-bottom:10px"><div class="text-xs text-muted" style="margin-bottom:4px">Objectifs</div><div style="font-size:13px;white-space:pre-wrap">' + escapeHtml(formation.objectifs) + '</div></div>' : '') +
        (formation.prerequis ? '<div style="margin-bottom:10px"><div class="text-xs text-muted" style="margin-bottom:4px">Prérequis</div><div style="font-size:13px;white-space:pre-wrap">' + escapeHtml(formation.prerequis) + '</div></div>' : '') +
        (formation.public_vise ? '<div style="margin-bottom:10px"><div class="text-xs text-muted" style="margin-bottom:4px">Public visé</div><div style="font-size:13px;white-space:pre-wrap">' + escapeHtml(formation.public_vise) + '</div></div>' : '') +
        '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="flex items-c justify-b" style="margin-bottom:10px">' +
            '<span class="font-sb" style="font-size:13px;color:var(--ard-dark)">Sessions programmées</span>' +
            '<span class="text-xs text-muted">' + sessions.length + ' session' + (sessions.length > 1 ? 's' : '') + ' · ' + totalApprenants + ' apprenant' + (totalApprenants > 1 ? 's' : '') + '</span>' +
          '</div>' +
          sessionsHtml +
        '</div>';

      openModal('detail');
    } catch (e) {
      console.error(e);
      alert('Erreur : ' + (e.message || 'inconnue'));
    }
  };

  // =====================================================================
  // MODALE APPRENANT : ouvrir + rendu
  // =====================================================================
  window.ardalosOpenApprenant = async function(contactId) {
    try {
      await loadAllData();
      var titleEl = document.getElementById('detail-modal-title');
      var bodyEl = document.getElementById('detail-modal-body');

      var contact = cache.contacts.find(function(c) { return c.id === contactId; });
      if (!contact) { alert('Apprenant introuvable'); return; }

      titleEl.textContent = ((contact.prenom || '') + ' ' + (contact.nom || '')).trim() || 'Apprenant';

      var inscriptions = cache.inscriptions.filter(function(i) { return i.contact_id === contactId; });
      inscriptions.sort(function(a, b) {
        return new Date(b.created_at || 0).getTime() - new Date(a.created_at || 0).getTime();
      });

      var sessionsById = {};
      cache.sessions.forEach(function(s) { sessionsById[s.id] = s; });
      var formationsById = {};
      cache.formations.forEach(function(f) { formationsById[f.id] = f; });

      // Financements par inscription
      var finByIns = {};
      cache.financements.forEach(function(f) {
        if (!finByIns[f.inscription_id]) finByIns[f.inscription_id] = [];
        finByIns[f.inscription_id].push(f);
      });

      var inscriptionsHtml = inscriptions.length === 0
        ? '<div style="padding:14px;text-align:center;color:#9ca3af;font-style:italic;border:1px dashed #e5e7eb;border-radius:8px">Aucune inscription</div>'
        : inscriptions.map(function(i) {
            var s = sessionsById[i.session_id] || {};
            var f = formationsById[s.formation_id] || {};
            var fins = finByIns[i.id] || [];
            var finsText = fins.length > 0
              ? fins.map(function(ff) { return ff.type_financement + (ff.montant_ht ? ' (' + fmtEuro(Number(ff.montant_ht)) + ')' : ''); }).join(' · ')
              : '—';
            var statutCls = 'b-gray';
            if (i.statut === 'confirme' || i.statut === 'present') statutCls = 'b-green';
            else if (i.statut === 'abandon') statutCls = 'b-red';
            else if (i.statut === 'prospect') statutCls = 'b-amber';
            return '<div style="padding:10px;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:8px;font-size:12px">' +
              '<div class="flex items-c justify-b" style="margin-bottom:6px">' +
                '<span class="font-sb">' + escapeHtml(f.titre || 'Formation') + '</span>' +
                '<span class="badge ' + statutCls + '">' + escapeHtml(i.statut || 'inconnu') + '</span>' +
              '</div>' +
              '<div class="text-xs text-muted">Cohorte : ' + escapeHtml(fmtCohorte(s.date_debut, s.date_fin)) + ' · ' + escapeHtml(s.lieu || 'Lieu à préciser') + '</div>' +
              '<div class="text-xs" style="margin-top:4px">Montant : <strong>' + (i.montant_total_ht ? fmtEuro(Number(i.montant_total_ht)) : '—') + '</strong> · Financement : ' + escapeHtml(finsText) + '</div>' +
              (i.commercial_responsable ? '<div class="text-xs text-muted">Commercial : ' + escapeHtml(i.commercial_responsable) + '</div>' : '') +
            '</div>';
          }).join('');

      bodyEl.innerHTML =
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">' +
          '<div class="si"><span class="si-l">Email</span><span class="si-r">' + escapeHtml(contact.email || '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Téléphone</span><span class="si-r">' + escapeHtml(contact.telephone || '—') + '</span></div>' +
          '<div class="si"><span class="si-l">Créé le</span><span class="si-r">' + fmtDate(contact.created_at) + '</span></div>' +
          '<div class="si"><span class="si-l">Inscriptions</span><span class="si-r">' + inscriptions.length + '</span></div>' +
        '</div>' +
        '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="font-sb" style="font-size:13px;color:var(--ard-dark);margin-bottom:10px">Parcours de formation</div>' +
          inscriptionsHtml +
        '</div>';

      openModal('detail');
    } catch (e) {
      console.error(e);
      alert('Erreur : ' + (e.message || 'inconnue'));
    }
  };

  // =====================================================================
  // MODALE FORMATEUR : ouvrir + rendu
  // =====================================================================
  window.ardalosOpenFormateur = async function(formateurId) {
    try {
      await loadAllData();
      var titleEl = document.getElementById('detail-modal-title');
      var bodyEl = document.getElementById('detail-modal-body');

      var formateur = cache.formateurs.find(function(f) { return f.id === formateurId; });
      if (!formateur) { alert('Formateur introuvable'); return; }

      var nomComplet = ((formateur.prenom || '') + ' ' + (formateur.nom || '')).trim() || 'Formateur';
      titleEl.textContent = nomComplet;

      // Sessions de ce formateur
      var sessions = cache.sessions.filter(function(s) { return s.formateur_principal_id === formateurId; });
      sessions.sort(function(a, b) {
        return new Date(b.date_debut || 0).getTime() - new Date(a.date_debut || 0).getTime();
      });

      var formationsById = {};
      cache.formations.forEach(function(f) { formationsById[f.id] = f; });

      var nbBySession = {};
      cache.inscriptions.forEach(function(i) {
        if (i.statut === 'abandon') return;
        nbBySession[i.session_id] = (nbBySession[i.session_id] || 0) + 1;
      });

      var totalApprenants = 0;
      sessions.forEach(function(s) { totalApprenants += (nbBySession[s.id] || 0); });

      var sessionsHtml = sessions.length === 0
        ? '<div style="padding:14px;text-align:center;color:#9ca3af;font-style:italic;border:1px dashed #e5e7eb;border-radius:8px">Aucune session attribuée</div>'
        : sessions.map(function(s) {
            var f = formationsById[s.formation_id] || {};
            var nb = nbBySession[s.id] || 0;
            return '<div style="padding:10px;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:8px;font-size:12px">' +
              '<div class="flex items-c justify-b" style="margin-bottom:4px">' +
                '<span class="font-sb">' + escapeHtml(f.titre || 'Formation') + '</span>' +
                '<span class="badge b-navy">' + escapeHtml(fmtCohorte(s.date_debut, s.date_fin)) + '</span>' +
              '</div>' +
              '<div class="text-xs text-muted">' + escapeHtml(s.lieu || 'Lieu à préciser') + ' · ' + nb + ' apprenant' + (nb > 1 ? 's' : '') + '</div>' +
            '</div>';
          }).join('');

      bodyEl.innerHTML =
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">' +
          (formateur.specialite ? '<div class="si"><span class="si-l">Spécialité</span><span class="si-r">' + escapeHtml(formateur.specialite) + '</span></div>' : '') +
          (formateur.titre ? '<div class="si"><span class="si-l">Titre</span><span class="si-r">' + escapeHtml(formateur.titre) + '</span></div>' : '') +
          (formateur.email ? '<div class="si"><span class="si-l">Email</span><span class="si-r">' + escapeHtml(formateur.email) + '</span></div>' : '') +
          (formateur.telephone ? '<div class="si"><span class="si-l">Téléphone</span><span class="si-r">' + escapeHtml(formateur.telephone) + '</span></div>' : '') +
          '<div class="si"><span class="si-l">Sessions totales</span><span class="si-r">' + sessions.length + '</span></div>' +
          '<div class="si"><span class="si-l">Apprenants totaux</span><span class="si-r">' + totalApprenants + '</span></div>' +
        '</div>' +
        '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="font-sb" style="font-size:13px;color:var(--ard-dark);margin-bottom:10px">Sessions animées</div>' +
          sessionsHtml +
        '</div>';

      openModal('detail');
    } catch (e) {
      console.error(e);
      alert('Erreur : ' + (e.message || 'inconnue'));
    }
  };

  // =====================================================================
  // Patcher les fonctions existantes : apprenants + formateurs pour brancher les boutons
  // =====================================================================
  // On patche le script apprenants pour que le bouton "Voir" appelle ardalosOpenApprenant
  // Meme logique pour formateurs

  // On attend que le DOM ait charge puis on re-render avec les bons boutons
  function attachButtons() {
    // Apprenants : remplacer les "Voir" par des boutons qui ouvrent la modale
    var apprenantsTbody = document.getElementById('apprenants-tbody');
    if (apprenantsTbody) {
      // Observer les changements pour brancher le bouton
      var observer = new MutationObserver(function() {
        var buttons = apprenantsTbody.querySelectorAll('button');
        buttons.forEach(function(btn) {
          if (btn._ardalosHooked) return;
          var row = btn.closest('tr');
          if (!row) return;
          var nameEl = row.querySelector('.name-cell');
          if (!nameEl) return;
          var nomComplet = nameEl.textContent.trim();
          // Trouver le contact avec ce nom
          var contact = cache.contacts && cache.contacts.find(function(c) {
            return ((c.prenom || '') + ' ' + (c.nom || '')).trim() === nomComplet;
          });
          if (contact) {
            btn._ardalosHooked = true;
            btn.onclick = function(e) {
              e.stopPropagation();
              window.ardalosOpenApprenant(contact.id);
            };
          }
        });
      });
      observer.observe(apprenantsTbody, { childList: true, subtree: true });
    }

    // Formateurs : brancher le bouton "Fiche" de chaque card
    var formateursGrid = document.getElementById('formateurs-grid');
    if (formateursGrid) {
      var observer2 = new MutationObserver(function() {
        var cards = formateursGrid.querySelectorAll('.card');
        cards.forEach(function(card) {
          if (card._ardalosHooked) return;
          var nameEl = card.querySelector('.font-sb');
          if (!nameEl) return;
          var nomComplet = nameEl.textContent.trim();
          var formateur = cache.formateurs && cache.formateurs.find(function(f) {
            return ((f.prenom || '') + ' ' + (f.nom || '')).trim() === nomComplet;
          });
          if (formateur) {
            card._ardalosHooked = true;
            // Le premier bouton est "Fiche"
            var buttons = card.querySelectorAll('button');
            if (buttons.length >= 1) {
              buttons[0].onclick = function(e) {
                e.stopPropagation();
                window.ardalosOpenFormateur(formateur.id);
              };
            }
          }
        });
      });
      observer2.observe(formateursGrid, { childList: true, subtree: true });
    }
  }

  function init() {
    loadFormations();
    attachButtons();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


<!-- === CONNEXION SUPABASE ENTREPRISES + TACHES + FUNDING + DOCUMENTS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtEuro(n) {
    if (!n || n === 0) return '—';
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function fmtDate(s) {
    if (!s) return '—';
    return new Date(s).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function fmtDateRel(s) {
    if (!s) return '—';
    var d = new Date(s);
    var now = new Date();
    var diff = Math.floor((now - d) / 86400000);
    if (diff === 0) return 'Aujourd\'hui';
    if (diff === 1) return 'Hier';
    if (diff < 7) return 'Il y a ' + diff + 'j';
    if (diff < 30) return 'Il y a ' + Math.floor(diff / 7) + 'sem';
    return fmtDate(s);
  }

  function getInitials(nom) {
    if (!nom) return '??';
    var parts = nom.trim().split(/\s+/);
    if (parts.length >= 2) return (parts[0][0] + parts[1][0]).toUpperCase();
    return (parts[0][0] + (parts[0][1] || '')).toUpperCase();
  }

  // ==============================================================
  // 1) ENTREPRISES : agreger depuis formation_inscriptions par raison_sociale_client
  // ==============================================================
  async function loadEntreprises() {
    try {
      var subtitleEl = document.getElementById('entreprises-subtitle');
      var tbodyEl = document.getElementById('entreprises-tbody');
      if (!tbodyEl) return;

      var r = await sb.from('formation_inscriptions')
        .select('raison_sociale_client, siret_client, montant_total_ht, statut, contact_id');
      if (r.error) throw r.error;
      var inscriptions = r.data || [];

      // Grouper par raison sociale non vide
      var entreprisesByName = {};
      inscriptions.forEach(function(i) {
        if (!i.raison_sociale_client || !i.raison_sociale_client.trim()) return;
        var key = i.raison_sociale_client.trim();
        if (!entreprisesByName[key]) {
          entreprisesByName[key] = { nom: key, siret: i.siret_client, ca: 0, deals: 0, contacts: new Set(), abandons: 0 };
        }
        entreprisesByName[key].deals++;
        if (i.statut !== 'abandon') {
          entreprisesByName[key].ca += Number(i.montant_total_ht || 0);
        } else {
          entreprisesByName[key].abandons++;
        }
        if (i.contact_id) entreprisesByName[key].contacts.add(i.contact_id);
      });

      var entreprises = Object.values(entreprisesByName);
      entreprises.sort(function(a, b) { return b.ca - a.ca; });

      if (subtitleEl) {
        subtitleEl.textContent = entreprises.length + ' entreprise' + (entreprises.length > 1 ? 's' : '') + ' · Clients & partenaires';
      }

      if (entreprises.length === 0) {
        tbodyEl.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Aucune entreprise cliente pour le moment</td></tr>';
      } else {
        var rows = entreprises.map(function(e) {
          var statut = e.ca > 0 ? '<span class="badge b-green">Client actif</span>' : '<span class="badge b-amber">Prospect</span>';
          return '<tr>' +
            '<td class="name-cell">' + escapeHtml(e.nom) + '</td>' +
            '<td class="text-xs text-muted">' + escapeHtml(e.siret || '—') + '</td>' +
            '<td>' + e.contacts.size + '</td>' +
            '<td>' + e.deals + '</td>' +
            '<td class="font-sb text-blue">' + fmtEuro(e.ca) + '</td>' +
            '<td>' + statut + '</td>' +
            '<td><button class="btn-s" style="font-size:11px;padding:3px 8px">Voir</button></td>' +
          '</tr>';
        });
        tbodyEl.innerHTML = rows.join('');
      }

      console.log('[Ardalos Entreprises] OK :', entreprises.length);
    } catch (e) {
      console.error('[Ardalos Entreprises]', e);
      var tbodyEl = document.getElementById('entreprises-tbody');
      if (tbodyEl) tbodyEl.innerHTML = '<tr><td colspan="7" style="padding:20px;color:#dc2626">Erreur: ' + escapeHtml(e.message) + '</td></tr>';
    }
  }

  // ==============================================================
  // 2) TACHES : table taches avec checkbox pour marquer done
  // ==============================================================
  async function loadTasks() {
    try {
      var subtitleEl = document.getElementById('tasks-subtitle');
      var listEl = document.getElementById('tasks-list');
      var urgentEl = document.getElementById('tasks-urgent-count');
      if (!listEl) return;

      var r = await sb.from('taches').select('*').order('date_echeance', { ascending: true, nullsFirst: false });
      if (r.error) throw r.error;
      var taches = r.data || [];
      var actives = taches.filter(function(t) { return !t.done; });

      // Compter urgentes (echeance dans les 7j ou depasse)
      var now = new Date();
      var dans7j = new Date(now.getTime() + 7 * 86400000);
      var urgentes = actives.filter(function(t) {
        if (!t.date_echeance) return false;
        var d = new Date(t.date_echeance);
        return d <= dans7j;
      });

      if (subtitleEl) {
        subtitleEl.textContent = actives.length + ' tache' + (actives.length > 1 ? 's' : '') + ' active' + (actives.length > 1 ? 's' : '') + ' · ' + urgentes.length + ' urgente' + (urgentes.length > 1 ? 's' : '');
      }
      if (urgentEl) {
        urgentEl.textContent = urgentes.length + ' urgente' + (urgentes.length > 1 ? 's' : '');
      }

      if (actives.length === 0) {
        listEl.innerHTML = '<div style="padding:30px;text-align:center;color:#9ca3af;font-style:italic">Aucune tache active</div>';
      } else {
        var rows = actives.map(function(t) {
          var prio = (t.priorite || '').toLowerCase();
          var badgeLabel = 'A faire';
          var badgeCls = 'b-gray';
          var containerStyle = 'border:1px solid var(--g200)';
          if (t.date_echeance) {
            var d = new Date(t.date_echeance);
            var diffDays = Math.floor((d - now) / 86400000);
            if (diffDays < 0) {
              badgeLabel = 'Retard ' + Math.abs(diffDays) + 'j';
              badgeCls = 'b-red';
              containerStyle = 'background:var(--red-bg);border:1px solid var(--red-bdr)';
            } else if (diffDays === 0) {
              badgeLabel = "Aujourd'hui";
              badgeCls = 'b-amber';
              containerStyle = 'background:var(--amber-bg);border:1px solid var(--amber-bdr)';
            } else if (diffDays === 1) {
              badgeLabel = 'Demain';
              badgeCls = 'b-amber';
            } else if (diffDays <= 7) {
              badgeLabel = 'J+' + diffDays;
              badgeCls = 'b-navy';
            } else {
              badgeLabel = fmtDate(t.date_echeance);
            }
          }
          if (prio === 'haute' || prio === 'prioritaire' || prio === 'urgent') {
            badgeCls = 'b-red';
          }

          return '<div style="display:flex;align-items:flex-start;gap:9px;padding:9px;border-radius:var(--r8);' + containerStyle + ';margin-bottom:6px">' +
            '<input type="checkbox" style="margin-top:2px" data-task-id="' + escapeHtml(t.id) + '" class="task-cb">' +
            '<div class="flex-1">' +
              '<div class="font-sb" style="font-size:13px">' + escapeHtml(t.titre || 'Sans titre') + '</div>' +
              (t.contact ? '<div class="text-xs text-muted mt-1">Contact : ' + escapeHtml(t.contact) + '</div>' : '') +
            '</div>' +
            '<span class="badge ' + badgeCls + '">' + escapeHtml(badgeLabel) + '</span>' +
          '</div>';
        });
        listEl.innerHTML = rows.join('');

        // Brancher les checkboxes
        var cbs = listEl.querySelectorAll('.task-cb');
        cbs.forEach(function(cb) {
          cb.addEventListener('change', async function() {
            var id = cb.dataset.taskId;
            cb.disabled = true;
            try {
              var upd = await sb.from('taches').update({ done: cb.checked }).eq('id', id);
              if (upd.error) throw upd.error;
              // Recharger
              loadTasks();
            } catch (e) {
              alert('Erreur : ' + e.message);
              cb.checked = !cb.checked;
              cb.disabled = false;
            }
          });
        });
      }

      console.log('[Ardalos Tasks] OK :', actives.length, 'actives,', urgentes.length, 'urgentes');
    } catch (e) {
      console.error('[Ardalos Tasks]', e);
      var listEl = document.getElementById('tasks-list');
      if (listEl) listEl.innerHTML = '<div style="padding:20px;color:#dc2626">Erreur: ' + escapeHtml(e.message) + '</div>';
    }
  }

  // ==============================================================
  // 3) FUNDING : Dossiers de financement
  // ==============================================================
  async function loadFunding() {
    try {
      var subtitleEl = document.getElementById('funding-subtitle');
      var tbodyEl = document.getElementById('funding-tbody');
      var pageEl = document.getElementById('funding-pagination');
      if (!tbodyEl) return;

      // Financements + inscriptions jointes
      var fR = await sb.from('formation_financements').select('*').order('created_at', { ascending: false });
      if (fR.error) throw fR.error;
      var financements = fR.data || [];

      // Inscriptions pour avoir les contacts
      var insIds = [...new Set(financements.map(function(f) { return f.inscription_id; }).filter(Boolean))];
      var inscriptions = [];
      if (insIds.length > 0) {
        var iR = await sb.from('formation_inscriptions')
          .select('id, contacts(prenom, nom), commercial_responsable')
          .in('id', insIds);
        inscriptions = iR.data || [];
      }
      var insById = {};
      inscriptions.forEach(function(i) { insById[i.id] = i; });

      // Urgences = statut != accorde et dossier recent
      var actives = financements.filter(function(f) {
        return (f.statut_dossier || '').toLowerCase() !== 'accorde' &&
               (f.statut_dossier || '').toLowerCase() !== 'refuse';
      });

      if (subtitleEl) {
        subtitleEl.textContent = actives.length + ' dossier' + (actives.length > 1 ? 's' : '') + ' actif' + (actives.length > 1 ? 's' : '') + ' · AFDAS / OPCO / CPF';
      }

      if (financements.length === 0) {
        tbodyEl.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Aucun dossier de financement</td></tr>';
      } else {
        var rows = financements.map(function(f, idx) {
          var ins = insById[f.inscription_id] || {};
          var contact = ins.contacts || {};
          var nom = ((contact.prenom || '') + ' ' + (contact.nom || '')).trim() || '—';
          var initials = getInitials(nom);
          var ref = 'DOSS-' + (new Date(f.created_at || Date.now()).getFullYear()) + '-' + String(idx + 1).padStart(4, '0');

          var typeBadge = '<span class="badge b-navy">' + escapeHtml(f.type_financement || '—') + '</span>';
          var statut = (f.statut_dossier || 'En cours').toLowerCase();
          var statutCls = 'b-amber';
          var statutLabel = f.statut_dossier || 'En cours';
          if (statut.indexOf('accorde') !== -1) { statutCls = 'b-green'; statutLabel = 'Accorde'; }
          else if (statut.indexOf('refuse') !== -1) { statutCls = 'b-red'; statutLabel = 'Refuse'; }
          else if (statut.indexOf('instruction') !== -1) { statutCls = 'b-navy'; }
          else if (statut.indexOf('depose') !== -1) { statutCls = 'b-teal'; }

          return '<tr>' +
            '<td class="name-cell text-blue">' + ref + '</td>' +
            '<td><div class="flex items-c gap-2"><div class="av">' + initials + '</div><div><div style="font-size:12px;font-weight:500">' + escapeHtml(nom) + '</div></div></div></td>' +
            '<td>' + typeBadge + '</td>' +
            '<td><span class="badge ' + statutCls + '">' + escapeHtml(statutLabel) + '</span></td>' +
            '<td class="font-sb text-blue">' + fmtEuro(Number(f.montant_ht || 0)) + '</td>' +
            '<td class="text-xs text-muted">' + (f.piece_manquante ? escapeHtml(f.piece_manquante) : '—') + '</td>' +
            '<td class="text-xs text-muted">' + (f.date_depot ? fmtDate(f.date_depot) : '—') + '</td>' +
            '<td class="text-xs text-muted">' + (f.date_decision ? fmtDate(f.date_decision) : '—') + '</td>' +
            '<td class="text-xs">' + escapeHtml(ins.commercial_responsable || '—') + '</td>' +
            '<td><button class="btn-s" style="font-size:11px;padding:3px 8px">Ouvrir</button></td>' +
          '</tr>';
        });
        tbodyEl.innerHTML = rows.join('');
      }

      if (pageEl) pageEl.textContent = financements.length > 0 ? '1–' + financements.length + ' sur ' + financements.length : '0 dossier';

      console.log('[Ardalos Funding] OK :', financements.length);
    } catch (e) {
      console.error('[Ardalos Funding]', e);
      var tbodyEl = document.getElementById('funding-tbody');
      if (tbodyEl) tbodyEl.innerHTML = '<tr><td colspan="10" style="padding:20px;color:#dc2626">Erreur: ' + escapeHtml(e.message) + '</td></tr>';
    }
  }

  // ==============================================================
  // 4) DOCUMENTS : historique email_logs (sert de preuve des generations)
  // ==============================================================
  async function loadDocsHistory() {
    try {
      var subtitleEl = document.getElementById('docs-subtitle');
      var historyBody = document.getElementById('docs-history-body');
      var historyCount = document.getElementById('docs-history-count');
      if (!historyBody) return;

      var r = await sb.from('email_logs').select('*').order('created_at', { ascending: false }).limit(20);
      if (r.error) throw r.error;
      var logs = r.data || [];

      // Compter total generations
      var rCount = await sb.from('email_logs').select('id', { count: 'exact', head: true });
      var total = rCount.count || logs.length;

      if (subtitleEl) {
        subtitleEl.textContent = '10 modeles · ' + total + ' generation' + (total > 1 ? 's' : '') + ' · PDF / DOCX';
      }
      if (historyCount) {
        historyCount.textContent = '20 dernieres sur ' + total;
      }

      if (logs.length === 0) {
        historyBody.innerHTML = '<div style="padding:20px;text-align:center;color:#9ca3af;font-style:italic">Aucune generation enregistree</div>';
      } else {
        var rows = logs.map(function(l) {
          var succCls = l.success ? 'b-green' : 'b-red';
          var succLabel = l.success ? 'Envoye' : 'Echec';
          var fmt = l.format ? '<span class="badge b-navy" style="font-size:10px;margin-left:4px">' + escapeHtml(l.format.toUpperCase()) + '</span>' : '';
          return '<div style="padding:8px 10px;border-bottom:1px solid #f1f5f9;font-size:12px">' +
            '<div class="flex items-c justify-b">' +
              '<div><span class="font-sb">' + escapeHtml(l.filename || 'Sans nom') + '</span>' + fmt + '</div>' +
              '<span class="badge ' + succCls + '" style="font-size:10px">' + succLabel + '</span>' +
            '</div>' +
            '<div class="text-xs text-muted" style="margin-top:3px">Vers ' + escapeHtml(l.destinataire || '—') + ' · ' + fmtDateRel(l.created_at) + (l.envoye_par ? ' · ' + escapeHtml(l.envoye_par) : '') + '</div>' +
          '</div>';
        });
        historyBody.innerHTML = rows.join('');
      }

      console.log('[Ardalos Docs] OK :', logs.length, 'sur', total);
    } catch (e) {
      console.error('[Ardalos Docs]', e);
      var historyBody = document.getElementById('docs-history-body');
      if (historyBody) historyBody.innerHTML = '<div style="padding:20px;color:#dc2626">Erreur: ' + escapeHtml(e.message) + '</div>';
    }
  }

  function init() {
    loadEntreprises();
    loadTasks();
    loadFunding();
    loadDocsHistory();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


<!-- === FONCTIONS BOUTONS (Nouvelle tache + Ouvrir dossier + Voir entreprise) === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtEuro(n) {
    if (!n || n === 0) return '—';
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function fmtDate(s) {
    if (!s) return '—';
    return new Date(s).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
  }

  // ======================================================================
  // NOUVELLE TACHE : ouvrir modale + save
  // ======================================================================
  window.ardalosNewTache = function() {
    document.getElementById('new-tache-titre').value = '';
    document.getElementById('new-tache-contact').value = '';
    document.getElementById('new-tache-date').value = '';
    document.getElementById('new-tache-priorite').value = 'normale';
    document.getElementById('new-tache-error').style.display = 'none';
    if (typeof openModal === 'function') openModal('new-tache');
  };

  window.ardalosSaveTache = async function() {
    var errEl = document.getElementById('new-tache-error');
    var btnEl = document.getElementById('new-tache-save');
    errEl.style.display = 'none';

    var titre = document.getElementById('new-tache-titre').value.trim();
    if (!titre) {
      errEl.textContent = 'Le titre est obligatoire';
      errEl.style.display = 'block';
      return;
    }

    var payload = {
      titre: titre,
      contact: document.getElementById('new-tache-contact').value.trim() || null,
      date_echeance: document.getElementById('new-tache-date').value || null,
      priorite: document.getElementById('new-tache-priorite').value,
      done: false,
    };

    btnEl.disabled = true;
    btnEl.textContent = 'Creation...';
    try {
      var r = await sb.from('taches').insert(payload);
      if (r.error) throw r.error;
      if (typeof closeModal === 'function') closeModal('new-tache');
      // Recharger la liste des taches en relancant le loader
      // On trigger un reload en re-appelant l'init (simplement recharger la page si pas de fonction exposee)
      if (window.ardalosReloadTasks) {
        window.ardalosReloadTasks();
      } else {
        location.reload();
      }
    } catch (e) {
      errEl.textContent = 'Erreur : ' + (e.message || 'inconnue');
      errEl.style.display = 'block';
      btnEl.disabled = false;
      btnEl.textContent = 'Creer la tache';
    }
  };

  // ======================================================================
  // OUVRIR DOSSIER FINANCEMENT : utilise la modale universelle #modal-detail
  // ======================================================================
  window.ardalosOpenFinancement = async function(financementId) {
    try {
      var titleEl = document.getElementById('detail-modal-title');
      var bodyEl = document.getElementById('detail-modal-body');
      if (!titleEl || !bodyEl) { alert('Modale detail introuvable'); return; }

      bodyEl.innerHTML = '<div style="padding:20px;text-align:center;color:#9ca3af">Chargement...</div>';
      if (typeof openModal === 'function') openModal('detail');

      var fR = await sb.from('formation_financements').select('*').eq('id', financementId).single();
      if (fR.error) throw fR.error;
      var fin = fR.data;

      var contact = null;
      var insData = null;
      if (fin.inscription_id) {
        var iR = await sb.from('formation_inscriptions')
          .select('id, contacts(prenom, nom, email, telephone), commercial_responsable, montant_total_ht, formation_sessions(date_debut, date_fin, formations(titre))')
          .eq('id', fin.inscription_id).single();
        if (!iR.error && iR.data) {
          insData = iR.data;
          contact = iR.data.contacts;
        }
      }

      var nom = contact ? ((contact.prenom || '') + ' ' + (contact.nom || '')).trim() : '(Dossier sans contact)';
      titleEl.textContent = 'Dossier ' + (fin.type_financement || 'Financement') + ' — ' + nom;

      var formation = insData && insData.formation_sessions && insData.formation_sessions.formations
        ? insData.formation_sessions.formations.titre
        : null;

      var statutCls = 'b-amber';
      var statut = (fin.statut_dossier || 'En cours').toLowerCase();
      if (statut.indexOf('accorde') !== -1) statutCls = 'b-green';
      else if (statut.indexOf('refuse') !== -1) statutCls = 'b-red';
      else if (statut.indexOf('instruction') !== -1) statutCls = 'b-navy';
      else if (statut.indexOf('depose') !== -1) statutCls = 'b-teal';

      bodyEl.innerHTML =
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">' +
          '<div class="si"><span class="si-l">Type</span><span class="si-r"><span class="badge b-navy">' + escapeHtml(fin.type_financement || '—') + '</span></span></div>' +
          '<div class="si"><span class="si-l">Statut</span><span class="si-r"><span class="badge ' + statutCls + '">' + escapeHtml(fin.statut_dossier || 'En cours') + '</span></span></div>' +
          '<div class="si"><span class="si-l">Montant HT</span><span class="si-r font-sb text-blue">' + fmtEuro(Number(fin.montant_ht || 0)) + '</span></div>' +
          (fin.montant_accorde ? '<div class="si"><span class="si-l">Montant accorde</span><span class="si-r font-sb text-green">' + fmtEuro(Number(fin.montant_accorde)) + '</span></div>' : '') +
          (fin.ref_dossier ? '<div class="si"><span class="si-l">Ref dossier</span><span class="si-r">' + escapeHtml(fin.ref_dossier) + '</span></div>' : '') +
          (fin.date_depot ? '<div class="si"><span class="si-l">Date depot</span><span class="si-r">' + fmtDate(fin.date_depot) + '</span></div>' : '') +
          (fin.date_decision ? '<div class="si"><span class="si-l">Date decision</span><span class="si-r">' + fmtDate(fin.date_decision) + '</span></div>' : '') +
          (insData && insData.commercial_responsable ? '<div class="si"><span class="si-l">Commercial</span><span class="si-r">' + escapeHtml(insData.commercial_responsable) + '</span></div>' : '') +
        '</div>' +
        (contact ? '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="font-sb" style="font-size:13px;color:var(--ard-dark);margin-bottom:8px">Contact</div>' +
          '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:12px">' +
            '<div><span class="text-xs text-muted">Email</span><br>' + escapeHtml(contact.email || '—') + '</div>' +
            '<div><span class="text-xs text-muted">Telephone</span><br>' + escapeHtml(contact.telephone || '—') + '</div>' +
          '</div>' +
        '</div>' : '') +
        (formation ? '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="font-sb" style="font-size:13px;color:var(--ard-dark);margin-bottom:8px">Formation</div>' +
          '<div style="font-size:12px">' + escapeHtml(formation) + '</div>' +
        '</div>' : '') +
        (fin.piece_manquante ? '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="font-sb" style="font-size:13px;color:var(--ard-dark);margin-bottom:8px">Pieces manquantes</div>' +
          '<div style="font-size:12px;white-space:pre-wrap">' + escapeHtml(fin.piece_manquante) + '</div>' +
        '</div>' : '') +
        (fin.notes ? '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="font-sb" style="font-size:13px;color:var(--ard-dark);margin-bottom:8px">Notes</div>' +
          '<div style="font-size:12px;white-space:pre-wrap">' + escapeHtml(fin.notes) + '</div>' +
        '</div>' : '');

    } catch (e) {
      console.error(e);
      alert('Erreur : ' + (e.message || 'inconnue'));
    }
  };

  // ======================================================================
  // VOIR ENTREPRISE : modale detail depuis raison_sociale_client
  // ======================================================================
  window.ardalosOpenEntreprise = async function(raisonSociale) {
    try {
      var titleEl = document.getElementById('detail-modal-title');
      var bodyEl = document.getElementById('detail-modal-body');
      if (!titleEl || !bodyEl) return;

      titleEl.textContent = raisonSociale;
      bodyEl.innerHTML = '<div style="padding:20px;text-align:center;color:#9ca3af">Chargement...</div>';
      if (typeof openModal === 'function') openModal('detail');

      var r = await sb.from('formation_inscriptions')
        .select('id, montant_total_ht, statut, commercial_responsable, siret_client, adresse_client, contacts(prenom, nom, email), formation_sessions(date_debut, formations(titre))')
        .eq('raison_sociale_client', raisonSociale)
        .order('created_at', { ascending: false });
      if (r.error) throw r.error;
      var inscriptions = r.data || [];

      var totalCA = 0;
      var contacts = new Set();
      var siret = null;
      var adresse = null;
      inscriptions.forEach(function(i) {
        if (i.statut !== 'abandon') totalCA += Number(i.montant_total_ht || 0);
        if (i.contacts) contacts.add(i.contacts.prenom + ' ' + i.contacts.nom);
        if (i.siret_client && !siret) siret = i.siret_client;
        if (i.adresse_client && !adresse) adresse = i.adresse_client;
      });

      var insRows = inscriptions.map(function(i) {
        var f = i.formation_sessions && i.formation_sessions.formations ? i.formation_sessions.formations.titre : '—';
        var nomContact = i.contacts ? ((i.contacts.prenom || '') + ' ' + (i.contacts.nom || '')).trim() : '—';
        var statutCls = i.statut === 'confirme' || i.statut === 'present' ? 'b-green' :
                        i.statut === 'abandon' ? 'b-red' : 'b-amber';
        return '<tr>' +
          '<td style="font-size:12px">' + escapeHtml(nomContact) + '</td>' +
          '<td style="font-size:12px">' + escapeHtml(f) + '</td>' +
          '<td style="font-size:12px;text-align:right">' + fmtEuro(Number(i.montant_total_ht || 0)) + '</td>' +
          '<td><span class="badge ' + statutCls + '" style="font-size:10px">' + escapeHtml(i.statut || '—') + '</span></td>' +
        '</tr>';
      }).join('');

      bodyEl.innerHTML =
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">' +
          (siret ? '<div class="si"><span class="si-l">SIRET</span><span class="si-r">' + escapeHtml(siret) + '</span></div>' : '') +
          '<div class="si"><span class="si-l">Contacts</span><span class="si-r">' + contacts.size + '</span></div>' +
          '<div class="si"><span class="si-l">Inscriptions</span><span class="si-r">' + inscriptions.length + '</span></div>' +
          '<div class="si"><span class="si-l">CA total HT</span><span class="si-r font-sb text-blue">' + fmtEuro(totalCA) + '</span></div>' +
        '</div>' +
        (adresse ? '<div style="margin-bottom:14px"><span class="text-xs text-muted">Adresse</span><br><span style="font-size:12px">' + escapeHtml(adresse) + '</span></div>' : '') +
        (inscriptions.length > 0 ? '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="font-sb" style="font-size:13px;margin-bottom:10px">Inscriptions (' + inscriptions.length + ')</div>' +
          '<table class="dt" style="font-size:12px">' +
            '<thead><tr><th>Stagiaire</th><th>Formation</th><th style="text-align:right">Montant</th><th>Statut</th></tr></thead>' +
            '<tbody>' + insRows + '</tbody>' +
          '</table>' +
        '</div>' : '');

    } catch (e) {
      console.error(e);
      alert('Erreur : ' + (e.message || 'inconnue'));
    }
  };

  // ======================================================================
  // Brancher automatiquement les boutons "Ouvrir" Dossiers et "Voir" Entreprises
  // ======================================================================
  function attachDossierButtons() {
    var tbody = document.getElementById('funding-tbody');
    if (!tbody) return;
    var observer = new MutationObserver(function() {
      var rows = tbody.querySelectorAll('tr');
      rows.forEach(function(row, idx) {
        var btn = row.querySelector('button');
        if (!btn || btn._ardalosHooked) return;
        // Chercher l'id dans le cache (on ne l'a pas en attribut, on le recalcule avec l'index)
        // Plus simple : on relance une requete pour recuperer l'id au click
        btn._ardalosHooked = true;
        btn.onclick = async function(e) {
          e.stopPropagation();
          // On utilise la reference texte pour retrouver
          var refCell = row.querySelector('.name-cell');
          if (!refCell) return;
          // Recuperer le financement par ordre (tri par created_at desc)
          var r = await sb.from('formation_financements').select('id').order('created_at', { ascending: false });
          var fins = r.data || [];
          if (fins[idx]) {
            window.ardalosOpenFinancement(fins[idx].id);
          }
        };
      });
    });
    observer.observe(tbody, { childList: true, subtree: true });
  }

  function attachEntrepriseButtons() {
    var tbody = document.getElementById('entreprises-tbody');
    if (!tbody) return;
    var observer = new MutationObserver(function() {
      var rows = tbody.querySelectorAll('tr');
      rows.forEach(function(row) {
        var btn = row.querySelector('button');
        if (!btn || btn._ardalosHooked) return;
        var nameCell = row.querySelector('.name-cell');
        if (!nameCell) return;
        btn._ardalosHooked = true;
        var raison = nameCell.textContent.trim();
        btn.onclick = function(e) {
          e.stopPropagation();
          window.ardalosOpenEntreprise(raison);
        };
      });
    });
    observer.observe(tbody, { childList: true, subtree: true });
  }

  function init() {
    attachDossierButtons();
    attachEntrepriseButtons();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


<!-- === ENTREPRISES v2 (vraie table + modale nouvelle) === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtEuro(n) {
    if (!n || n === 0) return '—';
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function fmtDate(s) {
    if (!s) return '—';
    return new Date(s).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
  }

  // =====================================================================
  // FUSION entreprises + raison_sociale_client depuis inscriptions
  // =====================================================================
  async function loadEntreprisesV2() {
    try {
      var subtitleEl = document.getElementById('entreprises-subtitle');
      var tbodyEl = document.getElementById('entreprises-tbody');
      if (!tbodyEl) return;

      // Table entreprises
      var eR = await sb.from('entreprises').select('*').order('nom', { ascending: true });
      if (eR.error) throw eR.error;
      var entreprises = eR.data || [];

      // Inscriptions pour calculer CA et deals
      var iR = await sb.from('formation_inscriptions')
        .select('raison_sociale_client, siret_client, montant_total_ht, statut, contact_id');
      if (iR.error) throw iR.error;
      var inscriptions = iR.data || [];

      // Agregats par nom (normalise en lowercase trim)
      var aggByName = {};
      inscriptions.forEach(function(i) {
        if (!i.raison_sociale_client || !i.raison_sociale_client.trim()) return;
        var key = i.raison_sociale_client.trim().toLowerCase();
        if (!aggByName[key]) aggByName[key] = { ca: 0, deals: 0, contacts: new Set(), original: i.raison_sociale_client.trim() };
        aggByName[key].deals++;
        if (i.statut !== 'abandon') aggByName[key].ca += Number(i.montant_total_ht || 0);
        if (i.contact_id) aggByName[key].contacts.add(i.contact_id);
      });

      // Fusionner : pour chaque entreprise de la table, chercher son agregat
      var entreprisesById = {};
      entreprises.forEach(function(e) {
        var key = (e.nom || '').trim().toLowerCase();
        var agg = aggByName[key];
        entreprisesById[e.id] = {
          id: e.id,
          source: 'table',
          nom: e.nom,
          siret: e.siret,
          secteur: e.secteur,
          adresse: e.adresse,
          contact_principal: e.contact_principal,
          email: e.email,
          telephone: e.telephone,
          notes: e.notes,
          ca: agg ? agg.ca : 0,
          deals: agg ? agg.deals : 0,
          contacts_count: agg ? agg.contacts.size : 0,
        };
        if (agg) delete aggByName[key]; // Marquer comme matche
      });

      // Ajouter les entreprises "orphelines" (issues uniquement des inscriptions)
      var orphelines = [];
      Object.keys(aggByName).forEach(function(key) {
        var agg = aggByName[key];
        orphelines.push({
          source: 'inscriptions',
          nom: agg.original,
          siret: null,
          ca: agg.ca,
          deals: agg.deals,
          contacts_count: agg.contacts.size,
        });
      });

      var all = Object.values(entreprisesById).concat(orphelines);
      all.sort(function(a, b) { return b.ca - a.ca; });

      if (subtitleEl) {
        subtitleEl.textContent = all.length + ' entreprise' + (all.length > 1 ? 's' : '') + ' · Clients & partenaires';
      }

      if (all.length === 0) {
        tbodyEl.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Aucune entreprise · Clique sur "+ Nouvelle entreprise" pour commencer</td></tr>';
      } else {
        var rows = all.map(function(e) {
          var statut = e.deals > 0
            ? '<span class="badge b-green">Client actif</span>'
            : '<span class="badge b-gray">Prospect</span>';
          var nomData = 'data-entreprise-id="' + escapeHtml(e.id || '') + '" data-entreprise-nom="' + escapeHtml(e.nom) + '"';
          return '<tr>' +
            '<td class="name-cell">' + escapeHtml(e.nom) + (e.source === 'inscriptions' ? ' <span class="text-xs text-muted">(via inscription)</span>' : '') + '</td>' +
            '<td>' + escapeHtml(e.secteur || '—') + '</td>' +
            '<td>' + e.contacts_count + '</td>' +
            '<td>' + e.deals + '</td>' +
            '<td class="font-sb text-blue">' + fmtEuro(e.ca) + '</td>' +
            '<td>' + statut + '</td>' +
            '<td><button class="btn-s" style="font-size:11px;padding:3px 8px" ' + nomData + '>Voir</button></td>' +
          '</tr>';
        });
        tbodyEl.innerHTML = rows.join('');

        // Brancher les boutons Voir
        var buttons = tbodyEl.querySelectorAll('button[data-entreprise-nom]');
        buttons.forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var id = btn.dataset.entrepriseId;
            var nom = btn.dataset.entrepriseNom;
            if (id) window.ardalosOpenEntrepriseV2(id, nom);
            else window.ardalosOpenEntreprise(nom); // fallback vers ancienne fonction
          });
        });
      }

      console.log('[Ardalos Entreprises V2] OK :', all.length, '(' + entreprises.length + ' en table, ' + orphelines.length + ' via inscriptions)');
    } catch (e) {
      console.error('[Ardalos Entreprises V2]', e);
      var tbodyEl = document.getElementById('entreprises-tbody');
      if (tbodyEl) tbodyEl.innerHTML = '<tr><td colspan="7" style="padding:20px;color:#dc2626">Erreur: ' + escapeHtml(e.message) + '</td></tr>';
    }
  }

  // =====================================================================
  // Modale nouvelle entreprise : ouvrir + save
  // =====================================================================
  window.ardalosNewEntreprise = function() {
    document.getElementById('new-ent-nom').value = '';
    document.getElementById('new-ent-siret').value = '';
    document.getElementById('new-ent-secteur').value = '';
    document.getElementById('new-ent-adresse').value = '';
    document.getElementById('new-ent-contact').value = '';
    document.getElementById('new-ent-email').value = '';
    document.getElementById('new-ent-telephone').value = '';
    document.getElementById('new-ent-notes').value = '';
    document.getElementById('new-ent-error').style.display = 'none';
    if (typeof openModal === 'function') openModal('new-entreprise');
  };

  window.ardalosSaveEntreprise = async function() {
    var errEl = document.getElementById('new-ent-error');
    var btnEl = document.getElementById('new-ent-save');
    errEl.style.display = 'none';

    var nom = document.getElementById('new-ent-nom').value.trim();
    if (!nom) {
      errEl.textContent = 'Le nom de l\'entreprise est obligatoire';
      errEl.style.display = 'block';
      return;
    }

    var payload = {
      nom: nom,
      siret: document.getElementById('new-ent-siret').value.trim() || null,
      secteur: document.getElementById('new-ent-secteur').value || null,
      adresse: document.getElementById('new-ent-adresse').value.trim() || null,
      contact_principal: document.getElementById('new-ent-contact').value.trim() || null,
      email: document.getElementById('new-ent-email').value.trim() || null,
      telephone: document.getElementById('new-ent-telephone').value.trim() || null,
      notes: document.getElementById('new-ent-notes').value.trim() || null,
    };

    btnEl.disabled = true;
    btnEl.textContent = 'Creation...';
    try {
      var r = await sb.from('entreprises').insert(payload);
      if (r.error) throw r.error;
      if (typeof closeModal === 'function') closeModal('new-entreprise');
      loadEntreprisesV2();
    } catch (e) {
      errEl.textContent = 'Erreur : ' + (e.message || 'inconnue');
      errEl.style.display = 'block';
      btnEl.disabled = false;
      btnEl.textContent = 'Creer l\'entreprise';
    }
  };

  // =====================================================================
  // Modale detail entreprise V2 (par id depuis table)
  // =====================================================================
  window.ardalosOpenEntrepriseV2 = async function(entrepriseId, nomFallback) {
    try {
      var titleEl = document.getElementById('detail-modal-title');
      var bodyEl = document.getElementById('detail-modal-body');
      if (!titleEl || !bodyEl) return;

      bodyEl.innerHTML = '<div style="padding:20px;text-align:center;color:#9ca3af">Chargement...</div>';
      if (typeof openModal === 'function') openModal('detail');

      var entreprise = null;
      if (entrepriseId) {
        var eR = await sb.from('entreprises').select('*').eq('id', entrepriseId).single();
        if (!eR.error) entreprise = eR.data;
      }
      var nom = entreprise ? entreprise.nom : nomFallback;
      titleEl.textContent = nom;

      // Inscriptions matchantes
      var iR = await sb.from('formation_inscriptions')
        .select('id, montant_total_ht, statut, commercial_responsable, contacts(prenom, nom, email), formation_sessions(date_debut, formations(titre))')
        .eq('raison_sociale_client', nom);
      var inscriptions = (iR.error ? [] : (iR.data || []));

      var totalCA = 0;
      var contacts = new Set();
      inscriptions.forEach(function(i) {
        if (i.statut !== 'abandon') totalCA += Number(i.montant_total_ht || 0);
        if (i.contacts) contacts.add(i.contacts.prenom + ' ' + i.contacts.nom);
      });

      var insRows = inscriptions.map(function(i) {
        var f = i.formation_sessions && i.formation_sessions.formations ? i.formation_sessions.formations.titre : '—';
        var nomContact = i.contacts ? ((i.contacts.prenom || '') + ' ' + (i.contacts.nom || '')).trim() : '—';
        var statutCls = i.statut === 'confirme' || i.statut === 'present' ? 'b-green' :
                        i.statut === 'abandon' ? 'b-red' : 'b-amber';
        return '<tr>' +
          '<td style="font-size:12px">' + escapeHtml(nomContact) + '</td>' +
          '<td style="font-size:12px">' + escapeHtml(f) + '</td>' +
          '<td style="font-size:12px;text-align:right">' + fmtEuro(Number(i.montant_total_ht || 0)) + '</td>' +
          '<td><span class="badge ' + statutCls + '" style="font-size:10px">' + escapeHtml(i.statut || '—') + '</span></td>' +
        '</tr>';
      }).join('');

      var infoHtml = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px">';
      if (entreprise) {
        if (entreprise.siret) infoHtml += '<div class="si"><span class="si-l">SIRET</span><span class="si-r">' + escapeHtml(entreprise.siret) + '</span></div>';
        if (entreprise.secteur) infoHtml += '<div class="si"><span class="si-l">Secteur</span><span class="si-r">' + escapeHtml(entreprise.secteur) + '</span></div>';
        if (entreprise.contact_principal) infoHtml += '<div class="si"><span class="si-l">Contact</span><span class="si-r">' + escapeHtml(entreprise.contact_principal) + '</span></div>';
        if (entreprise.email) infoHtml += '<div class="si"><span class="si-l">Email</span><span class="si-r">' + escapeHtml(entreprise.email) + '</span></div>';
        if (entreprise.telephone) infoHtml += '<div class="si"><span class="si-l">Telephone</span><span class="si-r">' + escapeHtml(entreprise.telephone) + '</span></div>';
      }
      infoHtml += '<div class="si"><span class="si-l">Contacts</span><span class="si-r">' + contacts.size + '</span></div>';
      infoHtml += '<div class="si"><span class="si-l">Inscriptions</span><span class="si-r">' + inscriptions.length + '</span></div>';
      infoHtml += '<div class="si"><span class="si-l">CA total HT</span><span class="si-r font-sb text-blue">' + fmtEuro(totalCA) + '</span></div>';
      infoHtml += '</div>';

      if (entreprise && entreprise.adresse) {
        infoHtml += '<div style="margin-bottom:14px"><span class="text-xs text-muted">Adresse</span><br><span style="font-size:12px">' + escapeHtml(entreprise.adresse) + '</span></div>';
      }
      if (entreprise && entreprise.notes) {
        infoHtml += '<div style="margin-bottom:14px"><span class="text-xs text-muted">Notes</span><br><span style="font-size:12px;white-space:pre-wrap">' + escapeHtml(entreprise.notes) + '</span></div>';
      }

      if (inscriptions.length > 0) {
        infoHtml += '<div style="margin-top:14px;padding-top:14px;border-top:1px solid #e5e7eb">' +
          '<div class="font-sb" style="font-size:13px;margin-bottom:10px">Inscriptions (' + inscriptions.length + ')</div>' +
          '<table class="dt" style="font-size:12px">' +
            '<thead><tr><th>Stagiaire</th><th>Formation</th><th style="text-align:right">Montant</th><th>Statut</th></tr></thead>' +
            '<tbody>' + insRows + '</tbody>' +
          '</table>' +
        '</div>';
      }

      bodyEl.innerHTML = infoHtml;
    } catch (e) {
      console.error(e);
      alert('Erreur : ' + (e.message || 'inconnue'));
    }
  };

  // Demarrage : re-load entreprises avec la nouvelle logique
  function init() {
    loadEntreprisesV2();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


<!-- === CONNEXION SUPABASE MOTEUR AFDAS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtEuro(n) {
    if (!n || n === 0) return '0€';
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function fmtDate(s) {
    if (!s) return '—';
    return new Date(s).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  async function loadAfdas() {
    try {
      // 1) Tous les financements AFDAS
      var fR = await sb.from('formation_financements')
        .select('*')
        .ilike('type_financement', '%afdas%')
        .order('created_at', { ascending: false });
      if (fR.error) throw fR.error;
      var financements = fR.data || [];

      // 2) Inscriptions pour avoir les contacts
      var insIds = [...new Set(financements.map(function(f) { return f.inscription_id; }).filter(Boolean))];
      var inscriptions = [];
      if (insIds.length > 0) {
        var iR = await sb.from('formation_inscriptions')
          .select('id, contact_id, montant_total_ht, statut, date_inscription, contacts(id, prenom, nom, email, telephone, type, categorie_afdas), formation_sessions(date_debut, date_fin, formations(titre, duree))')
          .in('id', insIds);
        if (!iR.error) inscriptions = iR.data || [];
      }
      var insById = {};
      inscriptions.forEach(function(i) { insById[i.id] = i; });

      // 3) Agreger par contact
      var profilsByContactId = {};
      financements.forEach(function(f) {
        var ins = insById[f.inscription_id];
        if (!ins || !ins.contacts) return;
        var cId = ins.contacts.id;
        if (!profilsByContactId[cId]) {
          profilsByContactId[cId] = {
            contact: ins.contacts,
            financements: [],
            totalAccorde: 0,
            totalDemande: 0,
            hasRefuse: false,
            hasInstruction: false,
            hasDepose: false,
            lastInscription: null,
          };
        }
        var p = profilsByContactId[cId];
        p.financements.push({ fin: f, ins: ins });
        p.totalDemande += Number(f.montant_ht || 0);

        var statut = (f.statut_dossier || '').toLowerCase();
        if (statut.indexOf('accorde') !== -1) {
          p.totalAccorde += Number(f.montant_accorde || f.montant_ht || 0);
        }
        if (statut.indexOf('refuse') !== -1) p.hasRefuse = true;
        if (statut.indexOf('instruction') !== -1) p.hasInstruction = true;
        if (statut.indexOf('depose') !== -1) p.hasDepose = true;

        // Dernier inscription pour tri
        if (!p.lastInscription || (ins.date_inscription && ins.date_inscription > p.lastInscription.date_inscription)) {
          p.lastInscription = ins;
        }
      });

      var profils = Object.values(profilsByContactId);

      // 4) Calcul des KPI
      var nbProfils = profils.length;
      var nbRefusesOuInstruction = profils.filter(function(p) { return p.hasRefuse || p.hasInstruction; }).length;
      var nbDeposes = profils.filter(function(p) { return p.hasDepose; }).length;
      var year = new Date().getFullYear();
      var totalAccordeYTD = 0;
      financements.forEach(function(f) {
        if (!f.date_decision) return;
        var d = new Date(f.date_decision);
        if (d.getFullYear() !== year) return;
        if ((f.statut_dossier || '').toLowerCase().indexOf('accorde') === -1) return;
        totalAccordeYTD += Number(f.montant_accorde || f.montant_ht || 0);
      });

      // 5) MAJ des KPI dans le DOM
      var el = function(id) { return document.getElementById(id); };
      if (el('afdas-kpi-profils')) {
        el('afdas-kpi-profils').textContent = nbProfils;
        el('afdas-kpi-profils-sub').textContent = financements.length + ' dossier' + (financements.length > 1 ? 's' : '') + ' total';
      }
      if (el('afdas-kpi-carence')) {
        el('afdas-kpi-carence').textContent = nbRefusesOuInstruction;
        el('afdas-kpi-carence-sub').textContent = 'a surveiller';
      }
      if (el('afdas-kpi-fenetre')) {
        el('afdas-kpi-fenetre').textContent = nbDeposes;
        el('afdas-kpi-fenetre-sub').textContent = 'en attente decision';
      }
      if (el('afdas-kpi-accorde')) {
        el('afdas-kpi-accorde').textContent = fmtEuro(totalAccordeYTD);
        el('afdas-kpi-accorde-sub').textContent = year + ' cumule';
      }

      // 6) Render des cards profils
      var container = el('afdas-cards-container');
      if (!container) return;

      // Ajouter le divider en haut
      var html = '<div class="divider"><div class="divider-label">Profils AFDAS — ' + nbProfils + ' contact' + (nbProfils > 1 ? 's' : '') + '</div><div class="divider-line"></div></div>';

      if (profils.length === 0) {
        html += '<div style="padding:30px;text-align:center;color:#9ca3af;font-style:italic;border:1px dashed #e5e7eb;border-radius:8px">Aucun profil AFDAS pour le moment. Les contacts apparaitront ici des qu\'un financement AFDAS sera cree dans un dossier.</div>';
      } else {
        // Trier par total accorde desc
        profils.sort(function(a, b) { return b.totalAccorde - a.totalAccorde; });

        profils.forEach(function(p) {
          var c = p.contact;
          var nom = ((c.prenom || '') + ' ' + (c.nom || '')).trim() || 'Contact sans nom';
          var type = c.categorie_afdas || c.type || 'Intermittent';

          var cardClass, dotClass, statutBadge, detailHtml;

          if (p.hasRefuse) {
            cardClass = 'afdas-ko';
            dotClass = 'dot-ko';
            statutBadge = '<span class="badge b-red">Dossier refuse</span>';
          } else if (p.totalAccorde > 0) {
            cardClass = 'afdas-ok';
            dotClass = 'dot-ok';
            statutBadge = '<span class="badge b-green">' + fmtEuro(p.totalAccorde) + ' accorde</span>';
          } else if (p.hasDepose || p.hasInstruction) {
            cardClass = 'afdas-warn';
            dotClass = 'dot-warn';
            statutBadge = '<span class="badge b-amber">En cours</span>';
          } else {
            cardClass = 'afdas-warn';
            dotClass = 'dot-warn';
            statutBadge = '<span class="badge b-navy">A suivre</span>';
          }

          // Finance info
          var finBadges = '';
          p.financements.slice(0, 3).forEach(function(item) {
            var f = item.fin;
            var ins = item.ins;
            var fTitre = (ins && ins.formation_sessions && ins.formation_sessions.formations) ? ins.formation_sessions.formations.titre : 'Formation';
            var statutLower = (f.statut_dossier || '').toLowerCase();
            var bCls = 'b-gray';
            if (statutLower.indexOf('accorde') !== -1) bCls = 'b-green';
            else if (statutLower.indexOf('refuse') !== -1) bCls = 'b-red';
            else if (statutLower.indexOf('instruction') !== -1) bCls = 'b-navy';
            else if (statutLower.indexOf('depose') !== -1) bCls = 'b-teal';
            else if (statutLower.indexOf('constitution') !== -1) bCls = 'b-amber';
            finBadges += '<span class="badge ' + bCls + '" style="margin-right:4px;font-size:10px">' + escapeHtml(fTitre) + ' · ' + fmtEuro(Number(f.montant_ht || 0)) + '</span>';
          });
          if (p.financements.length > 3) {
            finBadges += '<span class="text-xs text-muted">+' + (p.financements.length - 3) + ' autre' + (p.financements.length - 3 > 1 ? 's' : '') + '</span>';
          }

          var nbJours = p.financements.length;
          detailHtml = '<div class="afdas-detail">' +
            nbJours + ' dossier' + (nbJours > 1 ? 's' : '') + ' AFDAS · Total demande : ' + fmtEuro(p.totalDemande) +
            (p.totalAccorde > 0 ? ' · <strong style="color:var(--green)">Accorde : ' + fmtEuro(p.totalAccorde) + '</strong>' : '') +
            '<div style="margin-top:6px">' + finBadges + '</div>' +
            '<div style="margin-top:8px;display:flex;justify-content:space-between;align-items:flex-end">' +
              '<div class="text-xs text-muted">' + escapeHtml(c.email || '') + (c.telephone ? ' · ' + escapeHtml(c.telephone) : '') + '</div>' +
              '<button class="btn-s" style="font-size:11px;padding:5px 11px" data-contact-id="' + escapeHtml(c.id) + '" onclick="window.ardalosOpenApprenant && window.ardalosOpenApprenant(this.dataset.contactId)">Voir fiche →</button>' +
            '</div>' +
          '</div>';

          html += '<div class="afdas-card ' + cardClass + '" style="margin-bottom:12px">' +
            '<div class="afdas-hdr">' +
              '<span class="dot ' + dotClass + '"></span>' +
              escapeHtml(nom) + ' — ' + escapeHtml(type) +
              ' <span style="margin-left:auto">' + statutBadge + '</span>' +
            '</div>' +
            detailHtml +
          '</div>';
        });
      }

      container.innerHTML = html;
      console.log('[Ardalos AFDAS] OK : ' + nbProfils + ' profils, ' + financements.length + ' dossiers, ' + fmtEuro(totalAccordeYTD) + ' accorde YTD');
    } catch (e) {
      console.error('[Ardalos AFDAS]', e);
      var container = document.getElementById('afdas-cards-container');
      if (container) container.innerHTML = '<div style="padding:20px;color:#dc2626">Erreur: ' + escapeHtml(e.message) + '</div>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadAfdas);
  } else {
    loadAfdas();
  }
})();
</script>


<!-- === CONNEXION SUPABASE QUALIOPI (32 indicateurs) === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  var allIndicateurs = [];     // Cache des 32 indicateurs
  var currentEditId = null;    // Id de l'indicateur en cours d'edition

  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtDate(s) {
    if (!s) return '—';
    return new Date(s).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function statutInfo(s) {
    switch(s) {
      case 'conforme': return { label: 'Conforme', icon: '✅', cls: 'b-green', color: '#059669' };
      case 'nc_mineure': return { label: 'NC mineure', icon: '⚠️', cls: 'b-amber', color: '#d97706' };
      case 'nc_majeure': return { label: 'NC majeure', icon: '🔴', cls: 'b-red', color: '#dc2626' };
      case 'non_applicable': return { label: 'Non applicable', icon: '➖', cls: 'b-gray', color: '#6b7280' };
      default: return { label: 'Non audite', icon: '🕓', cls: 'b-gray', color: '#9ca3af' };
    }
  }

  async function loadQualiopi() {
    try {
      var r = await sb.from('qualiopi_indicateurs').select('*').order('numero', { ascending: true });
      if (r.error) throw r.error;
      allIndicateurs = r.data || [];

      // Stats
      var total = allIndicateurs.length;
      var nbConformes = 0, nbNC_min = 0, nbNC_maj = 0, nbNonAudite = 0, nbNA = 0;
      allIndicateurs.forEach(function(i) {
        if (i.statut === 'conforme') nbConformes++;
        else if (i.statut === 'nc_mineure') nbNC_min++;
        else if (i.statut === 'nc_majeure') nbNC_maj++;
        else if (i.statut === 'non_applicable') nbNA++;
        else nbNonAudite++;
      });
      var totalAuditable = total - nbNA;
      var score = totalAuditable > 0 ? Math.round((nbConformes / totalAuditable) * 100) : 0;

      // KPI
      var el = function(id) { return document.getElementById(id); };
      if (el('qualiopi-score')) {
        el('qualiopi-score').textContent = score + '%';
        el('qualiopi-score-sub').textContent = nbConformes + '/' + totalAuditable + ' auditables';
      }
      if (el('qualiopi-nb-conformes')) el('qualiopi-nb-conformes').textContent = nbConformes;
      if (el('qualiopi-nb-nc')) {
        el('qualiopi-nb-nc').textContent = (nbNC_min + nbNC_maj);
        el('qualiopi-nb-nc-sub').textContent = nbNC_maj + ' maj. · ' + nbNC_min + ' min.';
      }
      if (el('qualiopi-nb-todo')) el('qualiopi-nb-todo').textContent = nbNonAudite;
      if (el('qualiopi-subtitle')) {
        el('qualiopi-subtitle').textContent = 'Referentiel National Qualite v9 · 32 indicateurs · NDA 93132464513';
      }

      // Render des 7 criteres
      var container = el('qualiopi-container');
      if (!container) return;

      // Grouper par critere
      var parCritere = {};
      allIndicateurs.forEach(function(i) {
        if (!parCritere[i.critere]) parCritere[i.critere] = { titre: i.critere_titre, items: [] };
        parCritere[i.critere].items.push(i);
      });

      var html = '';
      var criteres = Object.keys(parCritere).sort(function(a, b) { return parseInt(a) - parseInt(b); });
      criteres.forEach(function(cNum) {
        var crit = parCritere[cNum];
        var items = crit.items;
        var nbC_items = items.filter(function(i) { return i.statut === 'conforme'; }).length;
        var nbNC_items = items.filter(function(i) { return i.statut === 'nc_mineure' || i.statut === 'nc_majeure'; }).length;
        var nbNA_items = items.filter(function(i) { return i.statut === 'non_applicable'; }).length;
        var nbTodo_items = items.filter(function(i) { return i.statut === 'non_audite'; }).length;
        var totalAudit = items.length - nbNA_items;
        var pct = totalAudit > 0 ? Math.round((nbC_items / totalAudit) * 100) : 0;

        // Couleur barre progression
        var progCls = pct >= 90 ? 'green' : pct >= 60 ? 'gold' : '';
        var statusIcon = nbNC_items > 0 ? '⚠️' : (nbTodo_items > 0 ? '🕓' : '✅');

        html += '<div class="card" style="margin-bottom:12px">' +
          '<div class="card-h" style="display:flex;align-items:center;gap:12px">' +
            '<span class="card-title">' + statusIcon + ' Critere ' + cNum + ' — ' + escapeHtml(crit.titre) + '</span>' +
            '<div style="flex:1;display:flex;align-items:center;gap:8px;max-width:280px;margin-left:auto">' +
              '<div class="prog" style="flex:1"><div class="prog-fill ' + progCls + '" style="width:' + pct + '%"></div></div>' +
              '<span class="text-xs font-sb">' + pct + '%</span>' +
              '<span class="text-xs text-muted">(' + nbC_items + '/' + totalAudit + ')</span>' +
            '</div>' +
          '</div>' +
          '<div class="card-b" style="padding:0">';

        // Lignes d'indicateurs
        items.forEach(function(ind) {
          var info = statutInfo(ind.statut);
          var libelle = ind.libelle || '';
          if (libelle.length > 140) libelle = libelle.substring(0, 140) + '...';
          var dateVerif = ind.date_derniere_verif ? fmtDate(ind.date_derniere_verif) : 'Jamais';
          var ponderableBadge = ind.ponderable ? '<span class="badge b-gold" style="font-size:9px;margin-left:4px">ponderable</span>' : '';

          html += '<div class="quali-row" style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-top:1px solid #f1f5f9;cursor:pointer;transition:background 0.15s" ' +
              'onmouseover="this.style.background=\'#f8fafc\'" onmouseout="this.style.background=\'transparent\'" ' +
              'onclick="window.ardalosQualiopiEdit(\'' + ind.id + '\')">' +
            '<div style="flex:0 0 36px;font-weight:600;color:var(--ard-dark);font-size:13px;padding-top:2px">#' + ind.numero + '</div>' +
            '<div style="flex:1">' +
              '<div style="font-size:12px;line-height:1.4;color:#334155">' + escapeHtml(libelle) + ponderableBadge + '</div>' +
              (ind.notes ? '<div style="font-size:11px;color:#64748b;margin-top:4px;font-style:italic">📝 ' + escapeHtml(ind.notes.substring(0, 100)) + (ind.notes.length > 100 ? '...' : '') + '</div>' : '') +
              '<div style="font-size:10px;color:#94a3b8;margin-top:4px">Dernier audit : ' + dateVerif + (ind.verifie_par ? ' · ' + escapeHtml(ind.verifie_par) : '') + '</div>' +
            '</div>' +
            '<div style="flex:0 0 auto;text-align:right">' +
              '<span class="badge ' + info.cls + '" style="font-size:10px">' + info.icon + ' ' + info.label + '</span>' +
            '</div>' +
          '</div>';
        });

        html += '</div></div>';
      });

      container.innerHTML = html;
      console.log('[Ardalos Qualiopi] OK : ' + total + ' indicateurs, score ' + score + '%');
    } catch (e) {
      console.error('[Ardalos Qualiopi]', e);
      var container = document.getElementById('qualiopi-container');
      if (container) container.innerHTML = '<div style="padding:20px;color:#dc2626">Erreur: ' + escapeHtml(e.message) + '</div>';
    }
  }

  // ======================================================================
  // Modale edition
  // ======================================================================
  window.ardalosQualiopiEdit = function(id) {
    var ind = allIndicateurs.find(function(i) { return i.id === id; });
    if (!ind) return;
    currentEditId = id;

    document.getElementById('qualiopi-modal-title').textContent = 'Indicateur ' + ind.numero + ' — Critere ' + ind.critere;
    document.getElementById('qualiopi-modal-libelle').textContent = ind.libelle || '';
    document.getElementById('qualiopi-edit-statut').value = ind.statut || 'non_audite';
    document.getElementById('qualiopi-edit-verifie-par').value = ind.verifie_par || '';
    document.getElementById('qualiopi-edit-notes').value = ind.notes || '';
    document.getElementById('qualiopi-edit-preuves').value = ind.preuves || '';
    document.getElementById('qualiopi-edit-ponderable-info').style.display = ind.ponderable ? 'block' : 'none';
    document.getElementById('qualiopi-edit-error').style.display = 'none';
    if (typeof openModal === 'function') openModal('qualiopi-edit');
  };

  window.ardalosQualiopiSave = async function() {
    if (!currentEditId) return;
    var errEl = document.getElementById('qualiopi-edit-error');
    var btnEl = document.getElementById('qualiopi-edit-save');
    errEl.style.display = 'none';

    var payload = {
      statut: document.getElementById('qualiopi-edit-statut').value,
      verifie_par: document.getElementById('qualiopi-edit-verifie-par').value.trim() || null,
      notes: document.getElementById('qualiopi-edit-notes').value.trim() || null,
      preuves: document.getElementById('qualiopi-edit-preuves').value.trim() || null,
      date_derniere_verif: new Date().toISOString(),
      updated_at: new Date().toISOString(),
    };

    btnEl.disabled = true;
    btnEl.textContent = 'Enregistrement...';
    try {
      var r = await sb.from('qualiopi_indicateurs').update(payload).eq('id', currentEditId);
      if (r.error) throw r.error;
      if (typeof closeModal === 'function') closeModal('qualiopi-edit');
      loadQualiopi();
    } catch (e) {
      errEl.textContent = 'Erreur : ' + (e.message || 'inconnue');
      errEl.style.display = 'block';
      btnEl.disabled = false;
      btnEl.textContent = 'Enregistrer';
    }
  };

  // ======================================================================
  // Refresh + Export CSV
  // ======================================================================
  window.ardalosQualiopiRefresh = function() { loadQualiopi(); };

  window.ardalosQualiopiExport = function() {
    if (allIndicateurs.length === 0) { alert('Aucun indicateur a exporter'); return; }
    var rows = [['Numero','Critere','Titre critere','Libelle','Ponderable','Statut','Notes','Preuves','Verifie par','Date derniere verif']];
    allIndicateurs.forEach(function(i) {
      var info = statutInfo(i.statut);
      rows.push([
        i.numero, i.critere, i.critere_titre || '',
        (i.libelle || '').replace(/"/g, '""'),
        i.ponderable ? 'Oui' : 'Non',
        info.label,
        (i.notes || '').replace(/"/g, '""'),
        (i.preuves || '').replace(/"/g, '""'),
        i.verifie_par || '',
        i.date_derniere_verif ? fmtDate(i.date_derniere_verif) : ''
      ]);
    });
    var csv = rows.map(function(r) { return r.map(function(c) { return '"' + String(c) + '"'; }).join(';'); }).join('\n');
    var blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'qualiopi_' + new Date().toISOString().substring(0,10) + '.csv';
    a.click();
    URL.revokeObjectURL(url);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadQualiopi);
  } else {
    loadQualiopi();
  }
})();
</script>


<!-- === CONNEXION SUPABASE REPORTING + WORKFLOWS + CAMPAGNES === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  var COMMERCIAUX = ['Sylvain', 'David', 'Shaun', 'Jerome', 'Julien'];

  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtEuro(n) {
    if (!n || n === 0) return '0€';
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  function fmtDate(s) {
    if (!s) return '—';
    return new Date(s).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  // ======================================================================
  // REPORTING : KPI + sections performance/formation + repartition commerciaux
  // ======================================================================
  async function loadReporting() {
    try {
      var year = new Date().getFullYear();

      // Inscriptions
      var iR = await sb.from('formation_inscriptions').select('id, statut, statut_prospection, montant_total_ht, commercial_responsable, date_inscription, date_confirmation, contact_id, session_id, formation_sessions(date_debut, date_fin)');
      if (iR.error) throw iR.error;
      var inscriptions = iR.data || [];

      // Inscriptions YTD
      var insYTD = inscriptions.filter(function(i) {
        if (!i.date_inscription) return false;
        return new Date(i.date_inscription).getFullYear() === year;
      });

      var caRealise = 0, caPrev = 0;
      insYTD.forEach(function(i) {
        var mt = Number(i.montant_total_ht || 0);
        var s = i.statut;
        if (s === 'confirme' || s === 'present' || s === 'termine') caRealise += mt;
        if (s !== 'abandon' && s !== 'refuse') caPrev += mt;
      });

      var closes = insYTD.filter(function(i) { return i.statut === 'confirme' || i.statut === 'present' || i.statut === 'termine'; });
      var totalDeals = insYTD.filter(function(i) { return i.statut !== 'abandon'; }).length;
      var txClosing = totalDeals > 0 ? Math.round((closes.length / totalDeals) * 100) : 0;

      // Financements
      var fR = await sb.from('formation_financements').select('*');
      var financements = (fR.error ? [] : (fR.data || []));
      var financeAccorde = 0;
      financements.forEach(function(f) {
        if ((f.statut_dossier || '').toLowerCase().indexOf('accorde') === -1) return;
        if (f.date_decision && new Date(f.date_decision).getFullYear() !== year) return;
        financeAccorde += Number(f.montant_accorde || f.montant_ht || 0);
      });

      // Apprenants distincts YTD
      var contactsSet = new Set();
      insYTD.forEach(function(i) { if (i.contact_id && i.statut !== 'abandon') contactsSet.add(i.contact_id); });
      var nbApprenants = contactsSet.size;

      // Qualiopi score
      var qR = await sb.from('qualiopi_indicateurs').select('statut');
      var quali = (qR.error ? [] : (qR.data || []));
      var nbC = quali.filter(function(i) { return i.statut === 'conforme'; }).length;
      var nbNA = quali.filter(function(i) { return i.statut === 'non_applicable'; }).length;
      var auditable = quali.length - nbNA;
      var scoreQuali = auditable > 0 ? Math.round((nbC / auditable) * 100) : 0;

      var el = function(id) { return document.getElementById(id); };
      if (el('reporting-ca-realise')) {
        el('reporting-ca-realise').textContent = fmtEuro(caRealise);
        el('reporting-ca-realise-sub').textContent = 'YTD ' + year;
      }
      if (el('reporting-ca-previ')) {
        el('reporting-ca-previ').textContent = fmtEuro(caPrev);
        el('reporting-ca-previ-sub').textContent = 'Pipeline + realise';
      }
      if (el('reporting-closing')) {
        el('reporting-closing').textContent = txClosing + '%';
        el('reporting-closing-sub').textContent = closes.length + '/' + totalDeals + ' inscriptions';
      }
      if (el('reporting-qualiopi')) {
        el('reporting-qualiopi').textContent = scoreQuali + '%';
        el('reporting-qualiopi-sub').textContent = nbC + '/' + auditable + ' conformes';
      }
      if (el('reporting-finance')) el('reporting-finance').textContent = fmtEuro(financeAccorde);
      if (el('reporting-apprenants')) el('reporting-apprenants').textContent = nbApprenants;

      // Performance commerciale (sur YTD)
      var nbLeads = insYTD.filter(function(i) { return !i.statut_prospection || i.statut_prospection === 'a_contacter'; }).length;
      var nbQualif = insYTD.filter(function(i) { var s = i.statut_prospection; return s === 'interesse' || s === 'en_discussion' || s === 'dossier_en_cours'; }).length;
      var nbClosed = closes.length;
      var valeurMoy = nbClosed > 0 ? Math.round(closes.reduce(function(s, i) { return s + Number(i.montant_total_ht || 0); }, 0) / nbClosed) : 0;

      // Cycle vente moyen
      var cycleInscr = closes.filter(function(i) { return i.date_inscription && i.date_confirmation; });
      var cycleMoy = 0;
      if (cycleInscr.length > 0) {
        var total = cycleInscr.reduce(function(s, i) {
          return s + (new Date(i.date_confirmation) - new Date(i.date_inscription)) / 86400000;
        }, 0);
        cycleMoy = Math.round(total / cycleInscr.length);
      }

      var perfHtml =
        '<div class="si"><span class="si-l">Inscriptions YTD</span><span class="si-r font-sb">' + insYTD.length + '</span></div>' +
        '<div class="si"><span class="si-l">Leads</span><span class="si-r">' + nbLeads + '</span></div>' +
        '<div class="si"><span class="si-l">Qualifications en cours</span><span class="si-r">' + nbQualif + '</span></div>' +
        '<div class="si"><span class="si-l">Inscriptions closees</span><span class="si-r font-sb text-green">' + nbClosed + '</span></div>' +
        '<div class="si"><span class="si-l">Taux de closing</span><span class="si-r font-sb">' + txClosing + '%</span></div>' +
        '<div class="si"><span class="si-l">Valeur moyenne deal</span><span class="si-r font-sb">' + fmtEuro(valeurMoy) + '</span></div>' +
        '<div class="si"><span class="si-l">Cycle vente moyen</span><span class="si-r">' + cycleMoy + ' jours</span></div>';
      if (el('reporting-perf-commerciale')) el('reporting-perf-commerciale').innerHTML = perfHtml;

      // Formation & Financement
      var nbAfdas = financements.filter(function(f) { return (f.type_financement || '').toLowerCase().indexOf('afdas') !== -1; }).length;
      var nbAfdasAccorde = financements.filter(function(f) {
        return (f.type_financement || '').toLowerCase().indexOf('afdas') !== -1 &&
               (f.statut_dossier || '').toLowerCase().indexOf('accorde') !== -1;
      }).length;
      var txAfdasOK = nbAfdas > 0 ? Math.round((nbAfdasAccorde / nbAfdas) * 100) : 0;

      var nbAbandon = insYTD.filter(function(i) { return i.statut === 'abandon'; }).length;
      var txAbandon = insYTD.length > 0 ? ((nbAbandon / insYTD.length) * 100).toFixed(1) : '0';

      var formationHtml =
        '<div class="si"><span class="si-l">Apprenants formes YTD</span><span class="si-r font-sb">' + nbApprenants + '</span></div>' +
        '<div class="si"><span class="si-l">Dossiers financement total</span><span class="si-r">' + financements.length + '</span></div>' +
        '<div class="si"><span class="si-l">Dont AFDAS</span><span class="si-r">' + nbAfdas + '</span></div>' +
        '<div class="si"><span class="si-l">AFDAS accordes</span><span class="si-r font-sb text-green">' + nbAfdasAccorde + ' (' + txAfdasOK + '%)</span></div>' +
        '<div class="si"><span class="si-l">Score Qualiopi</span><span class="si-r font-sb text-green">' + scoreQuali + '%</span></div>' +
        '<div class="si"><span class="si-l">Taux abandon</span><span class="si-r">' + txAbandon + '%</span></div>' +
        '<div class="si"><span class="si-l">Financement accorde YTD</span><span class="si-r font-sb text-blue">' + fmtEuro(financeAccorde) + '</span></div>';
      if (el('reporting-formation-finance')) el('reporting-formation-finance').innerHTML = formationHtml;

      // Repartition par commercial
      var statsCom = {};
      COMMERCIAUX.forEach(function(c) { statsCom[c] = { ca: 0, nb: 0 }; });
      insYTD.forEach(function(i) {
        var c = i.commercial_responsable;
        if (!c || !statsCom[c]) return;
        if (i.statut !== 'abandon' && i.statut !== 'refuse') {
          statsCom[c].ca += Number(i.montant_total_ht || 0);
          statsCom[c].nb++;
        }
      });
      var maxCA = Math.max.apply(null, COMMERCIAUX.map(function(c) { return statsCom[c].ca; }).concat([1]));

      var comHtml = '<div style="display:flex;flex-direction:column;gap:10px">';
      COMMERCIAUX.sort(function(a, b) { return statsCom[b].ca - statsCom[a].ca; });
      COMMERCIAUX.forEach(function(c, idx) {
        var s = statsCom[c];
        var pct = maxCA > 0 ? Math.round((s.ca / maxCA) * 100) : 0;
        var medal = idx === 0 && s.ca > 0 ? '🥇 ' : idx === 1 && s.ca > 0 ? '🥈 ' : idx === 2 && s.ca > 0 ? '🥉 ' : '';
        comHtml += '<div>' +
          '<div class="flex items-c justify-b mb-1" style="font-size:12px">' +
            '<span class="font-sb">' + medal + escapeHtml(c) + '</span>' +
            '<span class="text-muted">' + s.nb + ' inscr. · <span class="font-sb text-blue">' + fmtEuro(s.ca) + '</span></span>' +
          '</div>' +
          '<div class="prog"><div class="prog-fill ' + (idx === 0 ? 'gold' : idx < 3 ? 'green' : '') + '" style="width:' + pct + '%"></div></div>' +
        '</div>';
      });
      comHtml += '</div>';
      if (el('reporting-par-commercial')) el('reporting-par-commercial').innerHTML = comHtml;

      console.log('[Ardalos Reporting] OK');
    } catch (e) {
      console.error('[Ardalos Reporting]', e);
    }
  }

  // ======================================================================
  // WORKFLOWS : stats email_logs
  // ======================================================================
  async function loadWorkflows() {
    try {
      var rC = await sb.from('email_logs').select('id', { count: 'exact', head: true });
      var total = rC.count || 0;

      // Ce mois
      var now = new Date();
      var moisDebut = new Date(now.getFullYear(), now.getMonth(), 1).toISOString();
      var rM = await sb.from('email_logs').select('*').gte('created_at', moisDebut);
      var emailsMois = (rM.error ? [] : (rM.data || []));

      var reussis = emailsMois.filter(function(e) { return e.success; }).length;
      var echecs = emailsMois.length - reussis;
      var txSucces = emailsMois.length > 0 ? Math.round((reussis / emailsMois.length) * 100) : 100;

      // Echecs totaux
      var rE = await sb.from('email_logs').select('id', { count: 'exact', head: true }).eq('success', false);
      var totalEchecs = rE.count || 0;

      var el = function(id) { return document.getElementById(id); };
      if (el('wf-subtitle')) el('wf-subtitle').textContent = total + ' email' + (total > 1 ? 's' : '') + ' envoye' + (total > 1 ? 's' : '') + ' au total · ' + emailsMois.length + ' ce mois';
      if (el('wf-kpi-total')) el('wf-kpi-total').textContent = total;
      if (el('wf-kpi-mois')) {
        el('wf-kpi-mois').textContent = emailsMois.length;
        el('wf-kpi-mois-sub').textContent = reussis + ' reussis · ' + echecs + ' echecs';
      }
      if (el('wf-kpi-succes')) el('wf-kpi-succes').textContent = txSucces + '%';
      if (el('wf-kpi-echecs')) el('wf-kpi-echecs').textContent = totalEchecs;

      console.log('[Ardalos Workflows] OK :', total, 'total,', emailsMois.length, 'ce mois');
    } catch (e) {
      console.error('[Ardalos Workflows]', e);
    }
  }

  // ======================================================================
  // CAMPAGNES : emails groupes par sujet
  // ======================================================================
  async function loadCampagnes() {
    try {
      var r = await sb.from('email_logs').select('*').order('created_at', { ascending: false });
      if (r.error) throw r.error;
      var logs = r.data || [];

      // Grouper par sujet
      var groupes = {};
      logs.forEach(function(l) {
        var sujet = l.sujet || '(Sans sujet)';
        if (!groupes[sujet]) {
          groupes[sujet] = { sujet: sujet, envois: 0, reussis: 0, echecs: 0, firstDate: null, lastDate: null };
        }
        var g = groupes[sujet];
        g.envois++;
        if (l.success) g.reussis++;
        else g.echecs++;
        if (!g.firstDate || l.created_at < g.firstDate) g.firstDate = l.created_at;
        if (!g.lastDate || l.created_at > g.lastDate) g.lastDate = l.created_at;
      });

      var campagnes = Object.values(groupes);
      campagnes.sort(function(a, b) { return (b.lastDate || '').localeCompare(a.lastDate || ''); });

      var subtitleEl = document.getElementById('camp-subtitle');
      var tbodyEl = document.getElementById('camp-tbody');
      if (!tbodyEl) return;

      if (subtitleEl) {
        subtitleEl.textContent = campagnes.length + ' campagne' + (campagnes.length > 1 ? 's' : '') + ' · ' + logs.length + ' email' + (logs.length > 1 ? 's' : '') + ' envoye' + (logs.length > 1 ? 's' : '');
      }

      if (campagnes.length === 0) {
        tbodyEl.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:#9ca3af;font-style:italic">Aucune campagne · Les emails envoyes depuis la plateforme apparaitront ici</td></tr>';
      } else {
        var rows = campagnes.map(function(c) {
          var txSucces = c.envois > 0 ? Math.round((c.reussis / c.envois) * 100) : 0;
          var statutBadge;
          if (c.echecs === 0) statutBadge = '<span class="badge b-green">Succes</span>';
          else if (c.reussis === 0) statutBadge = '<span class="badge b-red">Echec</span>';
          else statutBadge = '<span class="badge b-amber">Partiel</span>';

          var type = c.envois === 1 ? '<span class="badge b-navy">Email</span>' : '<span class="badge b-teal">Campagne (' + c.envois + ')</span>';

          return '<tr>' +
            '<td class="name-cell">' + escapeHtml(c.sujet) + '</td>' +
            '<td>' + type + '</td>' +
            '<td>' + statutBadge + '</td>' +
            '<td>' + c.envois + '</td>' +
            '<td class="font-sb ' + (txSucces >= 80 ? 'text-green' : txSucces >= 50 ? 'text-amber' : 'text-red') + '">' + txSucces + '%</td>' +
            '<td class="text-xs">' + c.reussis + ' / ' + c.echecs + '</td>' +
            '<td class="text-xs text-muted">' + fmtDate(c.lastDate) + '</td>' +
            '<td><button class="btn-s" style="font-size:11px;padding:3px 8px" disabled>Voir</button></td>' +
          '</tr>';
        });
        tbodyEl.innerHTML = rows.join('');
      }

      console.log('[Ardalos Campagnes] OK :', campagnes.length, 'campagnes /', logs.length, 'emails');
    } catch (e) {
      console.error('[Ardalos Campagnes]', e);
      var tbodyEl = document.getElementById('camp-tbody');
      if (tbodyEl) tbodyEl.innerHTML = '<tr><td colspan="8" style="padding:20px;color:#dc2626">Erreur: ' + escapeHtml(e.message) + '</td></tr>';
    }
  }

  function init() {
    loadReporting();
    loadWorkflows();
    loadCampagnes();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


<!-- === WORKFLOWS REELS + BOUTONS FONCTIONNELS === -->
<script>
(function() {
  var SUPABASE_URL = 'https://cvxzdiutxonnsnwoicqt.supabase.co';
  var SUPABASE_KEY = 'sb_publishable_J8ta-7L05zgK9rBy2OS9Bg_CjXHwZVK';
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) return;
  var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  var workflowsData = [];

  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function fmtDate(s) {
    if (!s) return '—';
    return new Date(s).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function fmtDateRel(s) {
    if (!s) return '—';
    var d = new Date(s);
    var now = new Date();
    var diff = Math.floor((now - d) / 86400000);
    if (diff === 0) return "Aujourd'hui";
    if (diff === 1) return 'Hier';
    if (diff < 7) return 'Il y a ' + diff + 'j';
    if (diff < 30) return 'Il y a ' + Math.floor(diff / 7) + 'sem';
    return fmtDate(s);
  }

  function fmtEuro(n) {
    if (!n || n === 0) return '0€';
    if (n >= 1000) return (n / 1000).toFixed(1).replace('.0', '') + 'k€';
    return Math.round(n) + '€';
  }

  // Info modale nouveau workflow
  window.ardalosWorkflowInfo = function() {
    if (typeof openModal === 'function') openModal('wf-info');
  };

  // ======================================================================
  // WORKFLOWS REELS : 5 workflows branches sur Supabase
  // ======================================================================
  async function loadWorkflowsReels() {
    var container = document.getElementById('wf-cards-container');
    if (!container) return;

    try {
      var now = new Date();
      var debutSemaine = new Date(now.getTime() - 7 * 86400000).toISOString();
      var debutMois = new Date(now.getFullYear(), now.getMonth(), 1).toISOString();
      var il30j = new Date(now.getTime() - 30 * 86400000).toISOString();

      // WF01 : contacts crees cette semaine + ce mois
      var cSem = await sb.from('contacts').select('id', { count: 'exact', head: true }).gte('created_at', debutSemaine);
      var cMois = await sb.from('contacts').select('id', { count: 'exact', head: true }).gte('created_at', debutMois);
      var derniersCont = await sb.from('contacts').select('prenom, nom, email, created_at').order('created_at', { ascending: false }).limit(5);

      // WF04 : dossiers AFDAS crees
      var afdasMois = await sb.from('formation_financements').select('id', { count: 'exact', head: true })
        .ilike('type_financement', '%afdas%').gte('created_at', debutMois);
      var afdasTotal = await sb.from('formation_financements').select('id', { count: 'exact', head: true })
        .ilike('type_financement', '%afdas%');
      var derniersAfdas = await sb.from('formation_financements')
        .select('id, type_financement, montant_ht, statut_dossier, created_at, formation_inscriptions(contacts(prenom, nom))')
        .ilike('type_financement', '%afdas%').order('created_at', { ascending: false }).limit(5);

      // WF05 : emails envoyes (via plateforme)
      var emailsMois = await sb.from('email_logs').select('id', { count: 'exact', head: true }).gte('created_at', debutMois);
      var emailsTotal = await sb.from('email_logs').select('id', { count: 'exact', head: true });
      var emailsReussis = await sb.from('email_logs').select('id', { count: 'exact', head: true }).eq('success', true);
      var derniersEmails = await sb.from('email_logs').select('sujet, destinataire, success, created_at').order('created_at', { ascending: false }).limit(5);

      // WF06 : sessions terminees recentes
      var hier = new Date(now.getTime() - 86400000).toISOString().substring(0, 10);
      var sessionsTerm = await sb.from('formation_sessions').select('id', { count: 'exact', head: true }).lt('date_fin', hier);
      var sessionsTerm30j = await sb.from('formation_sessions').select('id', { count: 'exact', head: true })
        .lt('date_fin', hier).gte('date_fin', il30j.substring(0, 10));
      var dernieresSessions = await sb.from('formation_sessions')
        .select('id, date_debut, date_fin, formations(titre)')
        .lt('date_fin', hier).order('date_fin', { ascending: false }).limit(5);

      // Definition des 4 workflows reels + 1 grise (Calendly)
      workflowsData = [
        {
          id: 'wf01',
          code: 'WF01',
          titre: 'Lead entrant : Suivi commercial',
          desc: 'Detection des nouveaux contacts pour attribution commerciale',
          actif: true,
          connecte: true,
          nbSemaine: cSem.count || 0,
          nbMois: cMois.count || 0,
          etapes: [
            { num: 'T', label: 'Declencheur : Contact cree', desc: 'Table contacts · INSERT detecte' },
            { num: '1', label: 'Deduplication email + telephone', desc: 'A faire manuellement pour le moment' },
            { num: '2', label: 'Lead scoring (manuel)', desc: 'Commercial qualifie le lead en pipeline' },
            { num: '3', label: 'Attribution commerciale', desc: 'Champ commercial_responsable dans l\'inscription' },
          ],
          derniersEvents: (derniersCont.data || []).map(function(c) {
            return {
              label: (c.prenom || '') + ' ' + (c.nom || ''),
              desc: c.email || '—',
              date: c.created_at,
            };
          }),
        },
        {
          id: 'wf04',
          code: 'WF04',
          titre: 'Dossier AFDAS : Traitement',
          desc: 'Suivi des dossiers AFDAS crees',
          actif: true,
          connecte: true,
          nbSemaine: null,
          nbMois: afdasMois.count || 0,
          nbTotal: afdasTotal.count || 0,
          etapes: [
            { num: 'T', label: 'Declencheur : Financement AFDAS cree', desc: 'Table formation_financements · type_financement AFDAS' },
            { num: '1', label: 'Verification categorie + volume', desc: 'Donnees AFDAS contact (categorie, cachets/jours)' },
            { num: '2', label: 'Suivi statut dossier', desc: 'Constitution → Depose → En instruction → Accorde' },
            { num: '3', label: 'Relances manuelles', desc: 'Automatisation J+5 / J+8 / J+12 en phase 2' },
          ],
          derniersEvents: (derniersAfdas.data || []).map(function(f) {
            var c = f.formation_inscriptions && f.formation_inscriptions.contacts ? f.formation_inscriptions.contacts : null;
            var nom = c ? ((c.prenom || '') + ' ' + (c.nom || '')).trim() : '(Sans contact)';
            return {
              label: nom,
              desc: f.type_financement + ' · ' + fmtEuro(Number(f.montant_ht || 0)) + ' · ' + (f.statut_dossier || 'En cours'),
              date: f.created_at,
            };
          }),
        },
        {
          id: 'wf02',
          code: 'WF02',
          titre: 'Lead Calendly → RDV auto',
          desc: 'Webhook Calendly pour creation automatique de contacts',
          actif: false,
          connecte: false,
          nbSemaine: null,
          nbMois: null,
          etapes: [
            { num: 'T', label: 'Webhook Calendly invitee.created', desc: 'NON BRANCHE (Phase 2)' },
            { num: '1', label: 'Recherche contact existant par email', desc: 'Deduplication auto' },
            { num: '2', label: 'Creation activite RDV', desc: 'Timeline + details' },
            { num: '3', label: 'Email confirmation + rappels', desc: 'Notifications programees' },
          ],
          derniersEvents: [],
        },
        {
          id: 'wf05',
          code: 'WF05',
          titre: 'Email dossier : Envoi & tracking',
          desc: 'Suivi des emails envoyes depuis la plateforme',
          actif: true,
          connecte: true,
          nbSemaine: null,
          nbMois: emailsMois.count || 0,
          nbTotal: emailsTotal.count || 0,
          txSucces: emailsTotal.count > 0 ? Math.round(((emailsReussis.count || 0) / emailsTotal.count) * 100) : 100,
          etapes: [
            { num: 'T', label: 'Declencheur : Email envoye', desc: 'Table email_logs · API /send-dossier-email' },
            { num: '1', label: 'Generation PDF du dossier', desc: 'Cloudmersive docx-to-pdf + fusion pdf-lib' },
            { num: '2', label: 'Envoi SMTP via Nodemailer', desc: 'Avec piece jointe PDF' },
            { num: '3', label: 'Log succes/echec', desc: 'Trace dans email_logs pour audit Qualiopi' },
          ],
          derniersEvents: (derniersEmails.data || []).map(function(e) {
            return {
              label: e.sujet || '(Sans sujet)',
              desc: 'Vers ' + (e.destinataire || '—') + ' · ' + (e.success ? '✓ Reussi' : '✗ Echec'),
              date: e.created_at,
            };
          }),
        },
        {
          id: 'wf06',
          code: 'WF06',
          titre: 'Cloture formation : Documents',
          desc: 'Sessions formation terminees (date_fin depassee)',
          actif: true,
          connecte: true,
          nbSemaine: null,
          nbMois: sessionsTerm30j.count || 0,
          nbTotal: sessionsTerm.count || 0,
          etapes: [
            { num: 'T', label: 'Declencheur : Session terminee', desc: 'formation_sessions WHERE date_fin < today' },
            { num: '1', label: 'Generation attestations (manuel)', desc: 'Via module Documents du CRM' },
            { num: '2', label: 'Envoi questionnaire satisfaction', desc: 'Formulaire Google Forms externe' },
            { num: '3', label: 'Update Qualiopi indicateur 11', desc: 'Evaluation de l\'atteinte des objectifs' },
          ],
          derniersEvents: (dernieresSessions.data || []).map(function(s) {
            var titre = s.formations ? s.formations.titre : 'Session';
            return {
              label: titre,
              desc: 'Du ' + fmtDate(s.date_debut) + ' au ' + fmtDate(s.date_fin),
              date: s.date_fin,
            };
          }),
        },
      ];

      // Render
      var html = '';
      workflowsData.forEach(function(wf) {
        var statutBadge = !wf.connecte
          ? '<span class="badge b-gray">Non connecte</span>'
          : wf.actif
            ? '<span class="badge b-green">Actif</span>'
            : '<span class="badge b-amber">Inactif</span>';

        var metric = '';
        if (wf.nbSemaine !== null && wf.nbSemaine !== undefined) {
          metric = wf.nbSemaine + ' cette semaine · ' + wf.nbMois + ' ce mois';
        } else if (wf.nbMois !== null && wf.nbMois !== undefined) {
          metric = wf.nbMois + ' ce mois';
          if (wf.nbTotal !== undefined) metric += ' · ' + wf.nbTotal + ' au total';
          if (wf.txSucces !== undefined) metric += ' · ' + wf.txSucces + '% succes';
        } else {
          metric = wf.connecte ? '0 execution' : 'Non branche';
        }

        html += '<div class="card" ' + (!wf.connecte ? 'style="opacity:0.6"' : '') + '>' +
          '<div class="card-h"><span class="card-title">' + wf.code + ' — ' + escapeHtml(wf.titre) + '</span>' + statutBadge + '</div>' +
          '<div class="card-b">';

        wf.etapes.forEach(function(e, idx) {
          var numClass = e.num === 'T' ? 'trigger' : (e.num === 'C' ? 'condition' : '');
          html += '<div class="wf-step"><div class="wf-num ' + numClass + '">' + e.num + '</div>' +
            '<div class="wf-content"><div class="wf-title">' + escapeHtml(e.label) + '</div>' +
            '<div class="wf-desc">' + escapeHtml(e.desc) + '</div></div></div>';
          if (idx < wf.etapes.length - 1) html += '<div class="wf-arrow">↓</div>';
        });

        html += '</div>' +
          '<div class="card-f">' +
            '<span class="text-xs text-muted">' + escapeHtml(metric) + '</span>' +
            '<button class="btn-s" style="font-size:11px;margin-left:auto" data-wf-id="' + wf.id + '" onclick="window.ardalosWorkflowDetail(this.dataset.wfId)"' + (!wf.connecte ? ' disabled' : '') + '>' + (wf.connecte ? 'Voir executions' : 'Indisponible') + '</button>' +
          '</div>' +
        '</div>';
      });

      container.innerHTML = html;
      console.log('[Ardalos Workflows Reels] OK :', workflowsData.length, 'workflows');
    } catch (e) {
      console.error('[Ardalos Workflows Reels]', e);
      container.innerHTML = '<div style="grid-column:1/-1;padding:20px;color:#dc2626">Erreur: ' + escapeHtml(e.message) + '</div>';
    }
  }

  // ======================================================================
  // Modale detail workflow (reutilise modal-detail)
  // ======================================================================
  window.ardalosWorkflowDetail = function(wfId) {
    var wf = workflowsData.find(function(w) { return w.id === wfId; });
    if (!wf) return;

    var titleEl = document.getElementById('detail-modal-title');
    var bodyEl = document.getElementById('detail-modal-body');
    if (!titleEl || !bodyEl) { alert('Modale detail introuvable'); return; }

    titleEl.textContent = wf.code + ' — ' + wf.titre;

    var html = '<div style="padding:12px;background:#f1f5f9;border-radius:8px;margin-bottom:14px;font-size:13px;color:#475569">' +
      escapeHtml(wf.desc) + '</div>';

    html += '<div class="font-sb" style="font-size:13px;margin-bottom:10px;color:var(--ard-dark)">Dernieres executions reelles</div>';

    if (wf.derniersEvents.length === 0) {
      html += '<div style="padding:20px;text-align:center;color:#9ca3af;font-style:italic">Aucune execution enregistree pour le moment</div>';
    } else {
      html += '<div style="display:flex;flex-direction:column;gap:8px">';
      wf.derniersEvents.forEach(function(ev) {
        html += '<div style="padding:10px 12px;border:1px solid #e5e7eb;border-radius:8px;font-size:12px">' +
          '<div class="flex items-c justify-b">' +
            '<span class="font-sb" style="color:var(--ard-dark)">' + escapeHtml(ev.label) + '</span>' +
            '<span class="text-xs text-muted">' + fmtDateRel(ev.date) + '</span>' +
          '</div>' +
          '<div class="text-xs text-muted" style="margin-top:3px">' + escapeHtml(ev.desc) + '</div>' +
        '</div>';
      });
      html += '</div>';
    }

    html += '<div style="margin-top:16px;padding:12px;background:#fef3c7;border:1px solid #fde68a;border-radius:8px;font-size:11px;color:#78350F">' +
      '<strong>⚙ Automatisation :</strong> Ce workflow est actuellement en mode <em>suivi</em>. ' +
      'L\'automatisation complete (triggers auto, actions enchainees) sera livree en Phase 2 ' +
      'apres la certification Qualiopi.' +
    '</div>';

    bodyEl.innerHTML = html;
    if (typeof openModal === 'function') openModal('detail');
  };

  // ======================================================================
  // Export Reporting CSV
  // ======================================================================
  window.ardalosReportingExport = async function() {
    try {
      var year = new Date().getFullYear();
      var iR = await sb.from('formation_inscriptions').select('id, statut, statut_prospection, montant_total_ht, commercial_responsable, date_inscription, contacts(prenom, nom, email), formation_sessions(date_debut, formations(titre))');
      var inscriptions = (iR.error ? [] : (iR.data || []));

      var rows = [['Date inscription','Stagiaire','Email','Formation','Commercial','Statut','Statut prospection','Montant HT']];
      inscriptions.forEach(function(i) {
        var c = i.contacts || {};
        var f = i.formation_sessions && i.formation_sessions.formations ? i.formation_sessions.formations.titre : '—';
        rows.push([
          i.date_inscription ? fmtDate(i.date_inscription) : '',
          ((c.prenom || '') + ' ' + (c.nom || '')).trim(),
          c.email || '',
          f,
          i.commercial_responsable || '',
          i.statut || '',
          i.statut_prospection || '',
          String(i.montant_total_ht || 0).replace('.', ','),
        ]);
      });

      var csv = rows.map(function(r) { return r.map(function(c) { return '"' + String(c).replace(/"/g, '""') + '"'; }).join(';'); }).join('\n');
      var blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = 'reporting_' + year + '_' + new Date().toISOString().substring(0,10) + '.csv';
      a.click();
      URL.revokeObjectURL(url);
      console.log('[Ardalos Reporting Export] ' + inscriptions.length + ' inscriptions');
    } catch (e) {
      alert('Erreur export : ' + (e.message || 'inconnue'));
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadWorkflowsReels);
  } else {
    loadWorkflowsReels();
  }
})();
</script>

</body>
</html>
