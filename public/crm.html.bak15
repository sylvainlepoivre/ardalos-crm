<div class="modal-ov" id="modal-qualiopi-edit">
  <div class="modal" style="max-width:640px">
    <div class="modal-h">
      <span class="modal-title" id="qualiopi-modal-title">Indicateur</span>
      <button class="modal-close" onclick="closeModal('qualiopi-edit')">✕</button>
    </div>
    <div class="modal-b">
      <div id="qualiopi-modal-libelle" style="font-size:13px;color:#475569;line-height:1.5;padding:10px;background:#f1f5f9;border-radius:8px;margin-bottom:14px"></div>
      <div class="fg">
        <label class="flabel">Statut <span class="req">*</span></label>
        <select class="fselect" id="qualiopi-edit-statut">
          <option value="non_audite">🕓 Non audite</option>
          <option value="conforme">✅ Conforme</option>
          <option value="nc_mineure">⚠️ Non-conformite mineure</option>
          <option value="nc_majeure">🔴 Non-conformite majeure</option>
          <option value="non_applicable">➖ Non applicable</option>
        </select>
        <div id="qualiopi-edit-ponderable-info" style="display:none;font-size:11px;color:#78350F;margin-top:4px">ℹ️ Cet indicateur peut etre pondere (NC mineure ou NC majeure)</div>
      </div>
      <div class="fg">
        <label class="flabel">Verifie par</label>
        <input type="text" class="finput" id="qualiopi-edit-verifie-par" placeholder="Nom du responsable interne">
      </div>
      <div class="fg">
        <label class="flabel">Notes / Elements de preuve</label>
        <textarea class="finput" id="qualiopi-edit-notes" rows="3" placeholder="Commentaires, plan d'action, remarques auditeur..."></textarea>
      </div>
      <div class="fg">
        <label class="flabel">Liens vers preuves (URL, chemins documents)</label>
        <textarea class="finput" id="qualiopi-edit-preuves" rows="2" placeholder="https://drive.google.com/... ou nom des fichiers"></textarea>
      </div>
      <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:16px">
        <button class="btn-s" onclick="closeModal('qualiopi-edit')">Annuler</button>
        <button class="btn-p" id="qualiopi-edit-save" onclick="window.ardalosQualiopiSave()">Enregistrer</button>
      </div>
      <div id="qualiopi-edit-error" style="margin-top:10px;color:#dc2626;font-size:12px;display:none"></div>
    </div>
  </div>
</div>

