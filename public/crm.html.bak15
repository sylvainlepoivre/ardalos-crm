      </div>

            <!-- AFDAS Barème Calculator -->
      <div class="card card-accent-gold mt-2">
        <div class="card-h"><span class="card-title" style="color:var(--ard-gold)">⚡ Calculateur rapide — Barèmes & Budget</span></div>
